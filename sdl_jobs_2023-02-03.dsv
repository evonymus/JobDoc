  || ', Address ID:' || sh.to_shpg_loc_cd
  || ' , City: ' || sh.to_cty_name
  || ', In case of any questions on the products mentioned in this mail, or if you want to unsubscribe, please contact the Delivery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from shpm_t sh
--inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join rfrc_num_t drf on drf.shpm_id = sh.shpm_id
inner join dom_val_t ddm on ddm.val_enu = drf.rfrc_num_typ and ddm.val_cd='DLRCD'
left join ( select max(mn.mntr_acty_id) as mntr_acty_id
    , mn.shpm_num
     from mntr_acty_t mn, shpm_t xsh
     where xsh.shpm_num = mn.shpm_num
        and substr(nvl(mn.alrt_text,'Nil'),1,9) = 'MSG:CDD2:'
        and  mn.alrt_typ_cd='CSL_'  || xsh.to_shpg_loc_cd
    group by mn.shpm_num
) aa on aa.shpm_num = sh.shpm_num
left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
left join rfrc_num_t rf
   -- inner join to the left joined reference table
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where sh.cur_optlstat_id < 260 -- delivered
and regexp_like(substr(nvl(sh.rfrc_num3,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and substr(nvl(sh.rfrc_num3, 'Nil'),1,10) > '2022-05-26'
-- alert type aleady defined
and exists (select * from alrt_typ_t at
    where at.alrt_typ_cd = 'CSL_'|| sh.to_shpg_loc_cd
	)
-- ver 1.2
-- Marek Dziekanski 2022-06-21 10:54
and substr(nvl(mna.alrt_text,'NULL'),1,19) != ('MSG:CDD2:' || substr(sh.rfrc_num3,1,10))
