     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <ReferenceNumberTypeCode></ReferenceNumberTypeCode>
     <ReferenceNumber></ReferenceNumber>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=LD_LEG_ID;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE; {R}{R}Update OCEANBKLD Reference Number{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}3{R}UPD_LD_OCEANVSLD{R}{R}{R}UPD_LD_OCEANVSLD{R}RFRC_LD{R}select distinct to_char(sd1.ld_leg_id) as ld_leg_id
	, tr.vesl as REF_NUM
, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
 end as activity
, 'OCEANVSLD' as code
FROM LD_LEG_T LD
inner join trip_t tr on tr.trip_id = ld.trip_id
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join ld_leg_detl_t sd1 on sd1.shpm_id = sd.shpm_id 
left join rfrc_num_t rf 
    inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'OCEANVSLD'
on rf.ld_leg_id = sd1.ld_leg_id
where tr.vesl is not null
and sd1.ld_leg_id is not null
and tr.rfrc_num1 is not null
and ld.cur_optlstat_id < 345 -- not completed yet
and trim(nvl(rf.rfrc_num,'Nil')) != trim(tr.vesl)
-- ver. 1.1
-- Marek Dziekanski 2022-03-01 17:03
order by ld_leg_id 
