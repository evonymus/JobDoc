{R}AlertData.EntityID=STOP_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_TYPE_CODE; {R}{R}ALRT_ADD_MZ{R}processGenerateAlert{R}API{EOL}SDL_ALRT_BBC{R}1{R}SDL_ALRT_BBC{R}{R}{R}ALRT_BBC{R}{R}select  to_char(sh.shpm_id) as shpm_id
, 'MSG:BBC:' ||  ' Chassis No: ' || sh.shpm_num 
  || ', Customer Name: ' || cs.cust_name
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from shpm_t sh
join cust_t cs on cs.cust_cd = sh.cust_cd
join addr_t ad on ad.addr_id = sh.to_addr_id
join shpg_loc_t sl on sl.shpg_loc_cd = sh.frm_shpg_loc_cd
where upper(nvl(sl.extl_cd2, 'Nil')) = 'BB'
-- load with in-transit status
and exists (select 1 from ld_leg_detl_t sd
   join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
   where sd.shpm_id = sh.shpm_id
   and ld.cur_optlstat_id = 335 -- in transit
)
-- the stop has not been alerted yet
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.shpm_num = sh.shpm_num
  and mon.alrt_typ_cd ='RPT_BBC'
  and substr(nvl(mon.alrt_text,'NULL'),1,8) = 'MSG:BBC:' 
  -- ver 1.0
  -- Marek Dziekanski, 2021-02-24
)


{R}{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT; {R}D:\JobTemplates\alrt_bbc.xml{R}Report Body Build Shipment Sent{R}processGenerateAlert{R}API{EOL}SDL_ALRT_BK_RTNG_INVALID_MZ{R}1{R}SDL_ALRT_BK_RTNG_INVALID_MZ{R}{R}{R}ALRT_BK_RTNG_INVALID_MZ{R}ALRT_BOOKING{R}select distinct to_char(tp.trip_id) as entity_id
, cast('BK_RTNG_INVALD_MZ' as varchar2(20)) as alrt_code
, 'MSG:BKFL:' || nvl(to_char(tp.ratd_dtt, 'yyyy-mm-dd hh24:mi:ss'), '0000-00-00 00:00:00')
    || ', Booking No:' || to_char(tp.trip_id)
    || ', Carrier:' || nvl(tp.carr_cd, 'Nil')
    || ', Original Location:' || nvl(tp.frst_shpg_loc_cd,'Nil')
    || ', Vessel:' || nvl(tp.vesl,'Nil')
    || ', Voyage:' || nvl(tp.voyg_num, 'Nil')
    || ', Vessel Dep. Loc:' || nvl(tp.dptr_shpg_loc_cd, 'Nil')
    || ', Vessel Arvl Loc:' || nvl(tp.arvl_shpg_loc_cd, 'Nil')
as text
from trip_t tp
-- only shipments from MZZ
inner join (select xtp.trip_id 
    from ld_leg_t xld, ld_leg_detl_t xsd, shpm_t xsh, trip_t xtp
    where  xsd.ld_leg_id = xld.ld_leg_id
    and  xsh.shpm_id = xsd.shpm_id
    and xld.trip_id = xtp.trip_id
    and xsh.frm_shpg_loc_cd = 'MZ') aa on aa.trip_id = tp.trip_id
where tp.lgst_grp_cd = 'SEU'
and tp.ratg_vlid_yn = 'F'
-- not picked yet
-- ver 1.1
-- Marek Dziekanski 2022-05-25 09:09
and tp.cur_optlstat_id < 2410
{R}<?xml version="1.0" encoding="UTF-8"?>
<CISDocument>
	<ApiHeader>
		<OperationName>processGenerateAlert</OperationName>
	</ApiHeader>
   <AlertData>
      <EntityID></EntityID>         
      <AlertTypeCode></AlertTypeCode>
      <AlertEntityTypeEnumVal>ALERTENTTYPE_BOOKING</AlertEntityTypeEnumVal>
      <AlertSeverityEnumVal>ALRTSVRTY_GREEN</AlertSeverityEnumVal>
      <AlertText></AlertText>	   	
   </AlertData>
</CISDocument>
{R}AlertData.EntityID=ENTITY_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_CODE; {R}{R}Alert Booking Rating Invalid for MZ{R}processGenerateAlert{R}API{EOL}SDL_ALRT_CDD2_MA{R}1{R}SDL_ALRT_CDD2_MA{R}{R}{R}ALRT_CDD2_MA{R}ALRT_SHPM{R}select distinct to_char(sh.shpm_id) as shpm_id
,'RPT_CDD2_MA' as alrt_type_code
, 'MSG:CDD2:' || substr(sh.rfrc_num3,1,10) 
  || ', Chassis No: ' || SD.SHPM_NUM 
  || ' , Customer Name: ' || sd.cust_name
  || ' , Dealer Code: ' || nvl(substr(drf.rfrc_num, instr(drf.rfrc_num, '-') + 1), ' ')
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ', Address ID:' || sh.to_shpg_loc_cd
  || ' , City: ' || sh.to_cty_name
  as text
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
left join rfrc_num_t drf 
	inner join dom_val_t ddm on ddm.val_enu = drf.rfrc_num_typ and ddm.val_cd='DLRCD'
on drf.shpm_id = sd.shpm_id
-- select the last record with the alert to compare
left join ( select max(mn.mntr_acty_id) as mntr_acty_id
		, mn.shpm_num
		 from mntr_acty_t mn,  shpm_t xsh
		 where xsh.shpm_num = mn.shpm_num
				and mn.alrt_typ_cd = 'RPT_CDD2_MA'  
	group by mn.shpm_num
) aa on aa.shpm_num = sh.shpm_num
left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
left join rfrc_num_t rf 
 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where sh.cur_optlstat_id < 260 -- delivered
and sh.frm_shpg_loc_cd = 'MA'
and regexp_like(substr(nvl(sh.rfrc_num3,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and substr(sh.rfrc_num3,1,10) > '2022-06-09'
-- ver 1.0.3
-- Marek Dziekanski 2022-05-31 10:17
and substr(nvl(mna.alrt_text,'NULL'),1,19) != ('MSG:CDD2:' || substr(sh.rfrc_num3,1,10)){R}<?xml version="1.0" encoding="UTF-8"?>
<CISDocument>
	<ApiHeader>
		<OperationName>processGenerateAlert</OperationName>
	</ApiHeader>
   <AlertData>
      <EntityID></EntityID>         
      <AlertTypeCode></AlertTypeCode>
      <AlertEntityTypeEnumVal>ALERTENTTYPE_SHIPMENT</AlertEntityTypeEnumVal>
      <AlertText></AlertText>	   
      <AlertSeverityEnumVal>ALRTSVRTY_YELLOW</AlertSeverityEnumVal>	
   </AlertData>
</CISDocument>
