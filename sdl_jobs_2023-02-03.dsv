-- and FND different to Pickup From Date
and substr(trim(upper(sh.rfrc_num19)), 1, 16) != to_char(sh.frm_pkup_dtt, 'yyyy-mm-dd"T"hh24:mi')


{R}{R}{R}{R}SEU PFD/FND STEP 4: Chain, update Pickup using FND{R}{R}Chaining{EOL}{R}6{R}SEU_CHN_UPD_EXTE2{R}SEU_RRT_UNSPND_SHGFLG_01{R}I_UPD_PICKUP_FROM_EXTE2,I_SET_SHPFLG_01,I_UPD_PDEVCD{R}SEU_CHN_UPD_EXTE2{R}{R}select sh.shpm_num as shpm_num
, to_date(substr(rf.rfrc_num, 1, 16), 'yyyy-mm-dd"T"hh24:mi') as pk_frm
, to_date(substr(rf.rfrc_num, 1, 10), 'yyyy-mm-dd') + 1438/1440 +
			case to_char(to_date(substr(rf.rfrc_num,1,10),'yyyy-mm-dd'), 'DY','NLS_DATE_LANGUAGE = ENGLISH')
					when 'SAT' then 2
					when 'SUN' then 1
					else 0
			end
as pk_to
, to_date(substr(rf.rfrc_num, 1, 16), 'yyyy-mm-dd"T"hh24:mi') + 1/1440 as del_frm
, to_date(substr(rf.rfrc_num, 1, 10), 'yyyy-mm-dd') + 1439/1440 +
			case to_char(to_date(substr(rf.rfrc_num,1,10),'yyyy-mm-dd'), 'DY','NLS_DATE_LANGUAGE = ENGLISH')
					when 'SAT' then 2
					when 'SUN' then 1
					else 0
			end
as del_to
-- Handling Product Deviations
, sh.shpm_num as ref_key
 , case validate_conversion(substr(nvl(sh.rfrc_num6,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
   -- WHEN CRD set to a date
   when 1 then
      case greatest(substr(rf.rfrc_num, 1,10), substr(sh.rfrc_num6, 1,10))
        -- when FND > CRD set it to 4
        when substr(rf.rfrc_num, 1,10) then cast('4' as varchar2(70))
        else
          -- if DEVCD set to 4, set it to 8
          case substr(nvl(prf.rfrc_num,'Nil'),1,1)
            when '4' then cast('8' as varchar2(70))
            else nvl(prf.rfrc_num, 'Nil')
          end
      end
   else nvl(sh.rfrc_num6,'Nil')
   end as devcd_ref_num
, case nvl(prf.rfrc_num_id,0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as devcd_action
, prf.rfrc_num_id as devcd_ref_id

from shpm_t sh
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'EXTE2'

left join rfrc_num_t prf
  inner join dom_val_t pdm on pdm.val_enu = prf.rfrc_num_typ and pdm.val_cd = 'PDEVCD'
on prf.shpm_id = sh.shpm_id
--  EXTE2 (body builder) date set
where validate_conversion(nvl(rf.rfrc_num,'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
-- make sure, the date in rfrc_num is specified in the correct format
and  regexp_like(substr(nvl(rf.rfrc_num,'Nil'),1,16),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]')
and sh.cur_optlstat_id < 230 --picked
-- ver. 1.5
-- Marek Dziekanski 2023-02-01 10:55
-- and EXTE2 (to body build loc.) day different to pickup date
and substr(rf.rfrc_num, 1, 17) != to_char(sh.frm_pkup_dtt,'yyyy-mm-dd"T"hh24:mi')
{R}{R}{R}{R}Update Delivery Window using EXTE2 reference field{R}{R}Chaining{EOL}{R}7{R}SEU_RRT_UNSPND_SHGFLG_01{R}SEU_RRT_BKGS_SHPFLG_01{R}{R}SEU_RRT_UNSPD_SHGFLG_01{R}{R}select to_char(ld.ld_leg_id) as leg_id
, nvl(ld.last_sec_cd, 'SUSP') as sec_cd
, current_date as dtt
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where upper(ld.ratg_vlid_yn) = 'F'
  and sh.lgst_grp_cd = 'SEU'
  and ld.sus_func_enu  > 1 -- 1=unsuspended
  and sh.cur_optlstat_id < 260 --delivered
  and rf.rfrc_num = '01' -- flag set for that job
--ver 1.1
-- Marek Dziekanski 2021-04-21 11:40
order by 1
{R}{R}SystemLoadID=LEG_ID;SECInformation.SECCode=SEC_CD;SECInformation.MovementDateTime=DTT; {R}D:\JobTemplates\rrt_unspnd.xml{R}SEU PFD/FND STEP 4.1: Unsuspend SEU loads{R}processLoadUnSuspend{R}API{EOL}{R}8{R}SEU_RRT_BKGS_SHPFLG_01{R}SEU_RRT_LDS_SHPFLG_01{R}{R}SEU_RRT_BKGS_SHPFLG_01{R}{R}select to_char(tp.trip_id) as trip_id
from trip_t tp
-- linked with a shipment that hasn't been delivered yet
where tp.lgst_grp_cd = 'SEU'
and exists (select 1 from ld_leg_t ld 
  join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
  join shpm_t sh on sh.shpm_id = sd.shpm_id
  join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
  join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
  where  ld.trip_id = tp.trip_id
    and sh.lgst_grp_cd = 'SEU'
    and ld.cur_optlstat_id < 345
    and sh.cur_optlstat_id < 260 -- delivered
    and rf.rfrc_num = '01' -- flag set for that job
-- ver: 2.2
-- Marek Dziekanski 2021-09-01 16:10
) order by trip_id

{R}{R}TripRateData.SystemTripID=TRIP_ID;{R}D:\JobTemplates\rrt_bkgs.xml{R}SEU PFD/FND STEP 5: Re-rate bookings for SHPFLG 01{R}processTripRate{R}API{EOL}{R}9{R}SEU_RRT_LDS_SHPFLG_01{R}SEU_CHN_SET_PLTRGTDT_1ST_LEG{R}{R}SEU_RRT_LDS_SHPFLG_01{R}RRT_ALL{R}select to_char(ld.ld_leg_id) as leg_id
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where ld.cur_optlstat_id < 345
and ld.lgst_grp_cd = 'SEU'
and rf.rfrc_num = '01'
  and not exists (select 1 from trip_t tt
  where tt.trip_id = ld.trip_id
-- ver 2.1
-- Marek Dziekanski datetime
) order by leg_id
  {R}<?xml version="1.0"?><CISDocument>
	<LoadRateData>
	<SystemLoadID></SystemLoadID>
	</LoadRateData>
	<IDsAreReferenceNumbersFlag>false</IDsAreReferenceNumbersFlag>
	<KeepSpotRateFlag>true</KeepSpotRateFlag>
	<SupressDetailedResultsFlag>true</SupressDetailedResultsFlag>
        <ApplyResourceConstraintsFlag>true</ApplyResourceConstraintsFlag>
   <ValidateCarrierServiceEquipmentFlag>false</ValidateCarrierServiceEquipmentFlag>
</CISDocument>

{R}LoadRateData.SystemLoadID=LEG_ID;{R}{R}SEU PFD/FND STEP 6: Re-rates loads SHPFLG 01{R}processLoadRate{R}API{EOL}{R}10{R}SEU_CHN_SET_PLTRGTDT_1ST_LEG{R}SEU_CHN_UPD_CDD2{R}I_SET_PLTRGTDT_DATE,I_SET_PLTRGTDTL_DATE{R}SEU_CHN_SET_PLTRGTDT_1ST_LEG{R}{R}select sd.shpm_num, sd.ld_leg_detl_id, sh.rfrc_num19
, to_char(ld.ld_leg_id) as ld_leg_id
, sd.seq_num
, aa.mn_end_dtt
, rf.rfrc_num_id
, case nvl(rf.rfrc_num_id,0)
   when 0 then 'AT_ADD'
   else 'AT_UPDATE'
end as activity
, to_char(st.last_cmpd_arvl_dtt, 'yyyy-mm-dd"T"hh24:mi:ss') as rfrc_num
, 'PLTRGTDT' as type_code
, lf.rfrc_num_id as l_rfrc_num_id
, case nvl(lf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
end as l_activity
, 'PLNTRGDTL' as l_type_code
from ld_leg_detl_t sd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join stop_t st on st.stop_id = sd.drop_stop_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
-- shfplg = 01
inner join rfrc_num_t rrf on rrf.shpm_id = sh.shpm_id
inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ
	and ddm.val_cd = 'SHPFLG'
	and rrf.rfrc_num = '01'
inner join (select xsd.shpm_id, min(xld.end_dtt) as mn_end_dtt
    from ld_leg_detl_t xsd
    inner join ld_leg_t xld on xld.ld_leg_id = xsd.ld_leg_id
    group by xsd.shpm_id) aa on aa.shpm_id = sh.shpm_id
left join rfrc_num_t rf
   -- inner join linking rf with dm
   inner join dom_val_t dm
      on rf.rfrc_num_typ = dm.val_enu
      and dm.val_cd is NOT NULL
      and dm.val_cd='PLTRGTDT'
-- completing left join of rf with ld_detl
on rf.ld_leg_detl_id = sd.ld_leg_detl_id
left join  rfrc_num_t lf
inner join dom_val_t lm on lm.val_enu= lf.rfrc_num_typ and lm.val_cd = 'PLNTRGDTL'
on lf.ld_leg_id = sd.ld_leg_id
where sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd
and validate_conversion(nvl(sh.rfrc_num19,'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') =1 -- FND set
and ld.lgst_grp_cd = 'SEU'
and ld.cur_optlstat_id between 305  and 330-- Tendeered
-- ver 1.5
-- Marek Dziekanski 2022-11-09 15:35
and nvl(rf.rfrc_num, 'Nil') != to_char(st.last_cmpd_arvl_dtt, 'yyyy-mm-dd"T"hh24:mi:ss')


{R}{R}{R}{R}Set PLTRGT Date for Load and Shipment Leg{R}{R}Chaining{EOL}{R}11{R}SEU_CHN_UPD_CDD2{R}SEU_CDD2_UPT_SHPM{R}I_SEU_UPD_CDD2{R}SEU_CHN_UPD_CDD2{R}{R}select distinct sh.shpm_num as ref_key
, case greatest(trunc(st.last_cmpd_arvl_dtt), to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss'))
   -- when cdd is later no CDD2 is necessary
   when to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss') then 'Nil'
      -- otherwise set cdd2 to stop date
   else to_char(trunc(st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
  end as cdd2_ref_num
, case nvl(rf.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE'
  end as cdd2_action
, to_char(rf.rfrc_num_id) as cdd2_ref_id
 , case greatest(trunc(st.last_cmpd_arvl_dtt), to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss'))
   -- when cdd is later then if CDD2 was set set DEVCD to 8 otherwise set it to nil
   when to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss') then case  trim(upper(nvl(sh.rfrc_num3,'NIL')))
                                                                  when 'NIL' then 'Nil'
                                                                  else '8'
                                                               end
-- if delivery is late set DEVCD to 4
   else '4'
  end as devcd_ref_num
, case nvl(rfd.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE'
  end as devcd_action
, to_char(rfd.rfrc_num_id) as devcd_ref_id
from stop_t st
inner join ld_leg_detl_t sd on sd.drop_stop_id = st.stop_id
-- it is the last leg
inner join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
-- report CDD2 only for shipments having updated PEAD/EAD/PFD/FND
inner join rfrc_num_t rrf on rrf.shpm_id = sh.shpm_id
inner join dom_val_t ddm on ddm.val_enu=rrf.rfrc_num_typ and ddm.val_cd='SHPFLG'
-- joining CDD2 reference
left join rfrc_num_t rf
  inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd is not null and dm.val_cd='CDD2'
on rf.shpm_id = sh.shpm_id
-- joining reference with DEVCD
left join rfrc_num_t rfd
  inner join dom_val_t dmd on rfd.rfrc_num_typ = dmd.val_enu and dmd.val_cd is not null and dmd.val_cd='PDEVCD'
on rfd.shpm_id = sh.shpm_id
where  st.shpm_drop > 0
and rrf.rfrc_num = '01' -- flag set for that job
and sh.lgst_grp_cd = 'SEU'
and st.last_cmpd_arvl_dtt is not null
-- CDD set to a proper date format
and regexp_like(nvl(sh.rfrc_num5,'Nil'),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]')
-- PDD is always set so ignore all records that don't have it set
and regexp_like(substr(nvl(sh.rfrc_num14,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
-- compare current CDD2 with the newly calculated to see if update is necessary
and substr(upper(nvl(rf.rfrc_num,'NULL')),1,10) != substr(
   -- compare stop date with cdd and take the bigger value
  case greatest(trunc(st.last_cmpd_arvl_dtt), to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss'))
   -- when cdd is later, no CDD2 is necessary
   when to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss') then 'NIL'
      -- otherwise set cdd2 to stop date
   else to_char(trunc(st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
  end, 1,10)
-- ver. 1.1
-- marek dziekanski 2022-10-13 12:37
order by ref_key{R}{R}{R}{R}SEU Update CDD2 {R}{R}Chaining{EOL}{R}12{R}SEU_CDD2_UPT_SHPM{R}SEU_RRT_BKGS_SHPFLG_01_02{R}{R}PH2_SEU_CDD2_UPD_SHPM{R}SEU_CDD2_UPD_SHPM{R}select sh.shpm_num as ref_key
-- if NOT a BB
, case nvl(bb.no, 0) when  0 then
     case nvl(erf.rfrc_num, 'Nil')
        when 'Nil' then greatest((trunc((st.last_cmpd_arvl_dtt)) + 1438/1440), (trunc(sh.frm_pkup_dtt) + 1438/1440))
        else trunc(sh.frm_pkup_dtt) + 180 + (1438/1440)
      end
  else
     trunc(sh.frm_pkup_dtt) + 180 +  (1438/1440)
  end
  as to_pkup
-- take the greater of two: stop date - 3 days,  current pickup date
, case validate_conversion(nvl(sh.rfrc_num5, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss')
	when 1 then
		-- CDD set land leg
		greatest((trunc((st.last_cmpd_arvl_dtt) ) - 3 +
		-- adjust for a weekend
		+ 		case to_char(st.last_cmpd_arvl_dtt, 'DY','NLS_DATE_LANGUAGE = ENGLISH')
							when 'SAT' then 2
							when 'SUN' then 1
							else 0
					end
		-- add minute part
		+  1/1440), (sh.frm_pkup_dtt + 1/1440),  to_date(sh.rfrc_num5, 'yyyy-mm-dd"T"hh24:mi:ss') - 3 )
  --CDD not set, OCEAN
	else sh.frm_pkup_dtt + 1/1440
		-- adjust for a weekend
		+ 		case to_char(st.last_cmpd_arvl_dtt, 'DY','NLS_DATE_LANGUAGE = ENGLISH')
							when 'SAT' then 2
							when 'SUN' then 1
							else 0
					end
	end
as frm_del

-- take the greater of: stop date, pickup date, CDD
-- if NOT a BB
, case nvl(bb.no, 0) when  0 then
     case validate_conversion(nvl(sh.rfrc_num5, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss')
        when 1 then
        trunc(greatest(st.last_cmpd_arvl_dtt, sh.frm_pkup_dtt, to_date(sh.rfrc_num5, 'yyyy-mm-dd"T"hh24:mi:ss')))
      else
        trunc(greatest(st.last_cmpd_arvl_dtt, sh.frm_pkup_dtt))
      end
    -- adjust for a weekend
    + 			case to_char(st.last_cmpd_arvl_dtt, 'DY','NLS_DATE_LANGUAGE = ENGLISH')
                        when 'SAT' then 2
                        when 'SUN' then 1
                        else 0
      end
-- set minutes to 23:59
    + 1439/1440
  else
-- if a BB add 180 days to pickup from and set as 23:58
     trunc(sh.frm_pkup_dtt) + 180 +  (1439/1440)
  end as to_del
from stop_t st
inner join ld_leg_detl_t dt on dt.drop_stop_id = st.stop_id
inner join shpm_t sh on dt.shpm_id = sh.shpm_id
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
left join rfrc_num_t erf
  inner join dom_val_t edm on edm.val_enu = erf.rfrc_num_typ and edm.val_cd = 'EXTE2'
on erf.shpm_id = sh.shpm_id
left join (select count(xsd.shpm_id) as no, xsd.shpm_id from ld_leg_detl_t xsd
   inner join shpg_loc_t lc on lc.shpg_loc_cd = xsd.frm_shpg_loc_cd
   where xsd.shpm_id = shpm_id
   and trim(upper(nvl(lc.extl_cd2,'Nil'))) = 'BB'
   group by xsd.shpm_id
   ) BB on bb.shpm_id = sh.shpm_id

where  st.shpm_drop > 0
and trim(rf.rfrc_num) = '01'
and st.shpg_loc_cd = sh.to_shpg_loc_cd
and sh.lgst_grp_cd = 'SEU'
-- ver. 1.5
-- 1440 number of minutes in a day
-- marek dziekanski 2022-11-22 09:28
and sh.cur_optlstat_id < 230 -- picked



