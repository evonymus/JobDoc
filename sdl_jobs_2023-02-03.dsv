{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_TYPE_CODE; {R}{R}Report ETA for a Dealer{R}processGenerateAlert{R}API{EOL}SDL_ALRT_DLR_VSL_DPT{R}1{R}SDL_ALRT_DLR_VSL_DPT{R}{R}{R}ALRT_DLR_VSL_DPT{R}ALRT_SHPM{R}	select distinct to_char(sh.shpm_id) as shpm_id
, nvl(at2.alrt_typ_cd, at1.alrt_typ_cd) as alrt_type_code
	, 'MSG:VSLDT:' || to_char(ld.shpd_dtt, 'yyyy-mm-dd hh24:mi:ss')
	|| ', Chassis No: ' || sh.shpm_num
	|| ', Customer Name: ' || nvl(rf.rfrc_num,' ')
	|| ', Shipment Destination Location Code:' || sh.to_shpg_loc_cd
	|| ', City: ' || sd.to_cty_name
	|| ', In case of any questions on the products mentioned in this mail, or if you want to unsubscribe, please contact the Delivery Service Desk. '
	|| ', Sweden: dsd.sodertalje@scania.com'
	|| ', The Netherlands: dsd.zwolle@scania.com'
	|| ', France: delivery.servicedeskangers@scania.com'
	as text
	from shpm_t sh
	inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
	inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
	inner join rfrc_num_t drf on drf.shpm_id = sd.shpm_id
	inner join dom_val_t ddm on ddm.val_enu = drf.rfrc_num_typ and ddm.val_cd='DLRCD'
	left join ( select max(mn.mntr_acty_id) as mntr_acty_id
			, mn.shpm_num
			 from mntr_acty_t mn, rfrc_num_t xrf, dom_val_t xdm, shpm_t xsh, alrt_typ_t xat
			 where xsh.shpm_num = mn.shpm_num
					and xrf.shpm_id = xsh.shpm_id
					and xrf.rfrc_num_typ = xdm.val_enu
					and xdm.val_cd = 'DLRCD'
					and substr(nvl(mn.alrt_text,'Nil'),1,10) = 'MSG:VSLDT:'
          and  mn.alrt_typ_cd= case nvl(xat.alrt_typ_cd, 'NIL')
                    when 'NIL' then 'DLR_'  || substr(xrf.rfrc_num, instr(xrf.rfrc_num, '-') + 1)
                    else xat.alrt_typ_cd
                end
			group by mn.shpm_num
	) aa on aa.shpm_num = sh.shpm_num
		left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
	left join rfrc_num_t rf
	 -- inner join to the left joined reference table
	 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='ORDCNAM'
on rf.shpm_id = sh.shpm_id
left join alrt_typ_t at1 on at1.alrt_typ_cd = 'DLR_' || substr(drf.rfrc_num, instr(drf.rfrc_num, '-') + 1)
left join alrt_typ_t at2 on at2.alrt_typ_cd = 'DLR_' || drf.rfrc_num
where ld.lgst_grp_cd = 'SEU'
--and service type includes an ocean leg
and ld.shpd_dtt is not null
and ld.srvc_cd in ('OCEAN_DD','OCEAN_DP','OCEAN_PD','OCEAN_PP','SSEA_DD','SSEA_DP','SSEA_PD','SSEA_PP')
and ld.shpd_dtt > to_date('2022-05-25','yyyy-mm-dd')
-- alert type aleady defined
and nvl(at1.alrt_typ_cd, at2.alrt_typ_cd) is not null
	-- ver 1.4
	-- Marek Dziekanski 2022-07-11 11:57
and substr(nvl(mna.alrt_text, 'Nil'),1,26) != 'MSG:VSLDT:' || to_char(ld.shpd_dtt, 'yyyy-mm-dd hh24:mi')
