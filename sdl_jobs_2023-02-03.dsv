{R}TripRateData.SystemTripID=TRIP_ID; {R}{R}Re-rate body build bookings {R}processTripRate{R}API{EOL}{R}11{R}SEU_CHN_CDD2_PREV_TDEVCD_5{R}SEU_RRT_LOAD_SHPFLG_03_2{R}I_SET_CDD2{R}SEU_CHN_CDD2_PREV_TDEVCD_5{R}{R}select sh.shpm_num as ref_key
, to_char(st.last_cmpd_arvl_dtt, 'yyyy-mm-dd"T"hh24:mi:ss') as c_ref_num
, to_char(rf.rfrc_num_id) as c_ref_id
, case nvl(rf.rfrc_num_id, 0) when 0 then 'AT_ADD'
  else 'AT_UPDATE'
end as c_activity
, cast('CDD2' as varchar2(80)) as c_ref_type
, cast('5' as varchar2(80)) as t_ref_num
, to_char(rrf.rfrc_num_id) as t_ref_id
, cast('TDEVCD' as varchar2(80)) as t_ref_type
, case nvl(rrf.rfrc_num_id, 0) when 0 then 'AT_ADD'
  else 'AT_UPDATE'
end as t_activity
from shpm_t sh
-- connecting the last leg
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.to_shpg_loc_cd = sh.to_shpg_loc_cd
inner join stop_t st on sd.drop_stop_id = st.stop_id
-- only the shipment having ETA later than CDD/CDD2, flagged SHPFLG03 to '03'
inner join rfrc_num_t srf on srf.shpm_id = sh.shpm_id
inner join dom_val_t sdm on sdm.val_enu = srf.rfrc_num_typ and sdm.val_cd = 'SHPFLG03'
-- left joining reference CDD2
left join rfrc_num_t rf 
	 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CDD2'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rrf 
	 inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ and ddm.val_cd = 'TDEVCD'
on rrf.shpm_id = sh.shpm_id
where nvl(srf.rfrc_num,'Nil') = '03'
and sh.cur_optlstat_id < 260 -- completed
and st.cmpd_arvl_dtt is not null
-- CDD is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- re-rated stop date later than CDD/CDD2
and st.last_cmpd_arvl_dtt > case validate_conversion(nvl(sh.rfrc_num3,'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss')
    when 1 then to_date(substr(sh.rfrc_num3, 1, 10), 'yyyy-mm-dd')
    else to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
-- ver 1.1.1
-- Marek Dziekanski 2022-04-27 16:43:24
    end

{R}{R}{R}{R}Update CDD2 and TDEVCD to 5 for previous legs{R}{R}Chaining{EOL}{R}12{R}SEU_RRT_LOAD_SHPFLG_03_2{R}SEU_RRT_BKGS_SHPFLG_03_2{R}{R}SEU_RRT_LOAD_SHPFLG_03{R}RRT_UNSPD{R}select to_char(ld.ld_leg_id) as ld_leg_id
