{R}Shipment.ShipmentNumber=REF_KEY;Shipment.PickupToDateTime=TO_PKUP;Shipment.DeliveryFromDateTime=FRM_DEL;Shipment.DeliveryToDateTime=TO_DEL; {R}{R}SEU PFD/FND STEP 9: Update Shipment with New CDD2{R}processShipmentOrderUpdate{R}API{EOL}{R}13{R}SEU_RRT_BKGS_SHPFLG_01_02{R}SEU_RRT_LDS_SHPFLG_01_02{R}{R}SEU_RRT_BKGS_SHPFLG_01{R}RRT_BKGS{R}select to_char(tp.trip_id) as trip_id
from trip_t tp
-- linked with a shipment that hasn't been delivered yet
where tp.lgst_grp_cd = 'SEU'
and exists (select 1 from ld_leg_t ld 
  join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
  join shpm_t sh on sh.shpm_id = sd.shpm_id
  join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
  join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
  where  ld.trip_id = tp.trip_id
    and sh.lgst_grp_cd = 'SEU'
    and ld.cur_optlstat_id < 345
    and sh.cur_optlstat_id < 260 -- delivered
    and rf.rfrc_num = '01' -- flag set for that job
-- ver: 2.2
-- Marek Dziekanski 2021-09-01 16:10
) order by trip_id

{R}<CISDocument>
   <ApiHeader>
      <OperationName>processTripRate</OperationName>
   </ApiHeader>
   <TripRateData>
     <SystemTripID></SystemTripID>
   </TripRateData>
</CISDocument>
{R}TripRateData.SystemTripID=TRIP_ID; {R}{R}Secon re-rating{R}processTripRate{R}API{EOL}{R}14{R}SEU_RRT_LDS_SHPFLG_01_02{R}SEU_SEL_TO_TENDER{R}{R}SEU_RRT_LDS_SHPFLG_01{R}RRT_ALL{R}select to_char(ld.ld_leg_id) as leg_id
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where ld.cur_optlstat_id < 345
and ld.lgst_grp_cd = 'SEU'
and rf.rfrc_num = '01'
  and not exists (select 1 from trip_t tt
  where tt.trip_id = ld.trip_id
-- ver 2.1
-- Marek Dziekanski datetime
) order by leg_id
  {R}<?xml version="1.0"?><CISDocument>
	<LoadRateData>
