{R}{R}SystemPlanID=plan_id{R}D:\JobTemplates\send_for_opt_skd_30010.xml{R}Sends for Optim. SKD plan 30010{R}processSendToOptimizer{R}API{EOL}SDL_SEU_CHN_ALRT_LOC{R}1{R}SDL_SEU_CHN_ALRT_LOC{R}CANCEL_ALRT_LOC_TENDER{R}I_ALRT_LOC,I_SET_ALRT_LOC_FLAG{R}SEU_CHN_ALRT_LOC{R}{R}select distinct to_char(sd.ld_leg_id)as ld_leg_id
, 'MSG:NEW LOC:' || sh.to_shpg_loc_cd || ', Chassis No: ' || SD.SHPM_NUM 
  || ', Customer Name: ' || sd.cust_name
  || ', PFD: ' || substr(sh.rfrc_num4,1,10)
  || ', City: ' || sd.to_cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsubscribe, please contact the Delivery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
 as text
, ld.cur_optlstat_id 
,  ld.carr_cd as carr_cd
, case ld.cur_optlstat_id 
  when 305 then 'S_PLANNED'
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from audt_shpm_t ash
inner join ld_leg_detl_t sd on sd.shpm_id = ash.shpm_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
where sd.ld_leg_id is NOT null
and ld.trip_id is NULL -- not a part of a booking
and sh.lgst_grp_cd='SEU'
and ld.cur_optlstat_id in (305, 310, 320)
and sh.to_shpg_loc_cd != ash.shpm_to_shpg_loc_cd
and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.ld_leg_id = sd.ld_leg_id
  and mon.alrt_typ_cd ='RPT_LAC'
  and substr(nvl(mon.alrt_text,'NULL'),1,(length(sh.to_shpg_loc_cd)+12)) = 'MSG:NEW LOC:' || sh.to_shpg_loc_cd 
  -- ver. 1.3
  -- Marek Dziekanski 2022-03-04 12:08
)
{R}{R}{R}{R}Report change of location and re-rate load{R}{R}Chaining{EOL}{R}2{R}CANCEL_ALRT_LOC_TENDER{R}SEU_LD_CLR{R}{R}CANCEL_ALRT_LOC_TENDER{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id 
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from ld_leg_t ld
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LDFLG'
where ld.cur_optlstat_id in (310,320) -- tendered or tender accepted
-- var 1.0
-- Marek Dziekanski 2021-12-10 14:25
and upper(nvl(rf.rfrc_num,'Nil')) = 'LOC'
{R}{R}LoadTenderData.SystemLoadID=LD_LEG_ID;LoadTenderData.CarrierCode=CARR_CD;LoadTenderData.CurrentLoadOperationalStatusEnumVal=CUR_OPTLSTAT_ID{R}D:\JobTemplates\processTenderCancel.xml{R}Cancel ALRT LOC Tenders{R}processTenderCancel{R}API{EOL}{R}3{R}SEU_LD_CLR{R}CHN_RRT_ALRT_LOC{R}{R}SEU_LD_CLR{R}LD_CLR{R}select ld.ld_leg_id as ld_leg_id
from ld_leg_t ld
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LDFLG'
where ld.cur_optlstat_id = 305 -- planned
and ld.trip_id is null
	-- var 1.0
	-- Marek Dziekanski 2022-03-04 13:52
and upper(nvl(rf.rfrc_num,'Nil')) = 'LOC'
{R}<?xml version="1.0" encoding="UTF-8"?>
<CISDocument>
	<ApiHeader>
		<OperationName>processLoadUpdate</OperationName>
		<ApiSourceEnumVal>APISRC_JOB_SERVER</ApiSourceEnumVal>
	</ApiHeader>
	<LoadUpdateData>
		<SystemLoadID></SystemLoadID>
		<ServiceCode>" "</ServiceCode>
		<CarrierCode>" "</CarrierCode>
		<TractorEquipmentTypeCode>" "</TractorEquipmentTypeCode>
		<DomicileCode></DomicileCode>
		<DomicileTrailerCode></DomicileTrailerCode>
      <ValidateCarrierServiceEquipmentFlag>FALSE</ValidateCarrierServiceEquipmentFlag>  
	</LoadUpdateData>
</CISDocument>
{R}LoadUpdateData.SystemLoadID=LD_LEG_ID{R}{R}Clear Load Carrier, Service, and Equipment{R}processLoadUpdate{R}API{EOL}{R}4{R}CHN_RRT_ALRT_LOC{R}{R}I_API_RRT_LOAD,I_DEL_LD_RFRC{R}CHN_RRT_ALRT_LOC{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, rf.rfrc_num_id
from ld_leg_t ld
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LDFLG'
where ld.cur_optlstat_id in (305,310,320) -- planned tendered or tender accepted
and ld.trip_id is NULL -- not a part of a booking
	-- var 1.1
	-- Marek Dziekanski 2022-03-04 12:16
and upper(nvl(rf.rfrc_num,'Nil')) = 'LOC'
{R}{R}{R}{R}Re-rate ALRT LOC Loads{R}{R}Chaining{EOL}SDL_SEU_CHN_ALRT_LOC_MA{R}1{R}SDL_SEU_CHN_ALRT_LOC_MA{R}{R}I_ALRT_LOAD{R}SEU_CHN_ALRT_LOC_MA{R}{R}select distinct to_char(sd.ld_leg_id)as ld_leg_id
,'RPT_LAC_MA' as alrt_type_code
, 'MSG:NEW LOC:' || sh.to_shpg_loc_cd || ', Chassis No: ' || SD.SHPM_NUM
  || ', Customer Name: ' || sd.cust_name
  || ', PFD: ' || substr(sh.rfrc_num4,1,10)
  || ' , Dealer Code: ' || nvl(substr(drf.rfrc_num, instr(drf.rfrc_num, '-') + 1), ' ')
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ', Address ID:' || sh.to_shpg_loc_cd
  || ', City: ' || sd.to_cty_name
 as text
, ld.cur_optlstat_id
,  ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 305 then 'S_PLANNED'
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from audt_shpm_t ash
inner join ld_leg_detl_t sd on sd.shpm_id = ash.shpm_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t drf
	inner join dom_val_t ddm on ddm.val_enu = drf.rfrc_num_typ and ddm.val_cd='DLRCD'
on drf.shpm_id = sd.shpm_id
left join rfrc_num_t rf
 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where sd.ld_leg_id is NOT null
and sh.frm_shpg_loc_cd = 'MA'
and ld.trip_id is NULL -- not a part of a booking
and sh.lgst_grp_cd='SEU'
and ld.cur_optlstat_id in (305, 310, 320)
and sh.to_shpg_loc_cd != ash.shpm_to_shpg_loc_cd
and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.ld_leg_id = sd.ld_leg_id
  and mon.alrt_typ_cd ='RPT_LAC_MA'
  and substr(nvl(mon.alrt_text,'NULL'),1,(length(sh.to_shpg_loc_cd)+12)) = 'MSG:NEW LOC:' || sh.to_shpg_loc_cd
  -- ver. 1.0
  -- Marek Dziekanski 2022-06-09 14:27

)
{R}{R}{R}{R}Report change of location for MA{R}{R}Chaining{EOL}SDL_SEU_CHN_ALRT_LOC_MS{R}1{R}SDL_SEU_CHN_ALRT_LOC_MS{R}{R}I_ALRT_LOAD{R}SEU_CHN_ALRT_LOC_MS{R}{R}select distinct to_char(sd.ld_leg_id)as ld_leg_id
,'RPT_LAC_MS' as alrt_type_code
, 'MSG:NEW LOC:' || sh.to_shpg_loc_cd || ', Chassis No: ' || SD.SHPM_NUM
  || ', Customer Name: ' || sd.cust_name
  || ', PFD: ' || substr(sh.rfrc_num4,1,10)
  || ' , Dealer Code: ' || nvl(substr(drf.rfrc_num, instr(drf.rfrc_num, '-') + 1), ' ')
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ', Address ID:' || sh.to_shpg_loc_cd
  || ', City: ' || sd.to_cty_name
 as text
, ld.cur_optlstat_id
,  ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 305 then 'S_PLANNED'
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from audt_shpm_t ash
inner join ld_leg_detl_t sd on sd.shpm_id = ash.shpm_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t drf
	inner join dom_val_t ddm on ddm.val_enu = drf.rfrc_num_typ and ddm.val_cd='DLRCD'
on drf.shpm_id = sd.shpm_id
left join rfrc_num_t rf
 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where sd.ld_leg_id is NOT null
and sh.frm_shpg_loc_cd = 'MS'
and ld.trip_id is NULL -- not a part of a booking
and sh.lgst_grp_cd='SEU'
and ld.cur_optlstat_id in (305, 310, 320)
and sh.to_shpg_loc_cd != ash.shpm_to_shpg_loc_cd
and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.ld_leg_id = sd.ld_leg_id
  and mon.alrt_typ_cd ='RPT_LAC_MS'
  and substr(nvl(mon.alrt_text,'NULL'),1,(length(sh.to_shpg_loc_cd)+12)) = 'MSG:NEW LOC:' || sh.to_shpg_loc_cd
  -- ver. 1.0
  -- Marek Dziekanski 2022-06-09 14:27

){R}{R}{R}{R}Report change of location for MS{R}{R}Chaining{EOL}SDL_SEU_CHN_ALRT_LOC_MZ{R}1{R}SDL_SEU_CHN_ALRT_LOC_MZ{R}{R}I_ALRT_LOAD{R}SEU_CHN_ALRT_LOC_MZ{R}{R}select distinct to_char(sd.ld_leg_id)as ld_leg_id
,'RPT_LAC_MZ' as alrt_type_code
, 'MSG:NEW LOC:' || sh.to_shpg_loc_cd || ', Chassis No: ' || SD.SHPM_NUM
  || ', Customer Name: ' || sd.cust_name
  || ', PFD: ' || substr(sh.rfrc_num4,1,10)
  || ' , Dealer Code: ' || nvl(substr(drf.rfrc_num, instr(drf.rfrc_num, '-') + 1), ' ')
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ', Address ID:' || sh.to_shpg_loc_cd
  || ', City: ' || sd.to_cty_name
 as text
, ld.cur_optlstat_id
,  ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 305 then 'S_PLANNED'
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from audt_shpm_t ash
inner join ld_leg_detl_t sd on sd.shpm_id = ash.shpm_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t drf
	inner join dom_val_t ddm on ddm.val_enu = drf.rfrc_num_typ and ddm.val_cd='DLRCD'
on drf.shpm_id = sd.shpm_id
left join rfrc_num_t rf
 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where sd.ld_leg_id is NOT null
and sh.frm_shpg_loc_cd = 'MZ'
and ld.trip_id is NULL -- not a part of a booking
and sh.lgst_grp_cd='SEU'
and ld.cur_optlstat_id in (305, 310, 320)
and sh.to_shpg_loc_cd != ash.shpm_to_shpg_loc_cd
and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.ld_leg_id = sd.ld_leg_id
  and mon.alrt_typ_cd ='RPT_LAC_MZ'
  and substr(nvl(mon.alrt_text,'NULL'),1,(length(sh.to_shpg_loc_cd)+12)) = 'MSG:NEW LOC:' || sh.to_shpg_loc_cd
  -- ver. 1.0
  -- Marek Dziekanski 2022-06-09 14:27

)
{R}{R}{R}{R}Report change of location for MZ{R}{R}Chaining{EOL}SDL_SEU_CHN_CDD2_UPD_TDEVCD_5{R}1{R}SDL_SEU_CHN_CDD2_UPD_TDEVCD_5{R}CHN_UPD_TDEVCD_8{R}I_CDD2_UPD_TDEVCD_5,I_UPD_TDEVCD_5{R}SEU_CHN_CDD2_UPD_TDEVCD_5{R}{R}select sh.shpm_num as ref_key
, case greatest(trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd'))
	when trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)) then to_char(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
	else 'Nil'
	end as ref_num
, to_char(rf.rfrc_num_id) as ref_id
, case when rf.rfrc_num_id is null then 'AT_ADD'
	 else 'AT_UPDATE'
	end as activity
	, cast('CDD2' as varchar2(80)) as ref_type
-- DEVCD

        , case validate_conversion(substr(nvl(sh.rfrc_num3,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
        when 1 then case greatest(trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)), to_date(substr(sh.rfrc_num3, 1, 10), 'yyyy-mm-dd'))
                    when trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)) then cast('5' as varchar2(120))
                    else 'Nil'
                    end
        else cast('5' as varchar2(120)) 
      end as t_ref_num

	, to_char(trf.rfrc_num_id) as t_ref_id
, case when trf.rfrc_num_id is null then 'AT_ADD'
	 else 'AT_UPDATE'
	end as t_activity
, cast('TDEVCD' as varchar2(80)) as t_ref_type
	 
from ld_leg_detl_t sd
--join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
join stop_t st on sd.drop_stop_id = st.stop_id
-- only the loads having dest = sh.dest i.e. the final ones
join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
-- left joining reference
left join rfrc_num_t rf 
	 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CDD2'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t trf 
	 inner join dom_val_t tdm on tdm.val_enu = trf.rfrc_num_typ and tdm.val_cd='TDEVCD'
on trf.shpm_id = sh.shpm_id
-- last stop ETA set
where nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt) is not null
-- CDD2 is different to ETA
and ( nvl(substr(rf.rfrc_num, 1, 13), '1970-01-01') != to_char(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt), 'yyyy-mm-dd"T"hh24')
	or upper(nvl(rf.rfrc_num,'NIL')) = 'NIL'
)
-- CDD is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- and the stop date later than CDD
and trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)) > to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
-- ver. 1.5
-- Marek Dziekanski, 2022-09-21 16:27
and exists (select 1 from op_ap_statnst_t op 
		where op.ld_leg_id = sd.ld_leg_id
	  and substr(op.sec_cd, 1, 2) in ('11','13','14','20','21' , '31','45','67','SC','82')
	)
{R}{R}{R}{R}Update CDD2 and TDEVCD to 5 for a late delivery{R}{R}Chaining{EOL}{R}2{R}CHN_UPD_TDEVCD_8{R}{R}I_UPD_TDEVCD_8,I_SET_SHPM_RFRC,I_GEN_CDD2_EVENT,I_ALRT_CDD2_EVENT{R}CHN_UPD_TDEVCD_8{R}{R}select sh.shpm_num as ref_key, trim(nvl(rf.rfrc_num,'NULL')) as tt
, sh.shpm_num as shpm_num
, to_char(sh.shpm_id) as shpm_id
-- 8 is the code of TDEVCD for early delivery
, to_char(rf.rfrc_num_id) as ref_id
, case when rf.rfrc_num_id is null then 'AT_ADD'
   else 'AT_UPDATE'
  end as activity
, to_char(srf.rfrc_num_id) as s_ref_id
, 'AT_UPDATE' as s_activity
, cast('Nil' as varchar2(70)) as s_ref_num
, cast('CDD2' as varchar2(70)) as s_ref_type
,  'MSG:CDD2: Nil , Chassis No: ' || SD.SHPM_NUM
  || ', Customer Name: ' || sd.cust_name
  || ', CDD2: Nil'
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as CDD2
from ld_leg_detl_t sd
join stop_t st on st.stop_id = sd.drop_stop_id
-- only the loads having dest = sh.dest i.e. the final ones
join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join shpg_loc_t sl on sl.shpg_loc_cd = sh.to_shpg_loc_cd
inner join addr_t ad on ad.addr_id = sl.addr_id
--CDD2
inner join rfrc_num_t srf on srf.shpm_id = sh.shpm_id
inner join dom_val_t sdm on sdm.val_enu = srf.rfrc_num_typ and sdm.val_cd='CDD2'
-- left joining reference
left join rfrc_num_t rf
   -- inner join to the left joined reference table
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='TDEVCD'
on rf.shpm_id = sh.shpm_id
where st.last_cmpd_arvl_dtt is not null
-- CDD is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- and the stop date earlier than CDD
and st.last_cmpd_arvl_dtt <= to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
-- and cdd2 is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num3,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- ver. 1.1a
-- Marek Dziekanski, 2022-06-29 23:40
-- added exclusion for SLA customers
and trim(nvl(rf.rfrc_num,'NULL')) not in ('5', '8')
and NOT (sh.lgst_grp_cd = 'SLA' and sh.cust_cd in ('65031','68477') )
{R}{R}{R}{R}Handle Transport Deviation 8 {R}{R}Chaining{EOL}SDL_SEU_CHN_MA_SET_CAPSSFR_COMPLETE{R}1{R}SDL_SEU_CHN_MA_SET_CAPSSFR_COMPLETE{R}{R}I_CAPSSFR_CONFIRM_DEPARTURE,I_CAPSSFR_CONFIRM_ARRIVAL{R}SEU_CHN_MA_SET_CAPSSFR_COMPLETE{R}{R}select to_char(ld.ld_leg_id) as load_id
, to_char(sd.pick_stop_id) as pick_stop_id
, to_char(sd.drop_stop_id) as drop_stop_id
from shpm_t sh
-- always 1st leg
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
where sd.frm_shpg_loc_cd = 'MA' -- France
and sd.to_shpg_loc_cd = 'CAPSSFR'
-- ver. 1.0
-- Marek Dziekanski 2022-06-28 13:16
and ld.cur_optlstat_id = 320 -- Tender Accepted
{R}{R}{R}{R}Set MA CAPSSFR load complete{R}{R}Chaining{EOL}SDL_SEU_CHN_RRT_DCK_CMT{R}1{R}SDL_SEU_CHN_RRT_DCK_CMT{R}{R}I_RFRC_LD,I_RRT_LOAD{R}SEU_CHN_RRT_DCK_CMT{R}{R}select  ld.ld_leg_id
, rf.rfrc_num_id as ref_id
, case nvl(rf.rfrc_num_id, 0) when 0 then 'AT_ADD'
  else 'AT_UPDATE'
  end as activity
, to_char(dc.updt_dtt, 'yyyy-mm-dd:hh24:mi') as ref_num
, 'LD_DCK' as code
from dock_cmtd_t dc
inner join ld_leg_t ld on ld.ld_leg_id = dc.ld_leg_id
left join rfrc_num_t rf
  inner join dom_val_t dm 
  on rf.rfrc_num_typ = dm.val_enu
  and dm.val_cd is not null
  and dm.val_cd  = 'LD_DCK'
on rf.ld_leg_id = ld.ld_leg_id
where ld.cur_optlstat_id in (310, 320) -- tendered, tender accepted
and ld.lgst_grp_cd = 'SEU'
-- dock updated after the last run
and nvl(rf.rfrc_num, '1900-01-01:00:00'  ) < to_char(dc.updt_dtt, 'yyyy-mm-dd:hh24:mi') 
-- FND is set to a date
and exists (select 1 from ld_leg_detl_t sd
   inner join shpm_t sh on sh.shpm_id = sd.shpm_id
   where sd.ld_leg_id = ld.ld_leg_id
   and regexp_like(substr(nvl(sh.rfrc_num19,'Nil'),1,16),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]')
-- ver.1.0
-- Marek Dziekanski 2021-07-01 16:25:00
)
{R}{R}{R}{R}SEU re-rate loads with dock commitments{R}{R}Chaining{EOL}SDL_SEU_CHN_SET_PLTRGTDT_OTHR{R}1{R}SDL_SEU_CHN_SET_PLTRGTDT_OTHR{R}{R}I_SET_PLTRGTDT_DATE,I_SET_PLTRGTDTL_DATE{R}SEU_CHN_SET_PLTRGTDT_OTHR{R}{R}select sd.shpm_num, sd.ld_leg_detl_id, ld.end_dtt
, sd.ld_leg_id as ld_leg_id
, sd.seq_num, ls.elpd_hrs
, rf.rfrc_num_id
, case nvl(rf.rfrc_num_id,0)
   when 0 then 'AT_ADD'
   else 'AT_UPDATE'
end as activity
, to_char(pld.end_dtt
   + ls.elpd_hrs / 24, 'yyyy-mm-dd"T"hh24:mi:ss') as rfrc_num
, 'PLTRGTDT' as type_code
, lf.rfrc_num_id as l_rfrc_num_id
, case nvl(lf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
end as l_activity
, 'PLNTRGDTL' as l_type_code
from ld_leg_detl_t sd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
-- join the previous leg
inner join ld_leg_detl_t psd on psd.shpm_id = sd.shpm_id and psd.to_shpg_loc_cd = sd.frm_shpg_loc_cd
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join ld_leg_schd_t ls on ls.ld_leg_id = sd.ld_leg_id and ls.arvl_shpg_loc_cd is not null
    and ls.dptr_stop_id = sd.pick_stop_id
    and ls.arvl_stop_id = sd.drop_stop_id
    and ls.arvl_dtt_src_enu = 1
-- load previous leg
inner join ld_leg_t pld on pld.ld_leg_id = psd.ld_leg_id
-- shfplg = 01
left join rfrc_num_t rf
   -- inner join linking rf with dm
   inner join dom_val_t dm
      on rf.rfrc_num_typ = dm.val_enu
      and dm.val_cd is NOT NULL
      and dm.val_cd='PLTRGTDT'
-- completing left join of rf with ld_detl
on rf.ld_leg_detl_id = sd.ld_leg_detl_id
left join  rfrc_num_t lf
inner join dom_val_t lm on lm.val_enu= lf.rfrc_num_typ and lm.val_cd = 'PLNTRGDTL'
on lf.ld_leg_id = sd.ld_leg_id
where  validate_conversion(nvl(sh.rfrc_num19,'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') =1 -- FND set
and ld.lgst_grp_cd = 'SEU'
and ld.cur_optlstat_id < 345
-- ver 1.1
-- Marek Dziekanski 2022-11-09 16:00
and nvl(rf.rfrc_num, 'Nil') !=  to_char(pld.end_dtt    + ls.elpd_hrs / 24, 'yyyy-mm-dd"T"hh24:mi:ss')
{R}{R}{R}{R}Set PLTRGT Date for Other Load and Shipment Leg{R}{R}Chaining{EOL}SDL_SEU_CHN_TENDER_CANCEL{R}1{R}SDL_SEU_CHN_TENDER_CANCEL{R}SEU_CHN_RM_LD_FROM_TRIP{R}I_TENDER_CANCEL,I_RFRC_LD,I_UPD_CARR_CD{R}SEU_CHN_TENDER_CANCEL{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id

, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as activity
, cast('LDFLG_C' as varchar2(20))  as code
, cast('DD' as varchar2(30)) as ref_num
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
left join rfrc_num_t rf
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG_C'
on rf.ld_leg_id = ld.ld_leg_id

where ld.cur_optlstat_id in (310,320)
and sh.lgst_grp_cd = 'SEU'
and ld.carr_cd is not null
-- not on a booking
and sd.trip_id is NULL
-- Delivery Stop
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
-- Financial Hold
or trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
-- Finish Date is not set to a date
or case sh.frm_shpg_loc_cd
    when 'MZ' then 'MZ'
    else
        trim(upper(nvl(sh.rfrc_num19,'NIL')))
    end = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
-- ver. 1.1a
-- Marek Dziekanski 2023-01-16 12:13
)

{R}{R}{R}{R}Cancel  SEU Tenders{R}{R}Chaining{EOL}{R}2{R}SEU_CHN_RM_LD_FROM_TRIP{R}SEU_CHN_DEL_DOCK_CMT{R}I_RM_LD_FROM_TRIP,I_RFRC_LD,I_UPD_CARR_CD{R}SEU_CHN_RM_LD_FROM_TRIP{R}{R}select distinct to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id

, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as activity
, cast('LDFLG_C' as varchar2(20))  as code
, cast('DD' as varchar2(30)) as ref_num
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
left join rfrc_num_t rf
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG_C'
on rf.ld_leg_id = ld.ld_leg_id

where ld.cur_optlstat_id in (310,320)
and sh.lgst_grp_cd = 'SEU'
and ld.carr_cd is not null
-- part of a booking
and sd.trip_id is NOT NULL
-- Delivery Stop
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
-- Financial Hold
or trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
-- Finish Date is not set to a date
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
-- ver. 1.0
-- Marek Dziekanski 2022-07-13 09:14
)
{R}{R}{R}{R}Remove a SEU Load from a Booking{R}{R}Chaining{EOL}{R}3{R}SEU_CHN_DEL_DOCK_CMT{R}{R}I_DEL_DOCK_CMT,I_DEL_LD_RFRC{R}SEU_CHN_DEL_DOCK_CMT{R}{R}select to_char(dc.dock_cmtd_id) as dock_cmtd_id
, to_char(dc.stop_id) as stop_id
, to_char(rf.rfrc_num_id) as rfrc_num_id
from dock_cmtd_t dc
inner join ld_leg_t ld on ld.ld_leg_id = dc.ld_leg_id
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LDFLG_C'
where ld.lgst_grp_cd = 'SEU'
and ld.cur_optlstat_id < 310 --tendered
-- ver. 1.0
-- Marek Dziekanski 2022-07-05 09:48
and nvl(rf.rfrc_num,'Nil') = 'DD'
{R}{R}{R}{R}Delete a Dock Commitment for SEU{R}{R}Chaining{EOL}SDL_SEU_CHN_UPD_CDD_PRALCDD{R}1{R}SDL_SEU_CHN_UPD_CDD_PRALCDD{R}SEU_CHN_GEN_PRALCDD_EVENT{R}I_UPD_PRALCDD,I_UPD_CDD{R}SEU_CHN_UPD_CDD_PRALCDD{R}{R}select sd.shpm_id
, to_char(tp.vesl_arvl_dtt,'yyyy-mm-dd"T"hh24:mi') as PRALCDD
, case nvl(rf.rfrc_num_id,0) when 0 then  'AT_ADD' else 'AT_UPDATE' end as Action
, to_char(rf.rfrc_num_id) as ref_id

, to_char(tp.vesl_arvl_dtt,'yyyy-mm-dd"T"hh24:mi') as CDD
, case nvl(rf2.rfrc_num_id,0) when 0 then  'AT_ADD' else 'AT_UPDATE' end as Action2
, to_char(rf2.rfrc_num_id) as ref_id2
, sd.shpm_num as shpm_num
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join trip_t tp on tp.trip_id = ld.trip_id
left join rfrc_num_t rf 
   -- inner join to the left join
   inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd='PRALCDD'
   -- the end of the left join
on rf.shpm_id = sd.shpm_id
left join rfrc_num_t rf2 
   -- inner join to the left join
   inner join dom_val_t dm on rf2.rfrc_num_typ = dm.val_enu and dm.val_cd='CDD'
   -- the end of the left join
on rf2.shpm_id = sd.shpm_id
where tp.vesl_arvl_dtt is not null
and ld.lgst_grp_cd = 'SEU'
and ld.CUR_OPTLSTAT_ID = 335 -- in transit

and (  substr(nvl(rf.rfrc_num,'Nil'),1,10) != to_char(tp.vesl_arvl_dtt, 'yyyy-mm-dd')
	OR substr(nvl(rf2.rfrc_num,'Nil'),1,10) != to_char(tp.vesl_arvl_dtt, 'yyyy-mm-dd')
)
  -- ver. 1.0
  -- handles chain jobs chn_upd_pralcdd
  -- Marek Dziekanski 2022-03-02 15:22
and upper(substr(nvl(ld.srvc_cd,'NULL'), 1, 5)) = 'OCEAN'
{R}{R}{R}{R}Chain reporting PRALCDD update/change{R}{R}Chaining{EOL}{R}2{R}SEU_CHN_GEN_PRALCDD_EVENT{R}{R}I_GEN_PRALCDD_FILE,I_RPT_PRALCDD_EVENT{R}SEU_GEN_PRALCDD_EVENT{R}{R}select to_char(sd.shpm_id) as shpm_id 
	 , 'MSG:PRALCDD:' || to_char(tp.vesl_arvl_dtt,'yyyy-mm-dd"T"hh24:mi')|| ', Chassis No: ' || SH.SHPM_NUM 
		|| ', Customer Name: ' || sd.cust_name
		|| ', PRALCDD: ' || to_char(tp.vesl_arvl_dtt,'yyyy-mm-dd"T"hh24:mi')
		|| ', City: ' || sd.to_cty_name
		|| ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
		|| ', Sweden: dsd.sodertalje@scania.com'
		|| ', The Netherlands: dsd.zwolle@scania.com'
		|| ', France: delivery.servicedeskangers@scania.com'
		as text
        , sh.shpm_num as shpm_num
	from ld_leg_t ld
    inner join trip_t tp on tp.trip_id = ld.trip_id
	inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
	inner join shpm_t sh on sh.shpm_id = sd.shpm_id
	inner join rfrc_num_t rf on rf.shpm_id = sd.shpm_id
	inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd='PRALCDD'
	where tp.vesl_arvl_dtt is not null
    and ld.lgst_grp_cd = 'SEU'
    and tp.vesl_arvl_dtt is not null
	and substr(nvl(rf.rfrc_num,'Nil'),1,10) = to_char(tp.vesl_arvl_dtt, 'yyyy-mm-dd')
	and upper(substr(nvl(ld.srvc_cd,'NULL'), 1, 5)) = 'OCEAN'
	and not exists (select 1 from MNTR_ACTY_T mon
		where mon.shpm_num = sh.shpm_num
		and mon.alrt_typ_cd ='RPT_PRALCDD'
		and substr(nvl(mon.alrt_text,'NULL'),13,16) = to_char(tp.vesl_arvl_dtt,'yyyy-mm-dd"T"hh24:mi')
		-- ver. 1.0.1
		-- handles chain jobs chn_upd_pralcdd
	-- Marek Dziekanski 2022-03-03 17:02
)
{R}{R}{R}{R}Report a change of PRALCDD value{R}{R}Chaining{EOL}SDL_SEU_CHN_UPD_TDEVCD_5_LAST_LEG{R}1{R}SDL_SEU_CHN_UPD_TDEVCD_5_LAST_LEG{R}SEU_UPD_TDEVCD_5_OTHER{R}I_UPD_TDEVCD_5,I_UPD_LTDEV5CD{R}SEU_CHN_UPD_TDEVCD_5_LAST_LEG{R}{R}select ld.ld_leg_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as activity
, rf.rfrc_num_id as ref_id
, 'LTDEV5CD' as code

-- TDEVCD = 5
, sh.shpm_num as ref_key
, case nvl(trf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as t_activity
, trf.rfrc_num_id as t_ref_id
, 'TDEVCD' as t_ref_type
, case sign(
  -- day of week for CRD
    (1 + trunc(to_date(substr(sh.rfrc_num6,1,10), 'yyyy-mm-dd'))
        - trunc(to_date(substr(sh.rfrc_num6,1,10), 'yyyy-mm-dd'), 'IW'))
    -
  -- day of week of FND
     (1 + trunc(to_date(substr(sh.rfrc_num19,1,10), 'yyyy-mm-dd'))
        - trunc(to_date(substr(sh.rfrc_num19,1,10), 'yyyy-mm-dd'), 'IW'))
    )
---------------------------------------------------------------------------
-- there is a weekend break
 when - 1 then
  case
      sign (
          greatest(
          ( to_date(substr(sh.rfrc_num5,1,10),'yyyy-mm-dd') +
        -- date difference betwen FND and CRD
              (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd')
                  - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')
              ) -
        -- deduct weekends as number of weeks multiplied by 2
              (trunc( (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd')
                    - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')) / 7) * 2)
             ), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd'))
            - trunc(st.drop_arvl_rptd_dtt)
      )
     when -1 then cast('5' as varchar2(70))
    else 'Nil'
  end
----------------------------------------------------------------------------
 -- CRD and FND on the same day of the week
 when 0 then
   case
      sign (
        greatest(
          ( to_date(substr(sh.rfrc_num5,1,10),'yyyy-mm-dd') +
            (
              -- FND minus CRD in days
              to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')
            )
           -
           (
              -- deduct weekends as number of week multiplied by 2
              trunc( (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')) / 7) * 2
            )
            ), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd') )
          - trunc(st.drop_arvl_rptd_dtt)
      )
      when -1 then cast('5' as varchar2(70))
      else 'Nil'
   end
  --------------------------------------------------------------------------
  when 1 then
    case
        sign (
          greatest(
            (to_date(substr(sh.rfrc_num5,1,10),'yyyy-mm-dd') +
            (
              -- FND minus CRD
              to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')
            )
           -
            (
              -- deduct number of week multiplied by 2
              trunc( (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')) / 7) * 2
            )
           -
          -- if CRD is on SAT or SUN add days
            case to_char(to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd'), 'DY','NLS_DATE_LANGUAGE = ENGLISH')
              when 'SAT' then 2
              when 'SUN' then 1
              else 0
            end
           - 2 ), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd') )
            - trunc(st.drop_arvl_rptd_dtt)
      )
  when -1 then cast('5' as varchar2(70))
  else 'Nil'
  end
 end as t_ref_num

from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
inner join stop_t st on st.stop_id = sd.drop_stop_id
left join rfrc_num_t rf
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LTDEV5CD'
on rf.ld_leg_id = ld.ld_leg_id

left join rfrc_num_t trf
  inner join dom_val_t tdm on tdm.val_enu = trf.rfrc_num_typ and tdm.val_cd = 'TDEVCD'
on trf.shpm_id = sh.shpm_id

where ld.lgst_grp_cd = 'SEU'
-- dates exist in proper format
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
and regexp_like ( substr(nvl(sh.rfrc_num6,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
and regexp_like ( substr(nvl(sh.rfrc_num19,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')

and st.drop_arvl_rptd_dtt is not null
and st.drop_arvl_rptd_dtt is not null
and nvl(trf.rfrc_num,'Nil') !=
 case sign(
  -- day of week for CRD
    (1 + trunc(to_date(substr(sh.rfrc_num6,1,10), 'yyyy-mm-dd'))
        - trunc(to_date(substr(sh.rfrc_num6,1,10), 'yyyy-mm-dd'), 'IW'))
    -
  -- day of week of FND
     (1 + trunc(to_date(substr(sh.rfrc_num19,1,10), 'yyyy-mm-dd'))
        - trunc(to_date(substr(sh.rfrc_num19,1,10), 'yyyy-mm-dd'), 'IW'))
    )
---------------------------------------------------------------------------
-- there is a weekend break
 when - 1 then
  case
      sign (
          greatest(
          ( to_date(substr(sh.rfrc_num5,1,10),'yyyy-mm-dd') +
        -- date difference betwen FND and CRD
              (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd')
                  - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')
              ) -
        -- deduct weekends as number of weeks multiplied by 2
              (trunc( (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd')
                    - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')) / 7) * 2)
             ), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd'))
            - trunc(st.drop_arvl_rptd_dtt)
      )
     when -1 then cast('5' as varchar2(70))
    else 'Nil'
  end
----------------------------------------------------------------------------
 -- CRD and FND on the same day of the week
 when 0 then
   case
      sign (
        greatest(
          ( to_date(substr(sh.rfrc_num5,1,10),'yyyy-mm-dd') +
            (
              -- FND minus CRD in days
              to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')
            )
           -
           (
              -- deduct weekends as number of week multiplied by 2
              trunc( (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')) / 7) * 2
            )
            ), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd') )
          - trunc(st.drop_arvl_rptd_dtt)
      )
      when -1 then cast('5' as varchar2(70))
      else 'Nil'
   end
  --------------------------------------------------------------------------
  when 1 then
    case
        sign (
          greatest(
            (to_date(substr(sh.rfrc_num5,1,10),'yyyy-mm-dd') +
            (
              -- FND minus CRD
              to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')
            )
           -
            (
              -- deduct number of week multiplied by 2
              trunc( (to_date(substr(sh.rfrc_num19,1,10),'yyyy-mm-dd') - to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd')) / 7) * 2
            )
           -
          -- if CRD is on SAT or SUN add days
            case to_char(to_date(substr(sh.rfrc_num6,1,10),'yyyy-mm-dd'), 'DY','NLS_DATE_LANGUAGE = ENGLISH')
              when 'SAT' then 2
              when 'SUN' then 1
              else 0
            end
           - 2 ), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd') )
            - trunc(st.drop_arvl_rptd_dtt)
      )
  when -1 then cast('5' as varchar2(70))
  else 'Nil'
  end
 end
-- ver 2.0
-- Marek Dziekanski 2022-12-13 15:02

and st.drop_arvl_rptd_dtt > to_date('2022-12-01','yyyy-mm-dd')

{R}{R}{R}{R}Update TDEVCD and LTDEVCD Transport Deviations to 5{R}{R}Chaining{EOL}{R}2{R}SEU_UPD_TDEVCD_5_OTHER{R}{R}{R}SEU_UPD_TDEVCD_5_OTHER{R}RFRC_LD{R}select ld.ld_leg_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as activity
, rf.rfrc_num_id as ref_id
, cast('5' as varchar2(70)) as ref_num
, 'LTDEV5CD' as code

from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sh.to_shpg_loc_cd != sd.to_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
inner join stop_t st on st.stop_id = sd.drop_stop_id

inner join rfrc_num_t prf on prf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t pdm on pdm.val_enu = prf.rfrc_num_typ and pdm.val_cd = 'PLNTRGDTL'
left join rfrc_num_t rf
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LTDEV5CD'
on rf.ld_leg_id = ld.ld_leg_id
where ld.lgst_grp_cd = 'SEU'
and validate_conversion(substr(nvl(prf.rfrc_num,'Nil'),1,16) as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
and st.drop_arvl_rptd_dtt is not null
and trunc(st.drop_arvl_rptd_dtt) > to_date(substr(prf.rfrc_num, 1,10), 'yyyy-mm-dd')
and nvl(rf.rfrc_num,'Nil') != '5'
-- ver 1.1
-- Marek Dziekanski 2022-12-15 20:45
and st.drop_arvl_rptd_dtt > to_date('2022-12-01','yyyy-mm-dd')
{R}<CISDocument>
