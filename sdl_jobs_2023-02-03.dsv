      <OperationName>processTrailerActivities</OperationName>
   </ApiHeader>
   <TrailerActivity>
      <SystemStopID></SystemStopID>
      <SystemLoadID></SystemLoadID>
      <TrailerActivityTypeEnumVal>EC_DRIVER_CHECKIN</TrailerActivityTypeEnumVal>
      <ReasonCode>SCA01</ReasonCode>
      <ActivityDateTime></ActivityDateTime>
      <ReverseFlag>False</ReverseFlag>
   </TrailerActivity>
</CISDocument>
{R}TrailerActivity.SystemLoadID=LOAD_ID;TrailerActivity.SystemStopID=DROP_STOP_ID;TrailerActivity.ActivityDateTime=<@CurrentDateTime@>; {R}{R}Confirm Stop Arrival using{R}processTrailerActivities{R}API{EOL}SDL_SEU_FLAG_TENDERED{R}1{R}SDL_SEU_FLAG_TENDERED{R}SEU_CHN_GEN_TDR_UPDATE{R}{R}SEU_FLAG_TENDERED{R}UPD_SHPM_RFRC{R}select distinct sh.shpm_num
, substr(nvl(sh.rfrc_num3,'Nil') || '|' || nvl(rf.rfrc_num,'Nil') || '|' || to_char(el.flex_qnty1), 1, 70) as ref_num
, case nvl(rrf.rfrc_num_id, 0)
	when 0 then 'AT_ADD'
	else 'AT_UPDATE'
	end as activity
, rrf.rfrc_num_id as ref_id
, 'SHPFLG02' as code
from shpm_t sh
--inner join elmt_t el on el.shpm_id = sh.shpm_id
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join (select el.shpm_id as shpm_id, max(el.flex_qnty1) as flex_qnty1
    from elmt_t el
    group by el.shpm_id ) el on el.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t rf
	inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'MRN'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rrf
	inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ and ddm.val_cd='SHPFLG02'
on rrf.shpm_id = sh.shpm_id
where ld.cur_optlstat_id in (310,320) -- tendered, tender accepted
and rrf.rfrc_num_id is null
--ver 1.3
-- Marek Dziekanski 2022-06-28 11:15
and ld.carr_cd in ('AXL', 'HOD', 'PAN', 'AHO', 'ROO')
and nvl(ld.updt_dtt, ld.crtd_dtt) > to_date('2022-03-22','yyyy-mm-dd')
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal></ReferenceNumberActionEnumVal>
     <ReferenceNumberCategoryEnumVal>RNC_SHPM</ReferenceNumberCategoryEnumVal>
     <ReferenceNumberEntityIdShipmentNumberFlag>TRUE</ReferenceNumberEntityIdShipmentNumberFlag>
     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <ReferenceNumberTypeCode></ReferenceNumberTypeCode>
     <ReferenceNumber></ReferenceNumber>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=SHPM_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE;{R}{R}Flag Tendered Loads{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}2{R}SEU_CHN_GEN_TDR_UPDATE{R}{R}I_FLAG_TENDERED,I_TENDER_UPDATE{R}SEU_CHN_GEN_TDR_UPDATE{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd
, sh.shpm_num
, substr(nvl(sh.rfrc_num3,'Nil') || '|' || nvl(rf.rfrc_num,'Nil') || '|' || to_char(el.flex_qnty1), 1, 70) as ref_num
, case nvl(rrf.rfrc_num_id, 0)
	when 0 then 'AT_ADD'
	else 'AT_UPDATE'
	end as activity
, rrf.rfrc_num_id as ref_id
, 'SHPFLG02' as code
from shpm_t sh
--inner join elmt_t el on el.shpm_id = sh.shpm_id
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join (select el.shpm_id as shpm_id, max(el.flex_qnty1) as flex_qnty1
    from elmt_t el
    group by el.shpm_id ) el on el.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t rf 
	inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'MRN'
on rf.shpm_id = sh.shpm_id
inner join rfrc_num_t rrf on rrf.shpm_id = sh.shpm_id
inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ and ddm.val_cd='SHPFLG02'
where ld.cur_optlstat_id in (310,320) -- tendered, tender accepted
--ver 1.0
-- Marek Dziekanski 2022-03-23 11:32
and  substr(nvl(sh.rfrc_num3,'Nil') 
    || '|' || nvl(rf.rfrc_num,'Nil') 
    || '|' || to_char(el.flex_qnty1), 1, 70) != nvl(rrf.rfrc_num,'Nil')
{R}{R}{R}{R}Trigger Tender Update using SHPFLG02{R}{R}Chaining{EOL}SDL_SEU_RRT_UNSPND_NIGHT{R}1{R}SDL_SEU_RRT_UNSPND_NIGHT{R}SEU_RRT_LD_NIGHT{R}{R}SEU_RRT_UNSPND_NIGHT{R}RRT_UNSPD{R}select ld.ld_leg_id as ld_leg_id
, nvl(ld.last_sec_cd, 'SUSP') as sec_cd
, current_date as dtt
from ld_leg_t ld
where ld.lgst_grp_cd = 'SEU'
and ld.ratg_vlid_yn = 'F'
and ld.cur_optlstat_id between 305 and 335
and ld.trip_id is null
and ld.updt_dtt < sysdate - 60/1440
--ver 1.0
-- Marek Dziekanski 2022-02-07 20:41
and ld.sus_func_enu != 1 --supended
