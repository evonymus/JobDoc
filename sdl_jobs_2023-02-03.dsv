{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_TYPE_CODE; {R}{R}Report CDD2 change for a Customer{R}processGenerateAlert{R}API{EOL}SDL_ALRT_CSL_ETA{R}1{R}SDL_ALRT_CSL_ETA{R}{R}{R}ALRT_CSL_ETA{R}ALRT_SHPM{R}select distinct to_char(sh.shpm_id) as shpm_id
, 'CSL_' || sh.to_shpg_loc_cd as alrt_type_code
, 'MSG:ETA:' || to_char(st.carr_eta_dtt, 'yyyy-mm-dd hh24:mi') 
  || ', Chassis No: ' || SD.SHPM_NUM 
  || ' , Customer Name: ' || sd.cust_name
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ', Address ID:' || sh.to_shpg_loc_cd
  || ' , City: ' || sd.to_cty_name
  || ', In case of any questions on the products mentioned in this mail, or if you want to unsubscribe, please contact the Delivery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join stop_t st on st.stop_id = sd.drop_stop_id
-- select the last record with the alert to compare
left join ( select max(mn.mntr_acty_id) as mntr_acty_id
    , mn.shpm_num
     from mntr_acty_t mn, shpm_t xsh
			 where xsh.shpm_num = mn.shpm_num
        and  mn.alrt_typ_cd='CSL_'  || xsh.to_shpg_loc_cd
				and substr(nvl(mn.alrt_text,'Nil'),1,8) ='MSG:ETA:'
    group by mn.shpm_num
) aa on aa.shpm_num = sh.shpm_num
left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
left join rfrc_num_t rf
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sd.shpm_id
where st.carr_eta_dtt is not null
and st.carr_eta_dtt > to_date('2022-05-25','yyyy-mm-dd')
-- alert type aleady defined
and exists (select * from alrt_typ_t at 
    where at.alrt_typ_cd = 'CSL_'|| sh.to_shpg_loc_cd
	)
	-- ver 1.0a
  -- Marek Dziekanski 2022-05-26 12:47

-- exclude already handled messages
and substr(nvl(mna.alrt_text, 'Nil'),1,24) != 'MSG:ETA:' || to_char(st.carr_eta_dtt, 'yyyy-mm-dd hh24:mi') 
