   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=LD_LEG_ID;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE; {R}{R}Update OCEANVSL Reference Number{R}processMaintainEntityReferenceNumber{R}API{EOL}SDL_TENDER_CANCEL{R}1{R}SDL_TENDER_CANCEL{R}{R}{R}TENDER_CANCEL{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id 
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
where ld.cur_optlstat_id in (310,320)
and ld.carr_cd is not null
-- not on a booking
and sd.trip_id is NULL
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
or trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
)
-- SLA with staus 500 cannot be cancelled
and not exists ( select shx.shpm_num
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA' 
    and nvl(shx.rfrc_num16,'Nil') = '500' -- order status 500
    and ldx.ld_leg_id = ld.ld_leg_id
--ver. 1.9.6
-- Marek Dziekanski 2022-03-01 10:53
)
{R}{R}LoadTenderData.SystemLoadID=LD_LEG_ID;LoadTenderData.CarrierCode=CARR_CD;LoadTenderData.CurrentLoadOperationalStatusEnumVal=CUR_OPTLSTAT_ID{R}D:\JobTemplates\processTenderCancel.xml{R}Tender Cancel{R}processTenderCancel{R}API{EOL}SDL_TENDER_KD_SKD{R}1{R}SDL_TENDER_KD_SKD{R}{R}{R}TENDER_KD_SKD{R}{R}select to_char(ld.ld_leg_id) ld_leg_id
from ld_leg_t ld
where  ld.cur_optlstat_id = 305--planned
and ld.srvc_cd is not null
-- not ocean service
and upper(ld.srvc_cd) not in ('SSEA','SS','SSEA_PP','SSEA_PD','SSEA_DD','SSEA_DP'
, 'OCEAN_PP','OCEAN_PD','OCEAN_DD','OCEAN_DP')
and  exists (  -- Finish Date Exists
  select sh.shpm_id
  from shpm_t sh
  join ld_leg_detl_t dt on sh.shpm_id=dt.shpm_id
  WHERE dt.ld_leg_id = ld.ld_leg_id
  -- kd or skd
  and sh.CDTY_CD  IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
  -- planned finish date exists in yyyy-mm-dd format
  and regexp_like (nvl(substr(sh.rfrc_num4,1,10), 'NIL'), '[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
  -- not on financial hold
  and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
  and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
  -- not to France
  --and UPPER(sh.to_ctry_cd) != 'FRA'
  and (sh.cust_cd != '61022' OR sh.frm_shpg_loc_cd != 'MA')
  -- ver. 1.2
  -- Marek Dziekanski 2021-02-22
){R}{R}LoadTenderData.SystemLoadID=ld_leg_id;{R}D:\JobTemplates\processTender.xml{R}Tender KD and SKDLoads{R}processTender{R}API{EOL}SDL_TENDER_TO_BODY_BUILD{R}1{R}SDL_TENDER_TO_BODY_BUILD{R}SEU_SET_SHPFLG02_BB{R}{R}TENDER_TO_BODY_BUILD{R}{R}select to_char(psd.ld_leg_id) as ld_leg_id
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join ld_leg_detl_t psd on psd.shpm_id = sh.shpm_id 
inner join ld_leg_t ld on psd.ld_leg_id = ld.ld_leg_id
inner join shpg_loc_t sl on sl.shpg_loc_cd = sd.to_shpg_loc_cd
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'EXTE2'
where  ld.CUR_OPTLSTAT_ID = 305 -- planneds
-- also tendering all previous legs
and psd.seq_num <= sd.seq_num
and ld.lgst_grp_cd = 'SEU'
-- EXTE2 or FND is set to a date
and ( validate_conversion(substr(nvl(rf.rfrc_num,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi') = 1
    OR  validate_conversion(substr(nvl(sh.rfrc_num19,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi') = 1 
)
and upper(trim(nvl(sl.extl_cd2,'Nil'))) = 'BB' -- Body Build Location have it set to 'BB'
  -- not on financial hold
and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
  -- ver. 1.3
  -- Marek Dziekanski 2022-05-13 15:28
 -- not delivery stop
and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
group by psd.ld_leg_id
{R}{R}LoadTenderData.SystemLoadID=ld_leg_id; {R}D:\JobTemplates\processTender.xml{R}Tender Loads to body builders{R}processTender{R}API{EOL}{R}2{R}SEU_SET_SHPFLG02_BB{R}{R}{R}SEU_FLAG_TENDERED{R}UPD_SHPM_RFRC{R}select distinct sh.shpm_num
, substr(nvl(sh.rfrc_num3,'Nil') || '|' || nvl(rf.rfrc_num,'Nil') || '|' || to_char(el.flex_qnty1), 1, 70) as ref_num
, case nvl(rrf.rfrc_num_id, 0)
	when 0 then 'AT_ADD'
	else 'AT_UPDATE'
	end as activity
, rrf.rfrc_num_id as ref_id
, 'SHPFLG02' as code
from shpm_t sh
--inner join elmt_t el on el.shpm_id = sh.shpm_id
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join (select el.shpm_id as shpm_id, max(el.flex_qnty1) as flex_qnty1
    from elmt_t el
    group by el.shpm_id ) el on el.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t rf
	inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'MRN'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rrf
	inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ and ddm.val_cd='SHPFLG02'
on rrf.shpm_id = sh.shpm_id
where ld.cur_optlstat_id in (310,320) -- tendered, tender accepted
and rrf.rfrc_num_id is null
--ver 1.3
-- Marek Dziekanski 2022-06-28 11:15
and ld.carr_cd in ('AXL', 'HOD', 'PAN', 'AHO', 'ROO')
and nvl(ld.updt_dtt, ld.crtd_dtt) > to_date('2022-03-22','yyyy-mm-dd')
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal></ReferenceNumberActionEnumVal>
     <ReferenceNumberCategoryEnumVal>RNC_SHPM</ReferenceNumberCategoryEnumVal>
     <ReferenceNumberEntityIdShipmentNumberFlag>TRUE</ReferenceNumberEntityIdShipmentNumberFlag>
     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <ReferenceNumberTypeCode></ReferenceNumberTypeCode>
     <ReferenceNumber></ReferenceNumber>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=SHPM_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE; {R}{R}Flag Tendered Loads{R}processMaintainEntityReferenceNumber{R}API{EOL}SDL_UPD_BATCH{R}1{R}SDL_UPD_BATCH{R}UPD_BATCH_BK{R}{R}UPD_BATCH_LD{R}{R}select  to_char(ld.ld_leg_id) as ref_key
, sh.rfrc_num2 as ref_num
,'AT_ADD' as activity
, rf.rfrc_num_id as ref_id
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t rf 
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDBATCHNO'
on rf.ld_leg_id = sd.ld_leg_id
-- ver. 1.2
-- Marek Dziekanski 2021-03-05 10:15
where upper(nvl(sh.rfrc_num2, 'NIL')) != 'NIL'
and rf.rfrc_num_id is null
group by ld.ld_leg_id, rf.rfrc_num_id, sh.rfrc_num2
order by ref_key desc, ref_id
{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID; {R}D:\JobTemplates\upd_batch_ld.xml{R}BACH STEP 1: Update Batch for Loads{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}2{R}UPD_BATCH_BK{R}{R}{R}UPD_BATCH_BK{R}{R}select to_char(tr.trip_id) as ref_key --, rf.rfrc_num as exist_rf, sh.shpm_num
, sh.rfrc_num2 as ref_num
, 'AT_ADD' as activity
, rf.rfrc_num_id as ref_id
from ld_leg_t ld
join trip_t tr on tr.trip_id = ld.trip_id
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
left join rfrc_num_t rf 
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='BKBATCHNO'
on rf.trip_id = tr.trip_id
-- ver. 1.2.1
-- Marek Dziekanski 2021-03-05 09:55
where upper(nvl(sh.rfrc_num2, 'NIL')) != 'NIL'
and rf.rfrc_num_id is null
group by tr.trip_id, rf.rfrc_num_id, sh.rfrc_num2
order by ref_key, ref_id
{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID; {R}D:\JobTemplates\upd_batch_bk.xml{R}BACH STEP 2: Update Batch for Bookings{R}processMaintainEntityReferenceNumber{R}API{EOL}SDL_UPD_LD_LIC_NUM{R}1{R}SDL_UPD_LD_LIC_NUM{R}{R}{R}UPD_LD_LIC_NUM{R}{R}select to_char(ld.ld_leg_id) ld_leg_id
, nvl(ld.trctr_lic_num,'Nil') as ref_num
, rf.rfrc_num_id as ref_id
, case nvl(rf.rfrc_num_id, 0) when 0 then 'AT_ADD'
  else 'AT_UPDATE' end as action
from ld_leg_t ld
left join rfrc_num_t rf
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ
    and dm.val_cd is not null 
    and dm.val_cd = 'LICPLT'
on ld.ld_leg_id = rf.ld_leg_id
where ld.cur_optlstat_id between 310 and 335 -- tendered, in transit
-- ver. 1.1
-- Marek Dziekanski 2022-02-02 09:46
and upper(nvl(rf.rfrc_num, 'NIL')) != upper(nvl(ld.trctr_lic_num,'Nil')){R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=LD_LEG_ID;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTION;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM; {R}D:\JobTemplates\upd_ld_lic_num.xml{R}Update Load License Number{R}processMaintainEntityReferenceNumber{R}API{EOL}UPD_LOAD_UPDTIME{R}1{R}UPD_LOAD_UPDTIME{R}{R}{R}UPD_LD_TIMESTMP{R}{R}SELECT DISTINCT L2.LD_LEG_ID LOADID,L2.CARR_CD CARRIER FROM SHPM_T S,LD_LEG_DETL_T L,LD_LEG_T L2 WHERE S.UPDT_DTT > L2.UPDT_DTT AND S.SHPM_ID=L.SHPM_ID AND L.LD_LEG_ID=L2.LD_LEG_ID AND L2.UPDT_DTT IS NOT NULL
AND L2.CUR_OPTLSTAT_ID IN ('320','335','315','325','330','345'){R}{R}LoadUpdateProgressData.CarrierCode=CARRIER;LoadUpdateProgressData.SystemLoadID=LOADID;LoadUpdateProgressData.SECInformation.MovementDateTime=<@CurrentDateTime@>; {R}D:\JobTemplates\processLoadUpdateProgress.xml{R}Job to update Loads with Service event code to reflect UpdateDatetime if shipment is updated{R}processLoadUpdateProgress{R}API{EOL}