   <UncommitFlag>true</UncommitFlag>
</CISDocument>
{R}LoadRateData.SystemLoadID=LD_LEG_ID; {R}{R}Rerates Loads at Night{R}processLoadRate{R}API{EOL}{R}3{R}SLA_RRT_BKGS_NIGHT{R}{R}{R}SLA_RRT_BKGS_NIGHT{R}RRT_BKGS{R}select tp.trip_id as trip_id
from ld_leg_t ld
inner join trip_t tp on tp.trip_id = ld.trip_id
where ld.lgst_grp_cd = 'SLA'
and ld.ratg_vlid_yn = 'F'
and ld.cur_optlstat_id between 305 and 335
and tp.updt_dtt < sysdate - 60 
and not exists (select count(lld.ld_leg_id), tp.trip_id
    from trip_t tp
    inner join ld_leg_t lld on tp.trip_id = lld.trip_id
    where lld.ld_leg_id = ld.ld_leg_id
    group by tp.trip_id
    having count(lld.ld_leg_id) > 30)
--ver 1.0
-- Marek Dziekanski 2021-11-05 11:41
group by tp.trip_id
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processTripRate</OperationName>
   </ApiHeader>
   <TripRateData>
     <SystemTripID></SystemTripID>
   </TripRateData>
</CISDocument>
{R}TripRateData.SystemTripID=TRIP_ID; {R}{R}Rerate Bookings at Night{R}processTripRate{R}API{EOL}SDL_SLA_SEL_TO_TENDER{R}1{R}SDL_SLA_SEL_TO_TENDER{R}{R}{R}SLA_SEL_TO_TENDER{R}{R}select to_char(ld.ld_leg_id) ld_leg_id
from ld_leg_t ld
join shpm_t sh on sh.shpm_id = ld.shpm_id
where  ld.cur_optlstat_id = 305--planned
and ld.lgst_grp_cd = 'SLA'
-- finish date is set
and regexp_like (substr(nvl(sh.rfrc_num19, 'Nil'),1,10), '[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
-- and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
-- not to France
-- and (sh.cust_cd != '61022' OR sh.frm_shpg_loc_cd != 'MA')
-- and ld.srvc_cd is not null
-- not ocean service
and upper(nvl(ld.srvc_cd,'NULL')) not in ('SSEA','SS','SSEA_PP','SSEA_PD','SSEA_DD','SSEA_DP'
, 'OCEAN_PP','OCEAN_PD','OCEAN_DD','OCEAN_DP')

-- SLA from 'ABCYD' must be order status = 500
and not exists (select ldx.ld_leg_id
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA'
  and ldx.ld_leg_id = ld.ld_leg_id
  -- the leg to 'ABCYD', 'EXTYD' allowed in other than 500 status
  and upper(dtx.to_shpg_loc_cd) != 'EXTYD'
    and shx.rfrc_num16 != '500' -- order status other than 500
    -- there must be a leg to the 'ABCYD' or 'EXTYD' yard location
  and exists (select 1 from ld_leg_detl_t dtxx
                join shpm_t shxx on shxx.shpm_id=dtxx.shpm_id
                and upper(dtxx.to_shpg_loc_cd) = 'EXTYD'
              )
  -- ver. 2.2
  -- Marek Dziekanski 2022-07-05 01:10
)
{R}{R}LoadTenderData.SystemLoadID=ld_leg_id;{R}D:\JobTemplates\processTender.xml{R}Tender SLA Loads{R}processTender{R}API{EOL}SDL_SLA_TENDER_TRIP{R}1{R}SDL_SLA_TENDER_TRIP{R}{R}{R}SLA_TENDER_TRIP{R}{R}select distinct sd.trip_id
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
where ld.cur_optlstat_id = 305--planned
and ld.lgst_grp_cd = 'SLA'
and ld.srvc_cd is not null
and sd.trip_id is not null
and upper(ld.srvc_cd) in ('SSEA','SS','SSEA_PP','SSEA_PD','SSEA_DD','SSEA_DP'
, 'OCEAN_PP','OCEAN_PD','OCEAN_DD','OCEAN_DP')
and  exists (  -- non on delivery stop
  select sh.shpm_id
  from shpm_t sh
  WHERE sh.SHPM_ID = sd.SHPM_ID
    and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES' -- not delivery stop
    -- ver. 2.0.2
    -- Marek Dziekanski 2021-03-26 13:24
)

{R}{R}TripTenderData.SystemTripID=trip_id;{R}D:\JobTemplates\tender_trip.xml{R}Tender SLA Loads{R}processTender{R}API{EOL}SDL_STR_SEU_CHN_RPT_LATE_DELIVERY{R}1{R}SDL_STR_SEU_CHN_RPT_LATE_DELIVERY{R}03_API_RRT_LOAD{R}I_UPD_LDFLG_03,I_UPD_LDSCDORIGSDT,I_UPD_LDSCDORIGEDT,I_UPD_ LDPRVLGARRDT{R}SEU_CHN_RPT_LATE_DELIVERY{R}{R}	select to_char(sdn.ld_leg_id) as ld_leg_id ,  ln.strd_dtt as start_date
, case nvl(rf.rfrc_num_id,0)
      when 0 then 'AT_ADD'
      else 'AT_UPDATE'
  end as lt_activity

, to_char(rf.rfrc_num_id) as lt_rfrc_num_id
, to_char(nvl(stp.drop_arvl_rptd_dtt, stp.carr_eta_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')  as lt_ref_num

, 'LDPRVLGARRDT' as lt_rfrc_name
, case nvl(rfe.rfrc_num_id,0)
      when 0 then 'AT_ADD'
      else 'AT_UPDATE'
  end as en_activity
, to_char(rfe.rfrc_num_id) as en_rfrc_num_id
, nvl(to_char(ln.end_dtt, 'yyyy-mm-dd"T"hh24:mi'), 'Nil') as en_ref_num
, 'LDSCDORIGEDT' as en_rfrc_name

, case nvl(rfs.rfrc_num_id,0)
      when 0 then 'AT_ADD'
      else 'AT_UPDATE'
  end as st_activity
, to_char(rfs.rfrc_num_id) as st_rfrc_num_id
, to_char(ln.strd_dtt, 'yyyy-mm-dd"T"hh24:mi') as st_ref_num
, 'LDSCDORIGSDT'  as st_rfrc_name

, case nvl(rff.rfrc_num_id,0)
      when 0 then 'AT_ADD'
      else 'AT_UPDATE'
   end as fl_activity
, to_char(rff.rfrc_num_id) as fl_rfrc_num_id
, '03' as fl_ref_num
, 'LDFLG'  as fl_rfrc_name

from ld_leg_detl_t sd
inner join ld_leg_detl_t sdn on sd.shpm_id=sdn.shpm_id
      and sd.to_shpg_loc_cd = sdn.frm_shpg_loc_cd
inner join ld_leg_t lp on lp.ld_leg_id = sd.ld_leg_id
inner join ld_leg_t ln on ln.ld_leg_id = sdn.ld_leg_id
inner join stop_t stp on stp.stop_id = sd.drop_stop_id
left join rfrc_num_t rf
   -- inner join linking rf with dm
   inner join dom_val_t dm
      on rf.rfrc_num_typ = dm.val_enu
      and dm.val_cd is NOT NULL
      and dm.val_cd='LDPRVLGARRDT'
on rf.ld_leg_id = ln.ld_leg_id
left join rfrc_num_t rfe
   -- inner join linking rf with dm LDPRVLGARRDT
   inner join dom_val_t dme
      on rfe.rfrc_num_typ = dme.val_enu
      and dme.val_cd is NOT NULL
      and dme.val_cd='LDSCDORIGEDT'
on rfe.ld_leg_id = sdn.ld_leg_id

left join rfrc_num_t rfs
   -- inner join linking rf with dm
   inner join dom_val_t dms
      on rfs.rfrc_num_typ = dms.val_enu
      and dms.val_cd is NOT NULL
      and dms.val_cd='LDSCDORIGSDT'
on rfs.ld_leg_id = sdn.ld_leg_id

-- joining LDFLG to mark loads for rerating
left join rfrc_num_t rff
   -- inner join linking rf with dm
   inner join dom_val_t dmf
      on rff.rfrc_num_typ = dmf.val_enu
      and dmf.val_cd is NOT NULL
      and dmf.val_cd='LDFLG'
	on rff.ld_leg_id = sdn.ld_leg_id

where ln.lgst_grp_cd = 'SEU'
and nvl(stp.drop_arvl_rptd_dtt, stp.carr_eta_dtt) is not null
and ln.cur_optlstat_id between 320 and 345
and  nvl(stp.drop_arvl_rptd_dtt, stp.carr_eta_dtt) != ln.strd_dtt
-- excluding all loads having more than 1 shipments
and not exists (select xsd.ld_leg_id, count(xsd.shpm_id) as nn from ld_leg_detl_t xsd
where xsd.ld_leg_id = sdn.ld_leg_id
--  start date in reference if set then in correct format
and validate_conversion(nvl(rfs.rfrc_num, '1970-01-01T24:01:01') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
group by xsd.ld_leg_id
having count(xsd.shpm_id) > 1)
-- excluding the loads that have already been processed
and to_char(nvl(stp.drop_arvl_rptd_dtt, stp.carr_eta_dtt), 'yyyy-mm-dd"T"hh24:mi:ss') != nvl(rf.rfrc_num,'Nil')
-- ver: 2.4.3
-- Marek Dziekanski 2022-09-07 17:13
order by ld_leg_id


{R}{R}{R}{R}SEU Report Late/Early Delivery{R}{R}Chaining{EOL}{R}2{R}03_API_RRT_LOAD{R}SEU_RRT_LATE_BKGS{R}{R}SEU_RRT_LD_SHPFLG_03{R}RRT_UNSPD{R}select to_char(ld.ld_leg_id) as ld_leg_id
--, to_char(ld.ld_leg_id) as ld_leg_id
--, to_char(rf.rfrc_num_id) as rfrc_num_id
from  ld_leg_t ld 
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG'
-- ver 1.1
-- Marek Dziekanski 2021-09-22 14:22
where rf.rfrc_num = '03'
group by ld.ld_leg_id{R}<CISDocument>
   <ApiHeader>
      <OperationName>processLoadRate</OperationName>
   </ApiHeader>
   <LoadRateData>
     <SystemLoadID></SystemLoadID>
   </LoadRateData>
	<IDsAreReferenceNumbersFlag>false</IDsAreReferenceNumbersFlag>
	<KeepSpotRateFlag>false</KeepSpotRateFlag>
	<SupressDetailedResultsFlag>true</SupressDetailedResultsFlag>
   <UncommitFlag>true</UncommitFlag>
</CISDocument>
{R}LoadRateData.SystemLoadID=LD_LEG_ID; {R}{R}Rerates Loads using API{R}processLoadRate{R}API{EOL}{R}3{R}SEU_RRT_LATE_BKGS{R}SEU_CHN_UPD_LDSTS{R}{R}SEU_CHN_RRT_LATE_BKGS{R}{R}select to_char(tr.trip_id) as trip_id
--, to_char(ld.ld_leg_id) as ld_leg_id
--, to_char(rf.rfrc_num_id) as rfrc_num_id
from trip_t tr
inner join ld_leg_t ld on ld.trip_id = tr.trip_id
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG'
-- ver 1.1
-- Marek Dziekanski 2021-09-22 14:22
where rf.rfrc_num = '03'
group by tr.trip_id
{R}{R}TripRateData.SystemTripID=TRIP_ID;{R}D:\JobTemplates\rrt_bkgs.xml{R}Re-rates Late Bookings{R}processTripRate{R}API{EOL}{R}4{R}SEU_CHN_UPD_LDSTS{R}SEU_ANNC_LATE_DELIVERY{R}I_UPD_LDSTS{R}SEU_CHN_UPD_LDSTS{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
	, lt_rf.rfrc_num as curr_rfrc
, case nvl(lt_rf.rfrc_num_id, 0)
		when 0 then 'AT_ADD'
		else 'AT_UPDATE'
	end as LT_ACTIVITY

		, nvl(pld.carr_cd, ' ') || ' ' ||
		case nvl(stp.drop_arvl_rptd_dtt, to_date('1970-01-01','yyyy-mm-dd'))
		-- if AAD not set
			when to_date('1970-01-01','yyyy-mm-dd') then
					case greatest( to_date(rf.rfrc_num, 'yyyy-mm-dd"T"hh24:mi:ss'), stp.carr_eta_dtt)
						when stp.carr_eta_dtt then 'Late ' || to_char(round(abs((stp.carr_eta_dtt - to_date(rf.rfrc_num, 'yyyy-mm-dd"T"hh24:mi:ss')) * 24)))  || ' hrs'                                           
						else  'Early ' || to_char(round(abs((stp.carr_eta_dtt - to_date(rf.rfrc_num, 'yyyy-mm-dd"T"hh24:mi:ss')) * 24)))  || ' hrs'                                           
					end
    -- if AAD set, just set Load Status to 'Arrived'
		else 'Arrived' 
	end as lt_rfrc_num

,	'LDSTS' as lt_rfrc_name
, to_char(lt_rf.rfrc_num_id) as lt_rfrc_num_id
from ld_leg_t ld
-- connecting previous leg using shipment and locations
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join ld_leg_detl_t sp on sp.shpm_id = sd.shpm_id
	and sd.frm_shpg_loc_cd = sp.to_shpg_loc_cd
	inner join stop_t stp on stp.stop_id = sp.drop_stop_id
inner join ld_leg_t pld on pld.ld_leg_id = sp.ld_leg_id

inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd = 'LDSCDORIGSDT'

inner join rfrc_num_t arf on arf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t adm on arf.rfrc_num_typ = adm.val_enu and adm.val_cd = 'LDFLG'

left join rfrc_num_t lt_rf 
	inner join dom_val_t lt_dm on lt_rf.rfrc_num_typ = lt_dm.val_enu and lt_dm.val_cd = 'LDSTS'
on lt_rf.ld_leg_id = ld.ld_leg_id
where ld.lgst_grp_cd = 'SEU'
and nvl(stp.drop_arvl_rptd_dtt, stp.carr_eta_dtt) is NOT NULL
-- ver: 1.4
-- Marek Dziekanski 2022-05-19 15:20
and arf.rfrc_num = '03'
{R}{R}{R}{R}SEU Report Late/Early Delivery{R}{R}Chaining{EOL}{R}5{R}SEU_ANNC_LATE_DELIVERY{R}SEU_CHN_LDFLG_03_DELETE{R}{R}SEU_ANNC_LATE_DELIVERY{R}TENDER_UPDATE{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd
from ld_leg_t ld
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd = 'LDFLG'
where ld.lgst_grp_cd = 'SEU'
and ld.cur_optlstat_id in (310,320)
-- ver: 1.0
-- Marek Dziekanski 2022-02-28 22:12
and rf.rfrc_num = '03'{R}<?xml version="1.0" encoding="UTF-8"?>
