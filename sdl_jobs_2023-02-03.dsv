   <ApiHeader>
      <OperationName>processLoadRate</OperationName>
   </ApiHeader>
   <LoadRateData>
     <SystemLoadID></SystemLoadID>
   </LoadRateData>
	<IDsAreReferenceNumbersFlag>false</IDsAreReferenceNumbersFlag>
	<KeepSpotRateFlag>false</KeepSpotRateFlag>
	<SupressDetailedResultsFlag>true</SupressDetailedResultsFlag>
   <UncommitFlag>true</UncommitFlag>
</CISDocument>
{R}LoadRateData.SystemLoadID=LD_LEG_ID; {R}{R}Rerates Loads at Night{R}processLoadRate{R}API{EOL}{R}3{R}SEU_RRT_BKGS_NIGHT{R}{R}{R}SEU_RRT_BKGS_NIGHT{R}RRT_BKGS{R}select tp.trip_id as trip_id
from ld_leg_t ld
inner join trip_t tp on tp.trip_id = ld.trip_id
where ld.lgst_grp_cd = 'SEU'
and ld.ratg_vlid_yn = 'F'
and ld.cur_optlstat_id between 305 and 335
and tp.updt_dtt < sysdate - 60 
and not exists (select count(lld.ld_leg_id), tp.trip_id
    from trip_t tp
    inner join ld_leg_t lld on tp.trip_id = lld.trip_id
    where lld.ld_leg_id = ld.ld_leg_id
    group by tp.trip_id
    having count(lld.ld_leg_id) > 30)
--ver 1.0
-- Marek Dziekanski 2022-02-07 20:41
group by tp.trip_id
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processTripRate</OperationName>
   </ApiHeader>
   <TripRateData>
     <SystemTripID></SystemTripID>
   </TripRateData>
</CISDocument>
{R}TripRateData.SystemTripID=TRIP_ID; {R}{R}Rerate Bookings at Night{R}processTripRate{R}API{EOL}SDL_SEU_UPD_CDD2_ETA{R}1{R}SDL_SEU_UPD_CDD2_ETA{R}CHN_UPD_TDEVCD_8{R}{R}SEU_UPD_CDD2_ETA{R}SET_SHPM_RFRC_NUM{R}select sh.shpm_num as ref_key
, case greatest(trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)), to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd'))
	when trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)) then to_char(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
	else 'Nil'
	end as ref_num
, to_char(rf.rfrc_num_id) as ref_id
, case when rf.rfrc_num_id is null then 'AT_ADD'
	 else 'AT_UPDATE'
	end as activity
	, cast('CDD2' as varchar2(80)) as ref_type
-- DEVCD

        , case validate_conversion(substr(nvl(sh.rfrc_num3,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
        when 1 then case greatest(trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)), to_date(substr(sh.rfrc_num3, 1, 10), 'yyyy-mm-dd'))
                    when trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)) then cast('5' as varchar2(120))
                    else 'Nil'
                    end
        else cast('5' as varchar2(120)) 
      end as t_ref_num

	, to_char(trf.rfrc_num_id) as t_ref_id
, case when trf.rfrc_num_id is null then 'AT_ADD'
	 else 'AT_UPDATE'
	end as t_activity
, cast('TDEVCD' as varchar2(80)) as t_ref_type
	 
from ld_leg_detl_t sd
--join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
join stop_t st on sd.drop_stop_id = st.stop_id
-- only the loads having dest = sh.dest i.e. the final ones
join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
-- left joining reference
left join rfrc_num_t rf 
	 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CDD2'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t trf 
	 inner join dom_val_t tdm on tdm.val_enu = trf.rfrc_num_typ and tdm.val_cd='TDEVCD'
on trf.shpm_id = sh.shpm_id
-- last stop ETA set
where nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt) is not null
-- CDD2 is different to ETA
and ( nvl(substr(rf.rfrc_num, 1, 13), '1970-01-01') != to_char(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt), 'yyyy-mm-dd"T"hh24')
	or upper(nvl(rf.rfrc_num,'NIL')) = 'NIL'
)
-- CDD is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- and the stop date later than CDD
and trunc(nvl(st.carr_eta_dtt, st.carr_eta_rptd_dtt)) > to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
-- ver. 1.5
-- Marek Dziekanski, 2022-09-21 16:27
and exists (select 1 from op_ap_statnst_t op 
		where op.ld_leg_id = sd.ld_leg_id
	  and substr(op.sec_cd, 1, 2) in ('11','13','14','20','21' , '31','45','67','SC','82')
	)
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal></ReferenceNumberActionEnumVal>
     <ReferenceNumberCategoryEnumVal>RNC_SHPM</ReferenceNumberCategoryEnumVal>
     <ReferenceNumberEntityIdShipmentNumberFlag>TRUE</ReferenceNumberEntityIdShipmentNumberFlag>
     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <ReferenceNumberTypeCode></ReferenceNumberTypeCode>
     <ReferenceNumber></ReferenceNumber>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY; ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY; ReferenceNumberUpdateData.ReferenceNumber=REF_NUM; ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID; ReferenceNumberUpdateData.ReferenceNumberTypeCode=REF_TYPE; {R}{R}Sets CDD2 when a transport is late{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}2{R}CHN_UPD_TDEVCD_8{R}{R}I_UPD_TDEVCD_8,I_SET_SHPM_RFRC,I_GEN_CDD2_EVENT,I_ALRT_CDD2_EVENT{R}CHN_UPD_TDEVCD_8{R}{R}select sh.shpm_num as ref_key, trim(nvl(rf.rfrc_num,'NULL')) as tt
, sh.shpm_num as shpm_num
, to_char(sh.shpm_id) as shpm_id
-- 8 is the code of TDEVCD for early delivery
, to_char(rf.rfrc_num_id) as ref_id
, case when rf.rfrc_num_id is null then 'AT_ADD'
   else 'AT_UPDATE'
  end as activity
, to_char(srf.rfrc_num_id) as s_ref_id
, 'AT_UPDATE' as s_activity
, cast('Nil' as varchar2(70)) as s_ref_num
, cast('CDD2' as varchar2(70)) as s_ref_type
,  'MSG:CDD2: Nil , Chassis No: ' || SD.SHPM_NUM
  || ', Customer Name: ' || sd.cust_name
  || ', CDD2: Nil'
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as CDD2
from ld_leg_detl_t sd
join stop_t st on st.stop_id = sd.drop_stop_id
-- only the loads having dest = sh.dest i.e. the final ones
join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join shpg_loc_t sl on sl.shpg_loc_cd = sh.to_shpg_loc_cd
inner join addr_t ad on ad.addr_id = sl.addr_id
--CDD2
inner join rfrc_num_t srf on srf.shpm_id = sh.shpm_id
inner join dom_val_t sdm on sdm.val_enu = srf.rfrc_num_typ and sdm.val_cd='CDD2'
-- left joining reference
left join rfrc_num_t rf
   -- inner join to the left joined reference table
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='TDEVCD'
on rf.shpm_id = sh.shpm_id
where st.last_cmpd_arvl_dtt is not null
-- CDD is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- and the stop date earlier than CDD
and st.last_cmpd_arvl_dtt <= to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
-- and cdd2 is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num3,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- ver. 1.1a
-- Marek Dziekanski, 2022-06-29 23:40
-- added exclusion for SLA customers
and trim(nvl(rf.rfrc_num,'NULL')) not in ('5', '8')
and NOT (sh.lgst_grp_cd = 'SLA' and sh.cust_cd in ('65031','68477') )
{R}{R}{R}{R}Handle Transport Deviation 8 {R}{R}Chaining{EOL}SDL_SLA_CHN_GEN_LD_EXTYD_EVENT{R}1{R}SDL_SLA_CHN_GEN_LD_EXTYD_EVENT{R}{R}I_GEN_LD_EXTYD_EVENT,I_ALRT_LD_EXTYD{R}SLA_CHN_GEN_LD_EXTY_EVENT{R}{R}select distinct ld.ld_leg_id
, 'MSG:LD_EXTYD:' || to_char(ld.ld_leg_id) || '  Chassis No: ' || SD.SHPM_NUM 
  || ' , Customer Name: ' || sd.cust_name
  || ' , Delivery: ' || to_char(st.cmpd_arvl_dtt, 'yyyy-mm-dd hh24:mi') 
  || ' , City: ' || sd.to_cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join stop_t st on st.stop_id = sd.drop_stop_id and sd.to_shpg_loc_cd='EXTYD'
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
where ld.lgst_grp_cd = 'SLA'
and sd.to_shpg_loc_cd = 'EXTYD'
and sh.to_shpg_loc_cd='EXTYD'
and sh.rfrc_num16 = '500' --order status
and ld.cur_optlstat_id in (345, 350) -- completed, closed
and not exists ( select 1 from mntr_acty_t mon
   where mon.ld_leg_id = ld.ld_leg_id
   and mon.alrt_typ_cd = 'LD_EXTYD'
-- ver 1.0
-- Marek Dziekanski 2021-04-29 14:49
   )
{R}{R}{R}{R}Generate SLA LD delivered to EXTYD event{R}{R}Chaining{EOL}SDL_SLA_CHN_GEN_PFD_EVENT{R}1{R}SDL_SLA_CHN_GEN_PFD_EVENT{R}{R}I_GEN_PFD_EVENT,I_ALRT_PFD{R}GEN_PFD_EVENT{R}{R}select distinct to_char(sd.shpm_id) as shpm_id
, sd.shpm_num as shpm_num
,  'MSG:PFD:' || substr(aas.shpm_rfrc_num4,1,10) || ', Chassis No: ' || SD.SHPM_NUM 
  || ', Customer Name: ' || sd.cust_name
  || ', PFD: ' || aas.shpm_rfrc_num4
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as Text
 , 'RPT_PFD' as alert_type_code
from audt_shpm_t aas 
inner join ld_leg_detl_t sd on sd.shpm_num = aas.shpm_num
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
inner join shpg_loc_t sl on sl.shpg_loc_cd = aas.shpm_to_shpg_loc_cd
join addr_t ad on ad.addr_id = sl.addr_id
where ld.cur_optlstat_id < 345 -- complete
and aas.audt_sys_dtt > to_date('2021-05-01','yyyy-mm-dd') -- to avoid generating previous msgs 
and upper(trim(nvl(aas.shpm_rfrc_num4,'Nil'))) != 'NIL'
-- there was at least one change of PFD
and exists (select 1 from audt_shpm_t xxs
  where xxs.shpm_num = aas.shpm_num
  and nvl(aas.shpm_rfrc_num4, 'Nil') != nvl(xxs.shpm_rfrc_num4, 'Nil'))
-- get the latest record from audit table
and audt_shpm_id in (select max(audt_shpm_id)
  from audt_shpm_t xas
  group by xas.shpm_num
)
-- and the change has not already been reported
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.shpm_num = aas.shpm_num
  and mon.alrt_typ_cd ='RPT_PFD'
  -- alert text is set to the PFD value
  and substr((nvl(mon.alrt_text,'NULL')), 1,18) = 'MSG:PFD:' || substr(trim(nvl(aas.shpm_rfrc_num4,'Nil')), 1,10)
-- ver. 1.0
-- Marek Dziekanski 2021-05-24 10:08
)
order by shpm_id
{R}{R}{R}{R}Generate PFD Event{R}{R}Chaining{EOL}SDL_SLA_CHN_TENDER_CANCEL{R}1{R}SDL_SLA_CHN_TENDER_CANCEL{R}SLA_CHN_RM_LD_FROM_TRIP{R}I_TENDER_CANCEL,I_RFRC_LD,I_UPD_CARR_CD{R}SLA_CHN_TENDER_CANCEL{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id

, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
end as activity
, cast('LDFLG_C' as varchar2(20))  as code
, cast('DD' as varchar2(30)) as ref_num

, crf.rfrc_num_id as c_ref_num_id
, case nvl(crf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as c_activity
, cast('LDCARRCD' as varchar2(20)) as c_code
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
left join rfrc_num_t rf
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG_C'
on rf.ld_leg_id = ld.ld_leg_id

left join rfrc_num_t crf
  inner join dom_val_t cdm on cdm.val_enu = crf.rfrc_num_typ and cdm.val_cd='LCARRCD'
on crf.ld_leg_id = ld.ld_leg_id

where ld.cur_optlstat_id in (310,320)
and sh.lgst_grp_cd = 'SLA'
and ld.carr_cd is not null
-- not on a booking
and sd.trip_id is NULL
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
)
-- SLA with staus 500 cannot be cancelled
and not exists ( select shx.shpm_num
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA'
    and nvl(shx.rfrc_num16,'Nil') = '500' -- order status 500
    and ldx.ld_leg_id = ld.ld_leg_id
--ver. 1.0
-- Marek Dziekanski 2022-07-05 09:26
)
{R}{R}{R}{R}Cancel SLA Tenders{R}{R}Chaining{EOL}{R}2{R}SLA_CHN_RM_LD_FROM_TRIP{R}SLA_CHN_DEL_DOCK_CMT{R}I_RM_LD_FROM_TRIP,I_RFRC_LD,I_UPD_CARR_CD{R}SLA_CHN_RM_LD_FROM_TRIP{R}{R}select distinct to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id

, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
end as activity
, cast('LDFLG_C' as varchar2(20))  as code
, cast('DD' as varchar2(30)) as ref_num

, crf.rfrc_num_id as c_ref_num_id
, case nvl(crf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as c_activity
, cast('LDCARRCD' as varchar2(20)) as c_code
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
left join rfrc_num_t rf
  inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG_C'
on rf.ld_leg_id = ld.ld_leg_id

left join rfrc_num_t crf
  inner join dom_val_t cdm on cdm.val_enu = crf.rfrc_num_typ and cdm.val_cd='LCARRCD'
on crf.ld_leg_id = ld.ld_leg_id

where ld.cur_optlstat_id in (310,320)
and sh.lgst_grp_cd = 'SLA'
and ld.carr_cd is not null
-- a part of booking
and sd.trip_id is NOT NULL
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
)
-- SLA with staus 500 cannot be cancelled
and not exists ( select shx.shpm_num
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA'
    and nvl(shx.rfrc_num16,'Nil') = '500' -- order status 500
    and ldx.ld_leg_id = ld.ld_leg_id
--ver. 1.0
-- Marek Dziekanski 2022-07-13 09:15
)
{R}{R}{R}{R}Remove SLA Load from Booking{R}{R}Chaining{EOL}{R}3{R}SLA_CHN_DEL_DOCK_CMT{R}{R}I_DEL_DOCK_CMT,I_DEL_LD_RFRC{R}SLA_CHN_DEL_DOCK_CMT{R}{R}select to_char(dc.dock_cmtd_id) as dock_cmtd_id
, to_char(dc.stop_id) as stop_id
, to_char(rf.rfrc_num_id) as rfrc_num_id
from dock_cmtd_t dc
inner join ld_leg_t ld on ld.ld_leg_id = dc.ld_leg_id
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LDFLG_C'
where ld.lgst_grp_cd = 'SLA'
and ld.cur_optlstat_id < 310 --tendered
-- ver. 1.0
-- Marek Dziekanski 2022-07-05 09:49
and nvl(rf.rfrc_num,'Nil') = 'DD'
{R}{R}{R}{R}Delete a Dock Commitment for SLA{R}{R}Chaining{EOL}SDL_SLA_CHN_UPD_PRALCDD{R}1{R}SDL_SLA_CHN_UPD_PRALCDD{R}CHN_GEN_PRALCDD_EVENT{R}I_UPD_PRALCDD,I_UPD_CDD{R}CHN_UPD_PRALCDD{R}{R}select sd.shpm_id
, to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi') as PRALCDD
, case nvl(rf.rfrc_num_id,0) when 0 then  'AT_ADD' else 'AT_UPDATE' end as Action
, to_char(rf.rfrc_num_id) as ref_id

, to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi') as CDD
, case nvl(rf2.rfrc_num_id,0) when 0 then  'AT_ADD' else 'AT_UPDATE' end as Action2
, to_char(rf2.rfrc_num_id) as ref_id2
, sd.shpm_num as shpm_num
 , 'MSG:PRALCDD:' || to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi')|| ', Chassis No: ' || SH.SHPM_NUM
  || ', Customer Name: ' || sd.cust_name
  || ', PRALCDD: ' || to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi')
  || ', City: ' || sd.to_cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
join trip_t tr on tr.trip_id = ld.trip_id
left join rfrc_num_t rf
   -- inner join to the left join
   inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd='PRALCDD'
   -- the end of the left join
on rf.shpm_id = sd.shpm_id
left join rfrc_num_t rf2
   -- inner join to the left join
   inner join dom_val_t dm on rf2.rfrc_num_typ = dm.val_enu and dm.val_cd='CDD'
   -- the end of the left join
on rf2.shpm_id = sd.shpm_id
where ld.carr_eta_last_stop_dtt is not null
and ld.lgst_grp_cd = 'SLA'
and ld.CUR_OPTLSTAT_ID = 335 -- in transit
and (substr(nvl(rf.rfrc_num,'Nil'),1,10) != to_char(ld.carr_eta_last_stop_dtt, 'yyyy-mm-dd')
  OR substr(nvl(rf2.rfrc_num,'Nil'),1,10) != to_char(ld.carr_eta_last_stop_dtt, 'yyyy-mm-dd'))
  -- ver. 1.3
  -- handles chain jobs chn_upd_pralcdd
  -- Marek Dziekanski 2022-07-07 11:04
and upper(substr(nvl(ld.srvc_cd,'NULL'), 1, 5)) = 'OCEAN'
{R}{R}{R}{R}Scheduled: Chain updatin and reporting PRALCDD change{R}{R}Chaining{EOL}{R}2{R}CHN_GEN_PRALCDD_EVENT{R}{R}I_GEN_PRALCDD_EVENT,I_RPT_PRALCDD_EVENT{R}GEN_PRALCDD_EVENT{R}{R}select to_char(sd.shpm_id) as shpm_id
	 , 'MSG:PRALCDD:' || to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi')|| ', Chassis No: ' || SH.SHPM_NUM 
		|| ', Customer Name: ' || sd.cust_name
		|| ', PRALCDD: ' || to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi')
		|| ', City: ' || sd.to_cty_name
		|| ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
		|| ', Sweden: dsd.sodertalje@scania.com'
		|| ', The Netherlands: dsd.zwolle@scania.com'
		|| ', France: delivery.servicedeskangers@scania.com'
		as text
        , sh.shpm_num as shpm_num
	from ld_leg_t ld
	inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
	inner join shpm_t sh on sh.shpm_id = sd.shpm_id
	inner join rfrc_num_t rf on rf.shpm_id = sd.shpm_id
	inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd='PRALCDD'
	where ld.carr_eta_last_stop_dtt is not null
    and ld.lgst_grp_cd = 'SLA'
	and substr(nvl(rf.rfrc_num,'Nil'),1,10) = to_char(ld.carr_eta_last_stop_dtt, 'yyyy-mm-dd')
	and upper(substr(nvl(ld.srvc_cd,'NULL'), 1, 5)) = 'OCEAN'
	and not exists (select 1 from MNTR_ACTY_T mon
		where mon.shpm_num = sh.shpm_num
		and mon.alrt_typ_cd ='RPT_PRALCDD'
		and substr(nvl(mon.alrt_text,'NULL'),1,28) = 'MSG:PRALCDD:' || to_char(ld.carr_eta_last_stop_dtt,'yyyy-mm-dd"T"hh24:mi')
		-- ver. 1.1
		-- handles chain jobs chn_upd_pralcdd
	-- Marek Dziekanski 2022-03-04 17:43
)
{R}{R}{R}{R}Report a change of PRALCDD value{R}{R}Chaining{EOL}SDL_SLA_RRT_UNSPND_NIGHT{R}1{R}SDL_SLA_RRT_UNSPND_NIGHT{R}SLA_RRT_LD_NIGHT{R}{R}SLA_RRT_UNSPND_NIGHT{R}RRT_UNSPD{R}select ld.ld_leg_id as ld_leg_id
, nvl(ld.last_sec_cd, 'SUSP') as sec_cd
, current_date as dtt
from ld_leg_t ld
where ld.lgst_grp_cd = 'SLA'
and ld.ratg_vlid_yn = 'F'
and ld.cur_optlstat_id between 305 and 335
and ld.trip_id is null
and ld.updt_dtt < sysdate - 60/1440
--ver 1.0
-- Marek Dziekanski 2021-11-05 11:41
and ld.sus_func_enu != 1 --supended
