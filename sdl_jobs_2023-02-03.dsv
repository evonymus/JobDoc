{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_TYPE_CODE; {R}{R}Report ETA for a Customer{R}processGenerateAlert{R}API{EOL}SDL_ALRT_CSL_VSL_DPT{R}1{R}SDL_ALRT_CSL_VSL_DPT{R}{R}{R}ALRT_CSL_VSL_DPT{R}ALRT_BOOKING{R}select distinct to_char(sh.shpm_id) as shpm_id
	, 'CSL_' || sh.to_shpg_loc_cd as alrt_code
		, 'MSG:VSLDT:' || to_char(ld.shpd_dtt, 'yyyy-mm-dd hh24:mi:ss')
	|| ', Chassis No: ' || sh.shpm_num 
	|| ', Customer Name: ' || nvl(rf.rfrc_num,' ')
	|| ', Shipment Destination Location Code:' || sh.to_shpg_loc_cd
	|| ', City: ' || sd.to_cty_name
	|| ', In case of any questions on the products mentioned in this mail, or if you want to unsubscribe, please contact the Delivery Service Desk. '
	|| ', Sweden: dsd.sodertalje@scania.com'
	|| ', The Netherlands: dsd.zwolle@scania.com'
	|| ', France: delivery.servicedeskangers@scania.com'
as text
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
	left join ( select max(mn.mntr_acty_id) as mntr_acty_id
			, mn.shpm_num
     from mntr_acty_t mn, shpm_t xsh
     where xsh.shpm_num = mn.shpm_num
        and substr(nvl(mn.alrt_text,'Nil'),1,10) = 'MSG:VSLDT:'
        and  mn.alrt_typ_cd='' || xsh.to_shpg_loc_cd
    group by mn.shpm_num
) aa on aa.shpm_num = sh.shpm_num
left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
left join rfrc_num_t rf 
	 -- inner join to the left joined reference table
	 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='ORDCNAM'
on rf.shpm_id = sh.shpm_id
where ld.lgst_grp_cd = 'SEU'
and ld.shpd_dtt is not null
and ld.srvc_cd in ('OCEAN_DD','OCEAN_DP','OCEAN_PD','OCEAN_PP','SSEA_DD','SSEA_DP','SSEA_PD','SSEA_PP')
and ld.shpd_dtt > to_date('2022-05-28','yyyy-mm-dd')
-- alert type aleady defined
and exists (select * from alrt_typ_t at 
    where at.alrt_typ_cd ='CSL_' || sh.to_shpg_loc_cd 
	) 
	-- ver 1.1
	-- Marek Dziekanski 2022-05-30 13:46
and substr(nvl(mna.alrt_text, 'Nil'),1,26) != 'MSG:VSLDT:' || to_char(ld.shpd_dtt, 'yyyy-mm-dd hh24:mi:ss')

