MASTER{R}NO{R}JOB_CD{R}NEXT_JOB_CD_SUCCESS{R}SUB_JOBS{R}ESC{R}TEMPL{R}SQL{R}XML{R}SUBST{R}TPLT_FILE{R}JOB_DESC{R}API{R}JOB_TYPE{EOL}SDL_ALRT_ADD{R}1{R}SDL_ALRT_ADD{R}{R}{R}ALRT_ADD{R}{R}SELECT distinct to_char(st.stop_id) as stop_id
, 'MSG:ADD:' || to_char(st.drop_arvl_rptd_dtt,'yyyymmddhh24mi') ||', Chassis No: ' || SD.SHPM_NUM 
  || ', Customer Name: ' || sd.cust_name
  || ', ALD: ' || to_char(st.drop_arvl_rptd_dtt, 'yyyy-mm-dd hh24:mi') 
  || ', City: ' || sd.to_cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
FROM STOP_T ST
JOIN LD_LEG_DETL_T SD ON SD.LD_LEG_ID = ST.LD_LEG_ID
WHERE st.drop_arvl_rptd_dtt IS NOT NULL
-- the stop has not been alerted yet
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.stop_id = st.stop_id
  and mon.alrt_typ_cd ='RPT_AAD'
  and substr(nvl(mon.alrt_text,'NULL'),1,20) = ('MSG:ADD:' || to_char(st.drop_arvl_rptd_dtt,'yyyymmddhh24mi'))
  -- ver 1.21
  -- Marek Dziekanski, 2021-03-01 11:28
)
{R}{R}AlertData.EntityID=STOP_ID;AlertData.AlertText=TEXT; {R}D:\JobTemplates\alrt_add.xml{R}Report a Stop{R}processGenerateAlert{R}API{EOL}SDL_ALRT_ADD_MA{R}1{R}SDL_ALRT_ADD_MA{R}{R}{R}ALRT_ADD_MA{R}ALRT_STOP{R}select distinct to_char(st.stop_id) as stop_id
,'RPT_AAD_MA' as alrt_type_code
, 'MSG:ADD:' || to_char(st.drop_arvl_rptd_dtt,'yyyy-mm-dd hh24:mi')
|| ', Chassis No: ' || SD.SHPM_NUM
|| ', Load: ' || to_char(sd.ld_leg_id)
|| ', Delivery Add ID:' || sd.to_shpg_loc_cd
|| ', Customer Name: ' || sh.cust_name
|| ', COW Customer: ' || nvl(rf.rfrc_num,' ')
|| ', Final Address ID:' || sh.to_shpg_loc_cd
|| ', City: ' || sh.to_cty_name
as text
from stop_t st
	inner join ld_leg_detl_t sd on sd.ld_leg_id = st.ld_leg_id
		inner join shpm_t sh on sh.shpm_id = sd.shpm_id
		left join ( select max(mn.mntr_acty_id) as mntr_acty_id
			 , mn.stop_id
			 from mntr_acty_t mn
			 where mn.alrt_typ_cd = 'RPT_AAD_MA'
		group by mn.stop_id
	) aa on aa.stop_id = st.stop_id
	left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
	left join rfrc_num_t rf
	 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where st.drop_arvl_rptd_dtt IS NOT NULL
	-- the stop has not been alerted yet
and sh.frm_shpg_loc_cd = 'MA'
and st.drop_arvl_rptd_dtt > to_date('2022-06-22','yyyy-mm-dd')
-- ver 1.1
-- Marek Dziekanski 2022-06-21 23:36
and substr(nvl(mna.alrt_text,'NULL'),1,24) != 'MSG:ADD:' || to_char(st.drop_arvl_rptd_dtt,'yyyy-mm-dd hh24:mi')
{R}<?xml version="1.0" encoding="UTF-8"?>
<CISDocument>
	<ApiHeader>
		<OperationName>processGenerateAlert</OperationName>
	</ApiHeader>
   <AlertData>
      <EntityID></EntityID>         
