{R}SystemLoadID=LD_LEG_ID;SECInformation.SECCode=SEC_CD;SECInformation.MovementDateTime=DTT; {R}{R}Nightly Unsuspend for SLA{R}processLoadUnSuspend{R}API{EOL}{R}2{R}SLA_RRT_LD_NIGHT{R}SLA_RRT_BKGS_NIGHT{R}{R}SLA_RRT_LD_NIGHT{R}RRT_UNSPD{R}select ld.ld_leg_id as ld_leg_id
from ld_leg_t ld
where ld.lgst_grp_cd = 'SLA'
and ld.ratg_vlid_yn = 'F'
