{R}LoadRateData.SystemLoadID=LD_LEG_ID; {R}{R}Rerates Loads using API{R}processLoadRate{R}API{EOL}{R}10{R}SEU_RRT_BKGS_SHPFLG_03{R}SEU_CHN_CDD2_PREV_TDEVCD_5{R}{R}SEU_RRT_BKGS_SHPFLG_03{R}RRT_BKGS{R}select to_char(tp.trip_id) as trip_id
from trip_t tp
-- linked with a shipment that hasn't been delivered yet
where tp.lgst_grp_cd = 'SEU'
and exists (select 1 from ld_leg_t ld 
  join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
  join shpm_t sh on sh.shpm_id = sd.shpm_id
  join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
  join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG03'
  where  ld.trip_id = tp.trip_id
    and sh.lgst_grp_cd = 'SEU'
    and ld.cur_optlstat_id < 345
    and sh.cur_optlstat_id < 260 -- delivered
    and rf.rfrc_num = '03' -- flag set for that job
-- ver: 1.0
-- Marek Dziekanski 2022-04-26 15:09:01
) order by trip_id


{R}<CISDocument>
   <ApiHeader>
