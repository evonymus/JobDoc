{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;{R}{R}Delete SHPFLG set to 03 - used by TDEVCD5{R}processMaintainEntityReferenceNumber{R}API{EOL}SDL_STR_SEU_PFD_FND_CHAIN{R}1{R}SDL_STR_SEU_PFD_FND_CHAIN{R}SEU_CHN_UPD_PEAD{R}{R}SEU_SHPFLG_IN_PROGRESS{R}{R}select to_char(sh.shpm_id) as shpm_id
from shpm_t sh
inner join  rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where rf.rfrc_num = '01'
and sh.lgst_grp_cd = 'SEU'
union all
select to_char(sh.shpm_id) 
from shpm_t sh
where rownum < 2{R}{R}{R}{R}Start Update O Delivery Window Using PFD/FND{R}{R}Decision{EOL}{R}2{R}SEU_CHN_UPD_PEAD{R}SEU_CHN_UPD_EAD{R}I_UPD_PICKUP_FRM_REFS,I_SET_SHPFLG_01,I_UPD_PDEVCD{R}SEU_CHN_UPD_PEAD{R}{R}select sh.shpm_num as shpm_num
	, to_date(substr(sh.rfrc_num13, 1, 16), 'yyyy-mm-dd"T"hh24:mi') as pk_frm
	-- if CDD2 is set (i.e delivery is late)
