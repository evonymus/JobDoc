{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_TYPE_CODE; {R}{R}Report ETA for MZ{R}processGenerateAlert{R}API{EOL}SDL_ALRT_FTP{R}1{R}SDL_ALRT_FTP{R}{R}{R}ALRT_FTP{R}{R}select to_char(sd.shpm_id) as shpm_id 
, 'MSG:FTP:' ||  ' Chassis No: ' || sd.shpm_num 
  || ', Customer Name: ' || cs.cust_name
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from ld_leg_detl_t sd
join trip_t tp on sd.trip_id = tp.trip_id
join ld_leg_detl_t psd on psd.shpm_id = sd.shpm_id 
  and psd.to_shpg_loc_cd = tp.frst_shpg_loc_cd
join stop_t st on st.stop_id = psd.drop_stop_id
join shpg_loc_t sl on sl.shpg_loc_cd = tp.frst_shpg_loc_cd
join shpm_t sh on sh.shpm_id = sd.shpm_id
join cust_t cs on cs.cust_cd = sh.cust_cd
join addr_t ad on ad.addr_id = sh.to_addr_id
where st.drop_arvl_rptd_dtt is not null
and floor(case regexp_instr(nvl(sl.extl_cd1,'NULL'), '^[0-9]?[0-9]?[0-9]') 
    when 1 then sysdate - st.drop_arvl_rptd_dtt + cast(sl.extl_cd1 as int)
    else sysdate - st.drop_arvl_rptd_dtt + 14
  end) > 0 -- shippment arrived earlier than EXTL_CD1 days
-- the stop has not been alerted yet
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.shpm_num = sh.shpm_num
  and mon.alrt_typ_cd ='RPT_FTP'
  and substr(nvl(mon.alrt_text,'NULL'),1,8) = 'MSG:FTP:' 
  -- ver 1.0
  -- Marek Dziekanski, 2021-02-25
)
{R}{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT; {R}D:\JobTemplates\alrt_ftp.xml{R}Alert Port Free Time Expire{R}processGenerateAlert{R}API{EOL}SDL_ALRT_LFND{R}1{R}SDL_ALRT_LFND{R}{R}{R}ALRT_LFND{R}{R}SELECT distinct to_char(sh.shpm_id) as shpm_id
, 'MSG:PFND:' || substr(sh.rfrc_num19,1,10) || ', Chassis No: ' || SH.SHPM_NUM 
  || ', Customer Name: ' || sd.cust_name
  || ', CDD2: ' || sh.rfrc_num3
  || ', City: ' || sd.to_cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
FROM SHPM_T SH
join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
WHERE    regexp_like(substr(nvl(sh.rfrc_num19,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and to_date(substr(sh.rfrc_num19,1,10), 'yyyy-mm-dd') > trunc(sysdate)
and trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
-- the stop has not been alerted yet
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.shpm_num = sh.shpm_num
  and mon.alrt_typ_cd ='RPT_PFND'
  and substr(nvl(mon.alrt_text,'NULL'),1,19) = 'MSG:PFND:' || substr(sh.rfrc_num19,1,10)
  -- ver 1.3
  -- Marek Dziekanski, 2021-05-14 16:12
){R}{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT; {R}D:\JobTemplates\alrt_lfnd.xml{R}Report late FND{R}processGenerateAlert{R}API{EOL}SDL_ALRT_LPFD{R}1{R}SDL_ALRT_LPFD{R}{R}{R}ALRT_LPFD{R}{R}SELECT  to_char(sh.shpm_id) as shpm_id
, 'MSG:LPFD:' || substr(sh.rfrc_num4,1,10) || ', Chassis No: ' || SH.SHPM_NUM 
  || ', Customer Name: ' || cs.cust_name
  || ', PFD: ' || sh.rfrc_num4
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
FROM SHPM_T SH
join cust_t cs on cs.cust_cd = sh.cust_cd
join addr_t ad on ad.addr_id = sh.to_addr_id
WHERE    regexp_like(substr(nvl(sh.rfrc_num4,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and NOT regexp_like(substr(nvl(sh.rfrc_num19,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and to_date(substr(sh.rfrc_num4,1,10), 'yyyy-mm-dd') > trunc(sysdate)
and trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
-- the stop has not been alerted yet
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.shpm_num = sh.shpm_num
  and mon.alrt_typ_cd ='RPT_PFND'
  and substr(nvl(mon.alrt_text,'NULL'),1,19) = 'MSG:LPFD:' || substr(sh.rfrc_num4,1,10)
  -- ver 1.2
  -- Marek Dziekanski, 2021-05-14 16:04
)
{R}{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT; {R}D:\JobTemplates\alrt_lpfd.xml{R}Report late FND{R}processGenerateAlert{R}API{EOL}SDL_CHN_DELSTOP_SHPM_REMOVE{R}1{R}SDL_CHN_DELSTOP_SHPM_REMOVE{R}{R}I_REMV_FM_PL_LD,I_ATTACH_TO_PLAN{R}CHN_DELSTOP_REMOVE{R}{R}select to_char(sh.shpm_id) as shpm_id
, to_char(sh.plan_id) as plan_id
, to_char(ssd.ld_leg_id) as ld_leg_id
, to_char(ssd.ld_leg_detl_id) as ld_leg_detl_id
from shpm_t sh 
inner join ld_leg_detl_t ssd on ssd.shpm_id = sh.shpm_id
where  upper(nvl(sh.rfrc_num18,'Nil')) = 'YES'
and exists (select ld.ld_leg_id, count(sd.shpm_id) as nn
       from ld_leg_detl_t sd
       inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
       where sd.ld_leg_id = ssd.ld_leg_id
       and ld.cur_optlstat_id < 325 -- loading confirming
       group by ld.ld_leg_id
       having count(sd.shpm_id) > 1
   ) 
-- ver 1.0
-- Marek Dziekanski 2021-10-08 10:17
order by ld_leg_id
{R}{R}{R}{R}Remove DELSTOP Shpipments from Loads{R}{R}Chaining{EOL}SDL_CHN_GEN_CDD2_EVENT{R}1{R}SDL_CHN_GEN_CDD2_EVENT{R}{R}I_GEN_CDD2_EVENT,I_ALRT_CDD2_EVENT{R}GEN_CDD2_EVENT{R}{R}select distinct to_char(sd.shpm_id) as shpm_id
, sd.shpm_num as shpm_num
,  'MSG:CDD2:' || substr(sh.rfrc_num3,1,10) || ', Chassis No: ' || SD.SHPM_NUM 
  || ', Customer Name: ' || sd.cust_name
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ', CDD2: ' || sh.rfrc_num3
  || ', City: ' || ad.cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as CDD2
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_num = sh.shpm_num
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
inner join shpg_loc_t sl on sl.shpg_loc_cd = sh.to_shpg_loc_cd
inner join addr_t ad on ad.addr_id = sl.addr_id
left join rfrc_num_t rf
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sd.shpm_id
left join (select max(mn.mntr_acty_id) as mntr_acty_id, mn.shpm_num
from mntr_acty_t mn
where mn.alrt_typ_cd='RPT_CDD2'
group by mn.shpm_num
) aa
left join mntr_acty_t mn on aa.mntr_acty_id = mn.mntr_acty_id
on aa.shpm_num = sh.shpm_num
where validate_conversion(substr(nvl(sh.rfrc_num3,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi') = 1
and  substr(nvl(mn.alrt_text,'NilNilNilNil'), 10, 10) != substr(trim(nvl(sh.rfrc_num3,'Nil')), 1,10)
and to_char(sh.crtd_dtt,'yyyy-mm-dd') >  case substr(sh.shpm_num, 1,1) 
                                            when '1' then '2021-11-20'         
                                            else '2021-11-20' 
                                        end
-- ver. 1.8
-- Marek Dziekanski 2022-03-28 13:21                                   
order by shpm_num{R}{R}{R}{R}Chain job generating CDD2 Event{R}{R}Chaining{EOL}SDL_CHN_SET_ETA_PICKUP_DATE{R}1{R}SDL_CHN_SET_ETA_PICKUP_DATE{R}{R}I_SET_ETA{R}SET_LD_SDL_DATE{R}{R}select to_char(ld.ld_leg_id) ld_leg_id
, ld.carr_cd as carr_cd
, sd.pick_stop_seq_num as stop_num
, to_date(substr(ld.rfrc_num12,1,16), 'yyyy-mm-dd"T"hh24:mi') as sdl_date
, 'RETA' as event_code
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join stop_t st on st.stop_id = sd.pick_stop_id
where ld.CUR_OPTLSTAT_ID in (310, 320)
-- pickup stop not set yet
and st.carr_eta_dtt is NULL
-- Planned Load date set to a date
and regexp_like(substr(nvl(ld.rfrc_num12,'nil'),1,16),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]')
and validate_conversion(nvl(ld.rfrc_num12,'nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss')=1
-- ver. 1.2.1
-- Marek Dziekanski 2022-02-01 11:32
and nvl(st.carr_eta_dtt,to_date('1970-01-01','yyyy-mm-dd')) != to_date(ld.rfrc_num12, 'yyyy-mm-dd"T"hh24:mi:ss'){R}{R}{R}{R}Set Scheduled Load Date{R}{R}Chaining{EOL}SDL_CHN_TENDER_CANCEL{R}1{R}SDL_CHN_TENDER_CANCEL{R}CHN_DEL_DOCK_CMT{R}I_TENDER_CANCEL,I_RFRC_LD{R}CHN_TENDER_CANCEL{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id 
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id

, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
end as activity
, cast('LDFLG_C' as varchar2(20))  as code
, cast('DD' as varchar2(30)) as ref_num
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
left join rfrc_num_t rf
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='LDFLG_C'
on rf.ld_leg_id = ld.ld_leg_id
where ld.cur_optlstat_id in (310,320)
and ld.carr_cd is not null
-- not on a booking
and sd.trip_id is NULL
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
or trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
)
-- SLA with staus 500 cannot be cancelled
and not exists ( select shx.shpm_num
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA' 
    and nvl(shx.rfrc_num16,'Nil') = '500' -- order status 500
    and ldx.ld_leg_id = ld.ld_leg_id
--ver. 1.0
-- Marek Dziekanski 2022-05-16 12:29
)
{R}{R}{R}{R}Cancel SLA and SEU Tenders{R}{R}Chaining{EOL}{R}2{R}CHN_DEL_DOCK_CMT{R}{R}I_DEL_DOCK_CMT,I_DEL_LD_RFRC{R}CHN_DEL_DOCK_CMT{R}{R}select to_char(dc.dock_cmtd_id) as dock_cmtd_id
, to_char(dc.stop_id) as stop_id
, to_char(rf.rfrc_num_id) as rfrc_num_id
from dock_cmtd_t dc
inner join ld_leg_t ld on ld.ld_leg_id = dc.ld_leg_id
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'LDFLG_C'
where ld.cur_optlstat_id < 310 --tendered
-- ver. 1.0
-- Marek Dziekanski 2022-05-16 14:24
and nvl(rf.rfrc_num,'Nil') = 'DD'
{R}{R}{R}{R}Delete a Dock Commitment{R}{R}Chaining{EOL}SDL_CHN_UPD_DCK_REFN{R}1{R}SDL_CHN_UPD_DCK_REFN{R}{R}I_UPD_DCK_DCLIP,I_UPD_DCK_DCKCHSS{R}CHN_UPD_DCK_REFN{R}{R}select to_char(dc.dock_cmtd_id) as dock
, ssh.chassis
, ld.trctr_lic_num as lic_no
from dock_cmtd_t dc
inner join ld_leg_t ld on ld.ld_leg_id = dc.ld_leg_id
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join (select sh.shpm_id, max(sh.rfrc_num1)  as chassis
    from shpm_t sh
    group by sh.shpm_id) ssh on ssh.shpm_id = sd.shpm_id
where ld.trctr_lic_num is not null
and ( nvl(dc.rfrc_num2,'Nil') != nvl(ld.trctr_lic_num,'Nil')
   or nvl(ssh.chassis,'Nil') != nvl(dc.rfrc_num1,'Nil')
-- ver. 1.2
-- Marek Dziekanski 2022-03-25 14:24
)
{R}{R}{R}{R}Updates licence number and chassis for a dock{R}{R}Chaining{EOL}SDL_REMOVE_FRM_TRIP{R}1{R}SDL_REMOVE_FRM_TRIP{R}TENDER_CANCEL{R}{R}REMOVE_FRM_TRIP{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
where ld.cur_optlstat_id in (310,320)
and ld.carr_cd is not null
--  on a booking
and sd.trip_id is not NULL
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- do not cancel a KD/SKD loads
and sh.CDTY_CD  NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
-- order status other than 500 for SLA
and not exists (select 1 from shpm_t xsh
   where xsh.shpm_id = sh.shpm_id
   and upper(xsh.lgst_grp_cd) = 'SLA'
   -- order status
   and trim(nvl(xsh.rfrc_num16, 'Nil')) = '500'
)
-- remove only the loads that have been already tendered
and exists (select 1 from shpm_t xsh
   join ld_leg_detl_t xsd on xsd.shpm_id = xsh.shpm_id
   join ld_leg_t xld on xld.ld_leg_id = xsd.ld_leg_id
   where xsd.shpm_id = sh.shpm_id
   and xld.cur_optlstat_id in (310,320) -- tenderded, tender accepted
   and xsd.trip_id is NULL
--ver. 1.3 
-- Marek Dziekanski 2020-08-26
)

{R}{R}SystemLoadID=LD_LEG_ID; {R}D:\JobTemplates\remove_frm_trip.xml{R}PAUSED, replaced by SEU_CHN_RM_LD_FRM_TRIP{R}processRemoveLoadFromTrip{R}API{EOL}{R}2{R}TENDER_CANCEL{R}{R}{R}TENDER_CANCEL{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, ld.carr_cd as carr_cd
, case ld.cur_optlstat_id 
  when 310 then 'S_TENDERED'
  when 320 then 'S_TENDER_ACCEPTED'
  end as cur_optlstat_id
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
where ld.cur_optlstat_id in (310,320)
and ld.carr_cd is not null
-- not on a booking
and sd.trip_id is NULL
and ( trim(upper(nvl(sh.rfrc_num18,'NIL'))) = 'YES'
or trim(upper(nvl(sh.rfrc_num15,'NIL'))) = 'HOLD'
or trim(upper(nvl(sh.rfrc_num19,'NIL'))) = 'NIL'
)
-- exclude KD/SKD from cancelling tenders
and sh.CDTY_CD NOT IN ('KDB','KDT','KDR','SKDB','SKDT','SKDR')
and not exists (select 1
from shpm_t ssh
inner join rfrc_num_t rf on rf.shpm_id = ssh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='EXTE2'
where ssh.shpm_id = sh.shpm_id
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 1
)
-- SLA with staus 500 cannot be cancelled
and not exists ( select shx.shpm_num
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA' 
    and nvl(shx.rfrc_num16,'Nil') = '500' -- order status 500
    and ldx.ld_leg_id = ld.ld_leg_id
--ver. 1.9.6
-- Marek Dziekanski 2022-03-01 10:53
)
