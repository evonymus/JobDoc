   -- WHEN CRD set to a date
   when 1 then
      case greatest(substr(sh.rfrc_num13, 1,10), substr(sh.rfrc_num6, 1,10))
        -- when PEAD > CRD set it to 4
        when substr(sh.rfrc_num13, 1,10) then cast('4' as varchar2(70))
        else
