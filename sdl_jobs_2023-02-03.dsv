	left join rfrc_num_t rf
	 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sh.shpm_id
where st.drop_arvl_rptd_dtt IS NOT NULL
	-- the stop has not been alerted yet
and sh.frm_shpg_loc_cd = 'MS'
and st.drop_arvl_rptd_dtt > to_date('2022-06-22','yyyy-mm-dd')
-- ver 1.1
-- Marek Dziekanski 2022-06-21 23:38
and substr(nvl(mna.alrt_text,'NULL'),1,24) != 'MSG:ADD:' || to_char(st.drop_arvl_rptd_dtt,'yyyy-mm-dd hh24:mi')
