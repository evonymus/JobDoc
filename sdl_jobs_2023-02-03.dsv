	</LoadRateData>
	<IDsAreReferenceNumbersFlag>false</IDsAreReferenceNumbersFlag>
	<KeepSpotRateFlag>true</KeepSpotRateFlag>
	<SupressDetailedResultsFlag>true</SupressDetailedResultsFlag>
        <ApplyResourceConstraintsFlag>true</ApplyResourceConstraintsFlag>
   <ValidateCarrierServiceEquipmentFlag>false</ValidateCarrierServiceEquipmentFlag>
</CISDocument>

{R}LoadRateData.SystemLoadID=LEG_ID; {R}{R}Second re-rating{R}processLoadRate{R}API{EOL}{R}15{R}SEU_SEL_TO_TENDER{R}SEU_SET_SHPFLG02{R}{R}SEU_SEL_TO_TENDER{R}{R}select to_char(ld.ld_leg_id) ld_leg_id
from ld_leg_t ld
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join shpm_t sh on sh.shpm_id = sd.shpm_id
inner join shpg_loc_t sf on sf.shpg_loc_cd = sd.frm_shpg_loc_cd
inner join shpg_loc_t st on st.shpg_loc_cd = sd.to_shpg_loc_cd
where ld.cur_optlstat_id = 305--planned
and ld.trip_id is NULL
and ld.lgst_grp_cd = 'SEU'
and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
-- not to or from Body Build location
and nvl(sf.extl_cd2,'Nil') != 'BB'  and nvl(st.extl_cd2, 'Nil') != 'BB'
-- finish date set
and regexp_like (substr(nvl(sh.rfrc_num19, 'Nil'),1,10), '[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
and upper(nvl(ld.srvc_cd,'NULL')) not in ( 'OCEAN_PP','OCEAN_PD','OCEAN_DD','OCEAN_DP')
-- exclude all loads that have a leg from body build location and BBFND has not yet been
-- set to a valid date
and not exists (
select sdd.shpm_num
from ld_leg_detl_t sdd
inner join ld_leg_t ld on ld.ld_leg_id = sdd.ld_leg_id
inner join shpg_loc_t sf on sf.shpg_loc_cd = sdd.frm_shpg_loc_cd
left join rfrc_num_t rf
    inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='BBFND'
on rf.shpm_id = sdd.shpm_id
where sh.shpm_id = sdd.shpm_id
and upper(nvl(sf.extl_cd2,'Nil')) = 'BB'
and sd.ld_leg_id is not null
and validate_conversion(nvl(rf.rfrc_num, 'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss') = 0
)
-- not ocean service
-- ver. 2.6
-- Marek Dziekanski 2022-03-03 13:36
group by ld.ld_leg_id{R}{R}LoadTenderData.SystemLoadID=ld_leg_id;{R}D:\JobTemplates\processTender.xml{R}SEU PFD/FND STEP 10: Tender SEU Loads{R}processTender{R}API{EOL}{R}16{R}SEU_SET_SHPFLG02{R}SEU_DEL_SHPFLG_REFS{R}{R}SEU_FLAG_TENDERED{R}UPD_SHPM_RFRC{R}select distinct sh.shpm_num
, substr(nvl(sh.rfrc_num3,'Nil') || '|' || nvl(rf.rfrc_num,'Nil') || '|' || to_char(el.flex_qnty1), 1, 70) as ref_num
, case nvl(rrf.rfrc_num_id, 0)
	when 0 then 'AT_ADD'
	else 'AT_UPDATE'
	end as activity
, rrf.rfrc_num_id as ref_id
, 'SHPFLG02' as code
from shpm_t sh
--inner join elmt_t el on el.shpm_id = sh.shpm_id
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join (select el.shpm_id as shpm_id, max(el.flex_qnty1) as flex_qnty1
    from elmt_t el
    group by el.shpm_id ) el on el.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t rf
	inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'MRN'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rrf
	inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ and ddm.val_cd='SHPFLG02'
on rrf.shpm_id = sh.shpm_id
where ld.cur_optlstat_id in (310,320) -- tendered, tender accepted
and rrf.rfrc_num_id is null
--ver 1.3
-- Marek Dziekanski 2022-06-28 11:15
and ld.carr_cd in ('AXL', 'HOD', 'PAN', 'AHO', 'ROO')
and nvl(ld.updt_dtt, ld.crtd_dtt) > to_date('2022-03-22','yyyy-mm-dd')
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal></ReferenceNumberActionEnumVal>
     <ReferenceNumberCategoryEnumVal>RNC_SHPM</ReferenceNumberCategoryEnumVal>
     <ReferenceNumberEntityIdShipmentNumberFlag>TRUE</ReferenceNumberEntityIdShipmentNumberFlag>
     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <ReferenceNumberTypeCode></ReferenceNumberTypeCode>
     <ReferenceNumber></ReferenceNumber>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=SHPM_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE;{R}{R}Flag Tendered Loads{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}17{R}SEU_DEL_SHPFLG_REFS{R}TENDER_TO_BODY_BUILD{R}{R}SEU_DEL_SHPFLG_REFS{R}{R}select to_char(rf.shpm_id) as ref_key
, to_char(rf.rfrc_num_id) as ref_id
from rfrc_num_t rf 
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='SHPFLG'
inner join shpm_t sh on sh.shpm_id = rf.shpm_id
where rf.shpm_id is not null
and sh.lgst_grp_cd = 'SEU'
-- ver 2.0
-- Marek Dziekanski, 2020-02-16
and trim(nvl(rf.rfrc_num,'NUL')) = '01'

{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;{R}D:\JobTemplates\del_rfrc_num.xml{R}SEU PFD/FND STEP 2: Deletes SHPFLG with the value 01{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}18{R}TENDER_TO_BODY_BUILD{R}SEU_SET_SHPFLG02_BB{R}{R}TENDER_TO_BODY_BUILD{R}{R}select to_char(psd.ld_leg_id) as ld_leg_id
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join ld_leg_detl_t psd on psd.shpm_id = sh.shpm_id 
inner join ld_leg_t ld on psd.ld_leg_id = ld.ld_leg_id
inner join shpg_loc_t sl on sl.shpg_loc_cd = sd.to_shpg_loc_cd
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'EXTE2'
where  ld.CUR_OPTLSTAT_ID = 305 -- planneds
-- also tendering all previous legs
and psd.seq_num <= sd.seq_num
and ld.lgst_grp_cd = 'SEU'
-- EXTE2 or FND is set to a date
and ( validate_conversion(substr(nvl(rf.rfrc_num,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi') = 1
    OR  validate_conversion(substr(nvl(sh.rfrc_num19,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi') = 1 
)
and upper(trim(nvl(sl.extl_cd2,'Nil'))) = 'BB' -- Body Build Location have it set to 'BB'
  -- not on financial hold
and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
  -- ver. 1.3
  -- Marek Dziekanski 2022-05-13 15:28
 -- not delivery stop
and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
group by psd.ld_leg_id
{R}{R}LoadTenderData.SystemLoadID=ld_leg_id; {R}D:\JobTemplates\processTender.xml{R}Tender Loads to body builders{R}processTender{R}API{EOL}{R}19{R}SEU_SET_SHPFLG02_BB{R}{R}{R}SEU_FLAG_TENDERED{R}UPD_SHPM_RFRC{R}select distinct sh.shpm_num
, substr(nvl(sh.rfrc_num3,'Nil') || '|' || nvl(rf.rfrc_num,'Nil') || '|' || to_char(el.flex_qnty1), 1, 70) as ref_num
, case nvl(rrf.rfrc_num_id, 0)
	when 0 then 'AT_ADD'
	else 'AT_UPDATE'
	end as activity
, rrf.rfrc_num_id as ref_id
, 'SHPFLG02' as code
from shpm_t sh
--inner join elmt_t el on el.shpm_id = sh.shpm_id
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join (select el.shpm_id as shpm_id, max(el.flex_qnty1) as flex_qnty1
    from elmt_t el
    group by el.shpm_id ) el on el.shpm_id = sh.shpm_id
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
left join rfrc_num_t rf
	inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'MRN'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rrf
	inner join dom_val_t ddm on ddm.val_enu = rrf.rfrc_num_typ and ddm.val_cd='SHPFLG02'
on rrf.shpm_id = sh.shpm_id
where ld.cur_optlstat_id in (310,320) -- tendered, tender accepted
and rrf.rfrc_num_id is null
--ver 1.3
-- Marek Dziekanski 2022-06-28 11:15
and ld.carr_cd in ('AXL', 'HOD', 'PAN', 'AHO', 'ROO')
and nvl(ld.updt_dtt, ld.crtd_dtt) > to_date('2022-03-22','yyyy-mm-dd')
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal></ReferenceNumberActionEnumVal>
     <ReferenceNumberCategoryEnumVal>RNC_SHPM</ReferenceNumberCategoryEnumVal>
     <ReferenceNumberEntityIdShipmentNumberFlag>TRUE</ReferenceNumberEntityIdShipmentNumberFlag>
     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <ReferenceNumberTypeCode></ReferenceNumberTypeCode>
     <ReferenceNumber></ReferenceNumber>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=SHPM_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE; {R}{R}Flag Tendered Loads{R}processMaintainEntityReferenceNumber{R}API{EOL}SDL_STR_SEU_UPD_BBUILD{R}1{R}SDL_STR_SEU_UPD_BBUILD{R}SEU_CHN_UPD_BB_LD_DATE_PFD{R}I_SET_SHPFLG_04{R}{R}{R}{R}{R}{R}{R}Starting point for Body Build update{R}{R}Chaining{EOL}{R}2{R}SEU_CHN_UPD_BB_LD_DATE_PFD{R}SEU_CHN_UPD_BB_LD_DATE_FND{R}I_SET_SHPFLG_04,I_SET_ETA,I_UPD_BBUILD_LD_DATE_FND{R}UPD_BBUILD_LD_DATE_PFD{R}{R}select to_char(sd.ld_leg_id) as ld_leg_id
, to_date(substr(nvl(rf.rfrc_num,'Nil'),1,16), 'yyyy-mm-dd"T"hh24:mi:ss') as sdl_date
, sh.shpm_num as shpm_num
, ld.carr_cd as carr_cd
, sd.pick_stop_seq_num as stop_num
, 'BBSCD' as event_code
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id  = sh.shpm_id
left join stop_t st on st.stop_id = sd.pick_stop_id
inner join ld_leg_t ld on ld.ld_leg_id     = sd.ld_leg_id
inner join shpg_loc_t lc on lc.shpg_loc_cd = sd.frm_shpg_loc_cd
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'BBPFD'
left join rfrc_num_t rrf
inner join dom_val_t fdm on fdm.val_enu = rrf.rfrc_num_typ and fdm.val_cd = 'BBFND'
on rrf.shpm_id = sh.shpm_id
  -- getting the leg from Body Builder location
where trim(upper(nvl(lc.extl_cd2,'Nil'))) = 'BB' -- all body builder locations have 'BB' in extl_cd2
and sd.cur_optlstat_id < 510 --CONFIRMED
--BBPFD set to a valid date
and validate_conversion(substr(nvl(rf.rfrc_num,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')  = 1
and validate_conversion(substr(nvl(rrf.rfrc_num,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')  = 0
  -- not on financial hold
and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
 -- not delivery stop
and UPPER(nvl(substr(sh.rfrc_num18, 1, 10),'NIL')) != 'YES'
  -- ver. 1.8.1
  -- Marek Dziekanski 2022-11-08 16:06
 -- the load hasn't been already updated
and trunc(nvl(st.carr_eta_dtt, to_date('1970-01-01','yyyy-mm-dd'))) != to_date(substr(nvl(rf.rfrc_num,'Nil'),1,10), 'yyyy-mm-dd')
{R}{R}{R}{R}Update Body Build Dates using PFD{R}{R}Chaining{EOL}{R}3{R}SEU_CHN_UPD_BB_LD_DATE_FND{R}SEU_RRT_LOAD_SHPFLG_04{R}I_SET_SHPFLG_04,I_SET_ETA,I_UPD_BBUILD_LD_DATE_FND{R}UPD_BBUILD_LD_DATE_FND{R}{R}select to_char(sd.ld_leg_id) as ld_leg_id, ld.scdd_dtt
, to_date(substr(nvl(rf.rfrc_num,'Nil'),1,16), 'yyyy-mm-dd"T"hh24:mi:ss') as sdl_date
, sh.shpm_num as shpm_num
, ld.carr_cd as carr_cd
, sd.pick_stop_seq_num as stop_num
, 'BBSCD' as event_code
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id  = sh.shpm_id
inner join stop_t st on st.stop_id = sd.pick_stop_id
inner join ld_leg_t ld on ld.ld_leg_id     = sd.ld_leg_id
inner join shpg_loc_t lc on lc.shpg_loc_cd = sd.frm_shpg_loc_cd
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'BBFND'
  -- getting the leg from Body Builder location
where trim(upper(nvl(lc.extl_cd2,'Nil'))) = 'BB' -- all body builder locations have 'BB' in extl_cd2
and ld.cur_optlstat_id < 345
and sd.cur_optlstat_id < 510 -- CONFIRMED
-- BBFND set to a valid date
and validate_conversion(substr(nvl(rf.rfrc_num,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi') = 1
  -- not on financial hold
and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
 -- not delivery stop
and UPPER(nvl(substr(sh.rfrc_num18, 1, 10),'NIL')) != 'YES'
  -- ver. 1.8.1
  -- Marek Dziekanski 2022-11-08 16:10
 -- the load hasn't been already updated
and trunc(nvl(st.carr_eta_dtt, to_date('1970-01-01','yyyy-mm-dd'))) != to_date(substr(nvl(rf.rfrc_num,'Nil'),1,10), 'yyyy-mm-dd')
{R}{R}{R}{R}Update Body Build Dates using FND{R}{R}Chaining{EOL}{R}4{R}SEU_RRT_LOAD_SHPFLG_04{R}SEU_RRT_BKGS_SHPFLG_04{R}{R}SEU_RRT_LOAD_SHPFLG_04{R}RRT_UNSPD{R}select to_char(sd.ld_leg_id) as  ld_leg_id
from ld_leg_detl_t sd
  inner join shpm_t sh on sh.shpm_id = sd.shpm_id
  inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
  inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
  inner join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG04'
  where sh.lgst_grp_cd = 'SEU'
    and ld.cur_optlstat_id < 345
    and sh.cur_optlstat_id < 260 -- delivered
-- ver: 1.1
-- Marek Dziekanski 2022-03-07 09:50
and rf.rfrc_num = '04' -- flag set for that job

{R}<CISDocument>
   <ApiHeader>
      <OperationName>processLoadRate</OperationName>
   </ApiHeader>
   <LoadRateData>
     <SystemLoadID></SystemLoadID>
   </LoadRateData>
	<IDsAreReferenceNumbersFlag>false</IDsAreReferenceNumbersFlag>
	<KeepSpotRateFlag>false</KeepSpotRateFlag>
	<SupressDetailedResultsFlag>true</SupressDetailedResultsFlag>
   <UncommitFlag>true</UncommitFlag>
</CISDocument>
{R}LoadRateData.SystemLoadID=LD_LEG_ID; {R}{R}Rerates Loads using API{R}processLoadRate{R}API{EOL}{R}5{R}SEU_RRT_BKGS_SHPFLG_04{R}SEU_CHN_UPD_CDD2_SHPFLG_04{R}{R}SEU_RRT_BKGS_SHPFLG_04{R}{R}select to_char(tp.trip_id) as trip_id
from trip_t tp
-- linked with a shipment that hasn't been delivered yet
where tp.lgst_grp_cd = 'SEU'
and exists (select 1 from ld_leg_t ld 
  join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
  join shpm_t sh on sh.shpm_id = sd.shpm_id
  join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
  join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG04'
  where  ld.trip_id = tp.trip_id
    and sh.lgst_grp_cd = 'SEU'
    and ld.cur_optlstat_id < 345
    and sh.cur_optlstat_id < 260 -- delivered
    and rf.rfrc_num = '04' -- flag set for that job
-- ver: 1.1
-- Marek Dziekanski 2022-03-18 09:50
) order by trip_id

{R}{R}TripRateData.SystemTripID=TRIP_ID;{R}D:\JobTemplates\rrt_bkgs.xml{R}Re-rate body build bookings {R}processTripRate{R}API{EOL}{R}6{R}SEU_CHN_UPD_CDD2_SHPFLG_04{R}SEU_DEL_SHPFLG_04{R}I_SEU_UPD_CDD2,I_SEU_UPD_PDEVCD{R}SEU_CHN_UPD_CDD2_SHPFLG_04{R}{R}select distinct sh.shpm_num as ref_key
, case greatest(trunc(st.last_cmpd_arvl_dtt), to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss'))
   -- when cdd is later no CDD2 is necessary
   when to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss') then 'Nil'
      -- otherwise set cdd2 to stop date
   else to_char(trunc(st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
  end as cdd2_ref_num
, case nvl(rf.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE'
  end as cdd2_action
, to_char(rf.rfrc_num_id) as cdd2_ref_id
 , case greatest(trunc(st.last_cmpd_arvl_dtt), to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss'))
   -- when cdd is later then if CDD2 was set set PDEVCD to 8 otherwise set it to nil
   when to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss') then case  trim(upper(nvl(sh.rfrc_num3,'NIL')))
                                                                  when 'NIL' then 'Nil'
                                                                  else '8'
                                                               end
-- if delivery is late set PDEVCD to 4
   else '4'
  end as devcd_ref_num
, case nvl(rfd.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE'
  end as devcd_action
, to_char(rfd.rfrc_num_id) as devcd_ref_id
from stop_t st
inner join ld_leg_detl_t sd on sd.drop_stop_id = st.stop_id
-- it is the last leg
inner join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
-- report CDD2 only for shipments having updated BPFD or BFND
inner join rfrc_num_t rrf on rrf.shpm_id = sh.shpm_id
inner join dom_val_t ddm on ddm.val_enu=rrf.rfrc_num_typ and ddm.val_cd='SHPFLG04'
-- joining CDD2 reference
left join rfrc_num_t rf
  inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd is not null and dm.val_cd='CDD2'
on rf.shpm_id = sh.shpm_id
-- joining reference with PDEVCD
left join rfrc_num_t rfd
  inner join dom_val_t dmd on rfd.rfrc_num_typ = dmd.val_enu and dmd.val_cd is not null and dmd.val_cd='PDEVCD'
on rfd.shpm_id = sh.shpm_id
where  st.shpm_drop > 0
and rrf.rfrc_num = '04' -- flag set for that job
and sh.lgst_grp_cd = 'SEU'
and st.last_cmpd_arvl_dtt is not null
-- CDD set to a proper date format
and regexp_like(nvl(sh.rfrc_num5,'Nil'),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]')
-- compare current CDD2 with the newly calculated to see if update is necessary
and substr(upper(nvl(rf.rfrc_num,'NULL')),1,10) != substr(
   -- compare stop date with cdd and take the bigger value
  case greatest(trunc(st.last_cmpd_arvl_dtt), to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss'))
   -- when cdd is later, no CDD2 is necessary
   when to_date(substr(sh.rfrc_num5,1,16), 'yyyy-mm-dd"T"hh24:mi:ss') then 'NIL'
      -- otherwise set cdd2 to stop date
   else to_char(trunc(st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
  end, 1,10)
-- ver. 1.2
-- marek dziekanski 2022-10-13 15:50
order by ref_key{R}{R}{R}{R}SEU Update CDD2 and PDEVCD{R}{R}Chaining{EOL}{R}7{R}SEU_DEL_SHPFLG_04{R}SEU_CHN_TENDER_FROM_BODY_BUILD{R}{R}SEU_DEL_SHPFLG_04{R}DEL_SHP_RFRC_NUM{R}select to_char(rf.shpm_id) as ref_key
, to_char(rf.rfrc_num_id) as ref_id
from rfrc_num_t rf 
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='SHPFLG04'
inner join shpm_t sh on sh.shpm_id = rf.shpm_id
where rf.shpm_id is not null
and sh.lgst_grp_cd = 'SEU'
-- ver 1.1
-- Marek Dziekanski, 2022-03-07 09:40
and trim(nvl(rf.rfrc_num,'NUL')) = '04'
{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal>AT_DELETE</ReferenceNumberActionEnumVal>
     <ReferenceNumberCategoryEnumVal>RNC_SHPM</ReferenceNumberCategoryEnumVal>
     <ReferenceNumberEntityIdShipmentNumberFlag>FALSE</ReferenceNumberEntityIdShipmentNumberFlag>
     <ReferenceNumberEntityKey></ReferenceNumberEntityKey>
     <SystemReferenceNumberID></SystemReferenceNumberID>
   </ReferenceNumberUpdateData>
</CISDocument>
{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;{R}{R}Delete SHPFLG set to 04 - used in Body Build{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}8{R}SEU_CHN_TENDER_FROM_BODY_BUILD{R}{R}TENDER_FROM_BODY_BUILD,I_SET_PLTRGTDTL_DATE{R}SEU_CHN_TENDER_FROM_BODY_BUILD{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, sd.frm_shpg_loc_cd
, to_char(st.last_cmpd_arvl_dtt, 'yyyy-mm-dd"T"hh24:mi') as rfrc_num
, case nvl(lf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
end as l_activity
,   lf.rfrc_num_id as l_rfrc_num_id
, 'PLNTRGDTL' as l_type_code
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
inner join ld_leg_t ld on sd.ld_leg_id = ld.ld_leg_id
inner join stop_t st on st.stop_id = sd.drop_stop_id
inner join shpg_loc_t sl on sl.shpg_loc_cd = sd.frm_shpg_loc_cd
inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'BBFND'
left join  rfrc_num_t lf
inner join dom_val_t lm on lm.val_enu= lf.rfrc_num_typ and lm.val_cd = 'PLNTRGDTL'
on lf.ld_leg_id = ld.ld_leg_id
where ld.CUR_OPTLSTAT_ID = 305 -- planneds
and ld.lgst_grp_cd = 'SEU'
-- a load from LAXASV or FND set to a date
and validate_conversion( case sd.frm_shpg_loc_cd
                            when 'LAXASV' then '1970-01-01T00:00'
                            else substr(nvl(sh.rfrc_num19,'Nil'),1,16)
                            end
            as date,'yyyy-mm-dd"T"hh24:mi') = 1
and upper(trim(nvl(sl.extl_cd2,'Nil'))) = 'BB' -- Body Build Location have it set to 'BB'
  -- not on financial hold
and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
  -- ver. 1.2.1
  -- Marek Dziekanski 2022-12-07 09:24
 -- not delivery stop
and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
{R}{R}{R}{R}Tender from BB and set Load Target date{R}{R}Chaining{EOL}SDL_STR_SLA_CHN_UPD_PFD_FND{R}1{R}SDL_STR_SLA_CHN_UPD_PFD_FND{R}SLA_DEL_SHPFLG_REFS{R}SLA_DEL_SHPFLG_REFS{R}{R}{R}{R}{R}{R}{R}SLA PFD/FND STEP 1: updating shipment using PFD / FND{R}{R}Chaining{EOL}{R}2{R}SLA_DEL_SHPFLG_REFS{R}SLA_CHN_UPD_PEAD{R}{R}SLA_DEL_SHPFLG_REFS{R}{R}select to_char(rf.shpm_id) as ref_key
, to_char(rf.rfrc_num_id) as ref_id
from rfrc_num_t rf 
inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='SHPFLG'
inner join shpm_t sh on sh.shpm_id = rf.shpm_id
where rf.shpm_id is not null
and sh.lgst_grp_cd = 'SLA'
-- ver 1.1
-- Marek Dziekanski, 2021-04-21 11:58
and trim(nvl(rf.rfrc_num,'NUL')) = '01'

{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;{R}D:\JobTemplates\del_rfrc_num.xml{R}SLA PFD/FND STEP 2: Deletes SHPFLG with the value 01{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}3{R}SLA_CHN_UPD_PEAD{R}SLA_CHN_UPD_EAD{R}I_UPD_PICKUP_FRM_REFS,I_SET_SHPFLG_01,I_UPD_PDEVCD{R}SLA_CHN_UPD_PEAD{R}{R}select sh.shpm_num as shpm_num
, to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') as pk_frm
-- if delivery to SLA External yard, then pick up the same date as manufactured
, case trim(nvl(sh.rfrc_num12,'Nil'))
   when '6' then to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') + 1438/1440
   else case sd.to_shpg_loc_cd when 'EXTYD' then
         to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') + 1438/1440
         else greatest(to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') + 1438/1440, sh.to_pkup_dtt)
         end
  end as pk_to
, to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') + 1/1440 as del_frm
, case trim(nvl(sh.rfrc_num12,'Nil'))
   when '6' then to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') + 1439/1440
  else greatest(to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') + 1439/1440, sh.to_dlvy_dtt)
 end  as del_to
-- Handling Product Deviations
, sh.shpm_num as ref_key
 , case validate_conversion(substr(nvl(sh.rfrc_num6,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
   -- WHEN CRD set to a date
   when 1 then
      case greatest(substr(sh.rfrc_num13, 1,10), substr(sh.rfrc_num6, 1,10))
        -- when PEAD > CRD set it to 4
        when substr(sh.rfrc_num13, 1,10) then cast('4' as varchar2(70))
        else
          -- if DEVCD set to 4, set it to 8
          case substr(nvl(prf.rfrc_num,'Nil'),1,1)
            when '4' then cast('8' as varchar2(70))
            else nvl(prf.rfrc_num, 'Nil')
          end
      end
   else nvl(sh.rfrc_num6,'Nil')
   end as devcd_ref_num
, case nvl(prf.rfrc_num_id,0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as devcd_action
, prf.rfrc_num_id as devcd_ref_id

from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id

left join rfrc_num_t prf
  inner join dom_val_t pdm on pdm.val_enu = prf.rfrc_num_typ and pdm.val_cd = 'PDEVCD'
on prf.shpm_id = sh.shpm_id
-- finish date set
where sh.lgst_grp_cd='SLA'
and validate_conversion(substr(nvl(sh.rfrc_num13,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 1
-- FND has higher priority
and  validate_conversion(substr(nvl(sh.rfrc_num19,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 0
-- EAD has higher priority
and  validate_conversion(substr(nvl(sh.rfrc_num9,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 0
-- PFD has higher priority
and  validate_conversion(substr(nvl(sh.rfrc_num4,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 0
and sh.cur_optlstat_id < 230 --picked
-- ver. 4.1
-- Marek Dziekanski 2023-02-01 10:30
-- and PEAD date (day) different than pickup from date
and to_date(substr(sh.rfrc_num13, 1, 10), 'yyyy-mm-dd') != trunc(sh.frm_pkup_dtt)


{R}{R}{R}{R}SLA PFD/FND STEP 3:  Chain, update Pickup using PEAD{R}{R}Chaining{EOL}{R}4{R}SLA_CHN_UPD_EAD{R}SLA_CHN_UPD_FND{R}I_UPD_PICKUP_FRM_REFS,I_SET_SHPFLG_01,I_UPD_PDEVCD{R}SLA_CHN_UPD_EAD{R}{R}select sh.shpm_num as shpm_num
, to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') as pk_frm
-- if delivery to SLA External yard, then pick up the same date as manufactured
, case trim(nvl(sh.rfrc_num12,'Nil'))
   when '6' then to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') + 1438/1440
   else case sd.to_shpg_loc_cd when 'EXTYD' then
         to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') + 1438/1440
         else greatest(to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') + 1438/1440, sh.to_pkup_dtt)
         end
  end as pk_to
, to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') + 1/1440 as del_frm
, case trim(nvl(sh.rfrc_num12,'Nil'))
   when '6' then to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') + 1439/1440
   else greatest(to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') + 1439/1440, sh.to_dlvy_dtt)
end as del_to
-- Handling Product Deviations
, sh.shpm_num as ref_key
 , case validate_conversion(substr(nvl(sh.rfrc_num6,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
   -- WHEN CRD set to a date
   when 1 then
      case greatest(substr(sh.rfrc_num9, 1,10), substr(sh.rfrc_num6, 1,10))
        -- when EAD > CRD set it to 4
        when substr(sh.rfrc_num9, 1,10) then cast('4' as varchar2(70))
        else
          -- if DEVCD set to 4, set it to 8
          case substr(nvl(prf.rfrc_num,'Nil'),1,1)
            when '4' then cast('8' as varchar2(70))
            else nvl(prf.rfrc_num, 'Nil')
          end
      end
   else nvl(sh.rfrc_num6,'Nil')
   end as devcd_ref_num
, case nvl(prf.rfrc_num_id,0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as devcd_action
, prf.rfrc_num_id as devcd_ref_id

from shpm_t sh
join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id

left join rfrc_num_t prf
  inner join dom_val_t pdm on pdm.val_enu = prf.rfrc_num_typ and pdm.val_cd = 'PDEVCD'
on prf.shpm_id = sh.shpm_id
where sh.lgst_grp_cd='SLA'
-- EAD date set
and validate_conversion(substr(nvl(sh.rfrc_num9,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 1
-- PFD has higher priority than FND for SLA because it is used for invoicing
and  validate_conversion(substr(nvl(sh.rfrc_num4,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 0
-- FND has higher priority
and  validate_conversion(substr(nvl(sh.rfrc_num19,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi:ss') = 0
and sh.cur_optlstat_id < 230 --picked
-- ver. 4.1
-- Marek Dziekanski 2023-02-01 10:37
-- and EAD date (day) different than pickup from date
and to_date(substr(sh.rfrc_num9, 1, 10), 'yyyy-mm-dd') != trunc(sh.frm_pkup_dtt)


{R}{R}{R}{R}SLA PFD/FND STEP 4:  Chain, update Pickup using EAD{R}{R}Chaining{EOL}{R}5{R}SLA_CHN_UPD_FND{R}SLA_CHN_UPD_PFD{R}I_UPD_PICKUP_FRM_FND,I_SET_SHPFLG_01,I_UPD_PDEVCD{R}SLA_CHN_UPD_FND{R}{R}select sh.shpm_num as shpm_num
, to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') as pk_frm
-- if delivery to SLA External yard, then pick up the same date as manufactured
, case trim(nvl(sh.rfrc_num12,'Nil'))
   when '6' then to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') + 1438/1440
   else case sd.to_shpg_loc_cd when 'EXTYD' then
         to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') + 1438/1440
         else greatest(to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') + 1438/1440, sh.to_pkup_dtt)
         end
  end as pk_to
, to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') + 1/1440 as del_frm
, case trim(nvl(sh.rfrc_num12,'Nil'))
   when '6' then to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') + 1439/1440
   else greatest(to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') + 1439/1440, sh.to_dlvy_dtt)
  end as del_to
-- Handling Product Deviations
, sh.shpm_num as ref_key
 , case validate_conversion(substr(nvl(sh.rfrc_num6,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
   -- WHEN CRD set to a date
   when 1 then
      case greatest(substr(sh.rfrc_num19, 1,10), substr(sh.rfrc_num6, 1,10))
        -- when FND > CRD set it to 4
        when substr(sh.rfrc_num19, 1,10) then cast('4' as varchar2(70))
        else
          -- if DEVCD set to 4, set it to 8
          case substr(nvl(prf.rfrc_num,'Nil'),1,1)
            when '4' then cast('8' as varchar2(70))
            else nvl(prf.rfrc_num, 'Nil')
          end
      end
   else nvl(sh.rfrc_num6,'Nil')
   end as devcd_ref_num
, case nvl(prf.rfrc_num_id,0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as devcd_action
, prf.rfrc_num_id as devcd_ref_id

from shpm_t sh
join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd

left join rfrc_num_t prf
  inner join dom_val_t pdm on pdm.val_enu = prf.rfrc_num_typ and pdm.val_cd = 'PDEVCD'
on prf.shpm_id = sh.shpm_id
-- finish date set
where sh.lgst_grp_cd='SLA'
and sd.ld_leg_id is not null -- a load exists
and regexp_like(substr(nvl(sh.rfrc_num19,'Nil'),1,16),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]')
-- PFD has higher priority than FND for SLA because it is used for invoicing
and NOT regexp_like(substr(nvl(sh.rfrc_num4,'Nil'),1,16),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]')
and sh.cur_optlstat_id < 230 --picked
-- ver. 4.1
-- Marek Dziekanski 2023-02-01 10:39
-- and finish date (day) different than pickup from date
and to_date(substr(sh.rfrc_num19, 1, 10), 'yyyy-mm-dd') != trunc(sh.frm_pkup_dtt)

{R}{R}{R}{R}SLA PFD/FND STEP 5:  Chain, update Pickup using FND{R}{R}Chaining{EOL}{R}6{R}SLA_CHN_UPD_PFD{R}SLA_RRT_UNSPD_SHGFLG_01{R}I_UPD_PICKUP_FRM_PFD,I_SET_SHPFLG_01,I_UPD_PDEVCD{R}SLA_CHN_UPD_PFD{R}{R}select sh.shpm_num as shpm_num
, to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') as pk_frm,
-- if delivery to SLA External yard, then pick up the same date as manufactured
case  upper(trim(nvl(sh.rfrc_num12,'Nil')))
   when '6' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 14/24
   when '4' then
      case sh.cust_cd
         when '68447' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 14/24
         when '65031' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 14/24
         else
            case sd.to_shpg_loc_cd
               when 'EXTYD' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1438/1440
               else greatest(to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1438/1440, sh.to_pkup_dtt)
            end
      end
   when 'NIL' then
      case sh.cust_cd
         when '68447' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 14/24
         when '65031' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 14/24
         else
            case sd.to_shpg_loc_cd
               when 'EXTYD' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1438/1440
               else greatest(to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1438/1440, sh.to_pkup_dtt)
            end
      end
   else
      case sd.to_shpg_loc_cd
         when 'EXTYD' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1438/1440
         else greatest(to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1438/1440, sh.to_pkup_dtt)
      end
end as pk_to ,

to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1/1440 as del_frm,

case  sh.cust_cd
   when '68477' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1439/1440
   when '65031' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1439/1440
   else
      case trim(nvl(sh.rfrc_num12,'Nil'))
         when '6' then to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1439/1440
         else greatest(to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') + 1439/1440, sh.to_dlvy_dtt)
      end
end as del_to
-- Handling Product Deviations
, sh.shpm_num as ref_key
 , case validate_conversion(substr(nvl(sh.rfrc_num6,'Nil'),1,16) as date,'yyyy-mm-dd"T"hh24:mi')
   -- WHEN CRD set to a date
   when 1 then
      case greatest(substr(sh.rfrc_num4, 1,10), substr(sh.rfrc_num6, 1,10))
        -- when PFD > CRD set it to 4
        when substr(sh.rfrc_num4, 1,10) then cast('4' as varchar2(70))
        else
          -- if DEVCD set to 4, set it to 8
          case substr(nvl(prf.rfrc_num,'Nil'),1,1)
            when '4' then cast('8' as varchar2(70))
            else nvl(prf.rfrc_num, 'Nil')
          end
      end
   else nvl(sh.rfrc_num6,'Nil')
   end as devcd_ref_num
, case nvl(prf.rfrc_num_id,0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as devcd_action
, prf.rfrc_num_id as devcd_ref_id

from shpm_t sh
join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd

left join rfrc_num_t prf
  inner join dom_val_t pdm on pdm.val_enu = prf.rfrc_num_typ and pdm.val_cd = 'PDEVCD'
on prf.shpm_id = sh.shpm_id
-- finish date set
where sh.lgst_grp_cd = 'SLA'
and sd.ld_leg_id is not null -- a load exists
and regexp_like(substr(nvl(sh.rfrc_num4,'Nil'),1,16),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]T[0-9][0-9]:[0-9][0-9]')
and sh.cur_optlstat_id < 230 --picked
-- ver. 4.1
-- Marek Dziekanski 2023-02-01 10:40
-- and PFD date (day) different than pickup from date
-- EXTYD - external yard, cust: 68477, 65031, Brasil, sh.rfrc_num12, Product deviation code
and to_date(substr(sh.rfrc_num4, 1, 10), 'yyyy-mm-dd') != trunc(sh.frm_pkup_dtt)

{R}{R}{R}{R}SLA PFD/FND STEP 6:  Chain, update Pickup using PFD{R}{R}Chaining{EOL}{R}7{R}SLA_RRT_UNSPD_SHGFLG_01{R}SLA_RRT_BKGS_SHPFLG_01{R}{R}SLA_RRT_UNSPD_SHPFLG_01{R}{R}select distinct to_char(ld.ld_leg_id) as leg_id
, nvl(ld.last_sec_cd, 'SUSP') as sec_cd
, current_date as dtt
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where upper(ld.ratg_vlid_yn) = 'F'
  and sh.lgst_grp_cd = 'SLA'
  and ld.sus_func_enu  > 1 -- 1=unsuspended
  and sh.cur_optlstat_id < 260 --delivered
  and rf.rfrc_num = '01' -- flag set for that job
--ver 1.2
-- Marek Dziekanski 2021-05-19 11:14
order by 1
{R}{R}SystemLoadID=LEG_ID;SECInformation.SECCode=SEC_CD;SECInformation.MovementDateTime=DTT;{R}D:\JobTemplates\rrt_unspnd.xml{R}SLA PFD/FND STEP 7: Unsuspend SLA Loads{R}processLoadUnSuspend{R}API{EOL}{R}8{R}SLA_RRT_BKGS_SHPFLG_01{R}SLA_RRT_LDS_SHPFLG_01{R}{R}SLA_RRT_BKGS_SHPFLG_01{R}{R}select to_char(tp.trip_id) as trip_id
from trip_t tp
-- linked with a shipment that hasn't been delivered yet
where exists (select 1 from ld_leg_t ld 
  join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
  join shpm_t sh on sh.shpm_id = sd.shpm_id
  join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
  join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
  where  ld.trip_id = tp.trip_id
    and sh.lgst_grp_cd = 'SLA'
    and ld.cur_optlstat_id < 345
    and sh.cur_optlstat_id < 260 -- delivered
    and rf.rfrc_num = '01' -- flag set for that job
-- ver: 1.1
-- Marek Dziekanski 2021-04-21 11:48
) order by trip_id
{R}{R}TripRateData.SystemTripID=TRIP_ID;{R}D:\JobTemplates\rrt_bkgs.xml{R}SLA PFD/FND STEP 8: Re-rate bookings for SHPFLG 01{R}processTripRate{R}API{EOL}{R}9{R}SLA_RRT_LDS_SHPFLG_01{R}SLA_UPD_CDD2{R}{R}SLA_RRT_LDS_SHPFLG_01{R}{R}select distinct to_char(ld.ld_leg_id) as leg_id
from ld_leg_t ld
join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
join shpm_t sh on sh.shpm_id = sd.shpm_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where ld.cur_optlstat_id < 345
and sh.lgst_grp_cd = 'SLA'
and rf.rfrc_num = '01'
  and not exists (select 1 from trip_t tt
  where tt.trip_id = ld.trip_id
-- ver 1.2
-- Marek Dziekanski 2021-05-19 11:17
) order by leg_id
  
{R}{R}LoadRateData.SystemLoadID=LEG_ID;{R}D:\JobTemplates\rrt_all.xml{R}SLA PFD/FND STEP 9: Re-rates loads SHPFLG 01{R}processLoadRate{R}API{EOL}{R}10{R}SLA_UPD_CDD2{R}SLA_UPD_CDD2_CUST_CD{R}{R}SLA_UPD_CDD2{R}{R}select sh.shpm_num as ref_key
, to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')   as ref_num
, case nvl(rf.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE' 
  end as action
, to_char(rf.rfrc_num_id) as ref_id
from stop_t st
inner join ld_leg_detl_t sd on sd.drop_stop_id = st.stop_id
-- it is the last leg
inner join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id 
inner join rfrc_num_t rfx on rfx.shpm_id = sh.shpm_id
inner join dom_val_t dmx on dmx.val_enu=rfx.rfrc_num_typ and dmx.val_cd='SHPFLG'
left join rfrc_num_t rf 
inner join dom_val_t dm 
   on rf.rfrc_num_typ = dm.val_enu and dm.val_cd is not null 
   and dm.val_cd='CDD2' on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rx
  inner join dom_val_t dx on rx.rfrc_num_typ = dx.val_enu and dx.val_cd = 'ORDCUST'
on rx.shpm_id = sh.shpm_id
where  st.shpm_drop > 0
and ld.cur_optlstat_id <= 320 --Tender Accepted
and trim(rfx.rfrc_num) = '01'
and sh.lgst_grp_cd = 'SLA'
-- there is PFD of FND set
and (
   regexp_like(substr(nvl(sh.rfrc_num4,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
   OR
   regexp_like(substr(nvl(sh.rfrc_num19,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
)
and st.last_cmpd_arvl_dtt is not null
-- those customers have alwyas CDD2 to PFD or FND
and case upper(sh.cust_cd) when 'SCANIA' then nvl(rx.rfrc_num, ' ')
   else sh.cust_cd
end NOT in ('68477','65031')
-- PDD is always set so ignore all records that don't have it set
and regexp_like(substr(nvl(sh.rfrc_num14,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
-- stop.last_cmpd_arvl_dtt > CDD or if CDD is Nul/Nil, PDD (preliminary delivery date)
and  substr(sh.rfrc_num5,1,10)   < substr(to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss'),1,10 )
-- compare current CDD2 with the newly calculated to see if update is necessary
AND nvl(rf.rfrc_num,'NULL') != to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
-- ver. 2.4
-- marek dziekanski 2021-08-23 10:46
order by ref_key, ref_id

{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTION;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;{R}D:\JobTemplates\upd_cdd2.xml{R}SLA PFD/FND STEP 10: Updates CDD2 field{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}11{R}SLA_UPD_CDD2_CUST_CD{R}SLA_UPD_CDD2_PDEVCD_6{R}{R}SLA_UPD_CDD2_CUST_CD{R}{R}select sh.shpm_num as ref_key
-- for the selected customers CDD2 is alwys FND or PFD
, case validate_conversion(substr(nvl(sh.rfrc_num4,'Nil'),1,10) as date,'yyyy-mm-dd')
   when 1 then sh.rfrc_num4
   else sh.rfrc_num19
 end as ref_num
, case nvl(rf.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE' 
  end as action
, to_char(rf.rfrc_num_id) as ref_id
from shpm_t sh
-- it is the last leg
inner join rfrc_num_t rfx on rfx.shpm_id = sh.shpm_id
inner join dom_val_t dmx on dmx.val_enu=rfx.rfrc_num_typ and dmx.val_cd='SHPFLG'

inner join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd='CDD2'

left join rfrc_num_t rx 
   inner join dom_val_t dx on rx.rfrc_num_typ = dx.val_enu and dx.val_cd = 'ORDCUST'
on rx.shpm_id = sh.shpm_id
where sh.lgst_grp_cd = 'SLA'
--and sh.cust_cd in ('68477','65031')
and case upper(sh.cust_cd) when 'SCANIA' then nvl(rx.rfrc_num, ' ')
   else sh.cust_cd
end  in ('68477','65031')
-- there is PFD of FND set
and (
   validate_conversion(substr(nvl(sh.rfrc_num4,'Nil'),1,10) as date,'yyyy-mm-dd') > 0
   OR
   validate_conversion(substr(nvl(sh.rfrc_num19,'Nil'),1,10) as date,'yyyy-mm-dd') > 0
)
-- PDD is always set so ignore all records that don't have it set
and validate_conversion(substr(nvl(sh.rfrc_num14,'Nil'),1,10) as date,'yyyy-mm-dd') > 0
-- stop.last_cmpd_arvl_dtt != CDD or if CDD is Nul/Nil, PDD (preliminary delivery date)
-- compare current CDD2 with the newly calculated to see if update is necessary
and  case validate_conversion(substr(nvl(sh.rfrc_num4,'Nil'),1,10) as date,'yyyy-mm-dd')
   when 1 then substr(sh.rfrc_num4, 1,10)
   else substr(sh.rfrc_num19, 1, 10)
 end !=nvl(rf.rfrc_num,'NULL')
-- ver. 1.3
-- marek dziekanski 2021-09-17 11:04
order by ref_key, ref_id
{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTION;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID; {R}D:\JobTemplates\upd_cdd2.xml{R}Updates CDD2 for selected customers{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}12{R}SLA_UPD_CDD2_PDEVCD_6{R}SLA_CDD2_UPD_PDEVCD_4{R}{R}SLA_UPD_CDD2_PDEVCD_6{R}{R}select sh.shpm_num as ref_key
, to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')   as ref_num
, case nvl(rf.rfrc_num_id,0) when 0 then
    'AT_ADD' ELSE 'AT_UPDATE' 
  end as action
, to_char(rf.rfrc_num_id) as ref_id
from stop_t st
inner join ld_leg_detl_t sd on sd.drop_stop_id = st.stop_id
-- it is the last leg
inner join shpm_t sh on sh.shpm_id = sd.shpm_id and sh.to_shpg_loc_cd = sd.to_shpg_loc_cd
inner join rfrc_num_t rfx on rfx.shpm_id = sh.shpm_id
inner join dom_val_t dmx on dmx.val_enu=rfx.rfrc_num_typ and dmx.val_cd='SHPFLG'
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id 
inner join rfrc_num_t rf 
inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd is not null and dm.val_cd='CDD2'
on rf.shpm_id = sh.shpm_id
left join rfrc_num_t rx
  inner join dom_val_t dx on rx.rfrc_num_typ = dx.val_enu and dx.val_cd = 'ORDCUST'
on rx.shpm_id = sh.shpm_id
where  st.shpm_drop > 0
and sh.lgst_grp_cd = 'SLA'
and trim(nvl(sh.rfrc_num12,'Nil')) = '6' --PDEVCD set to 6
-- there is PFD of FND set
and (
   regexp_like(substr(nvl(sh.rfrc_num4,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
   OR
   regexp_like(substr(nvl(sh.rfrc_num19,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
)
-- PDD is always set so ignore all records that don't have it set
and regexp_like(substr(nvl(sh.rfrc_num14,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and st.last_cmpd_arvl_dtt is not null
-- stop.last_cmpd_arvl_dtt != CDD or if CDD is Nul/Nil, PDD (preliminary delivery date)
and  substr(sh.rfrc_num5,1,10)   != substr(to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss'),1,10 )
-- compare current CDD2 with the newly calculated to see if update is necessary
AND nvl(rf.rfrc_num,'NULL') != to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss')
-- ver. 1.3
-- marek dziekanski 2021-08-19 14:14
order by ref_key, ref_id
{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTION;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID; {R}D:\JobTemplates\upd_cdd2.xml{R}SLA PFD/FND STEP 7.1: Updates CDD2 when PDEVCD = 6{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}13{R}SLA_CDD2_UPD_PDEVCD_4{R}SLA_CDD2_UPT_SHPM{R}{R}SLA_CDD2_UPD_PDEVCD_4{R}{R}select  sh.shpm_num as ref_key
, to_char(rf.rfrc_num_id) as ref_id
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_Id = sh.shpm_id and sd.to_shpg_loc_cd = sh.to_shpg_loc_cd
inner join stop_t st on st.stop_id = sd.drop_stop_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd='PDEVCD'
where  st.shpm_drop > 0
and sh.lgst_grp_cd = 'SLA'
-- CDD set to a date
and regexp_like(substr(nvl(sh.rfrc_num5,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
-- comparing string to avoid conversions errors 
and  substr(sh.rfrc_num5,1,10)   < substr(to_char((st.last_cmpd_arvl_dtt), 'yyyy-mm-dd"T"hh24:mi:ss'),1,10 )
and sh.cur_optlstat_id < 260 -- delivered
and trim(upper(nvl(rf.rfrc_num,'NIL'))) = 'NIL'
-- ver. 2.1
-- marek dziekanski 2021-04-08 23:28
order by ref_key

{R}{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=REF_KEY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID; {R}D:\JobTemplates\cdd2_upd_pdevcd_4.xml{R}SLA PFD/FND STEP 11: Updates PDEVCD field with 4 when cdd2 created{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}14{R}SLA_CDD2_UPT_SHPM{R}SLA_SEL_TO_TENDER{R}{R}SLA_CDD2_UPT_SHPM{R}{R}select sh.shpm_num as ref_key, dt.ld_leg_id
, greatest((trunc((st.cmpd_arvl_dtt)) + 0.00001), (sh.frm_pkup_dtt + 0.00069)) as frm_del
, case (trim(nvl(sh.rfrc_num5, 'NIL'))) 
-- if cdd is null, i.e. a booking
   when 'NIL' 
   then case regexp_instr (substr(nvl(sh.rfrc_num14, 'Nil'),1,10), '[0-9]{4}-[0-1][0-9]-[0-3][0-9]') 
   -- if PDD set, pick up the latest of PDD, stop arrival date, or shipment to pickup date
         when 1 then greatest(
            to_date(substr(sh.rfrc_num14, 1, 10), 'yyyy-mm-dd')
            , (trunc((st.cmpd_arvl_dtt)) + 0.99930)
            , (sh.to_pkup_dtt + 0.00001)
         )
         else
   --otherwise pick the later of stop arrival date and pickup to date
          greatest((trunc((st.cmpd_arvl_dtt)) + 0.99930), (sh.to_pkup_dtt + 0.00001))
         end
   else  greatest((trunc((st.cmpd_arvl_dtt)) + 0.99930), (sh.to_pkup_dtt + 0.00001))
end as to_del
, sh.frm_pkup_dtt
from stop_t st
join ld_leg_detl_t dt on dt.drop_stop_id = st.stop_id
join shpm_t sh on dt.shpm_id = sh.shpm_id
join rfrc_num_t rf on rf.shpm_id = sh.shpm_id
join dom_val_t dm on dm.val_enu=rf.rfrc_num_typ and dm.val_cd='SHPFLG'
where  st.shpm_drop > 0
and st.shpg_loc_cd = sh.to_shpg_loc_cd
and sh.lgst_grp_cd = 'SLA'
-- check if the record has not been already processed
and sh.frm_dlvy_dtt !=  greatest((trunc((st.cmpd_arvl_dtt)) + 0.00001), (sh.frm_pkup_dtt + 0.00069)) 
and sh.cur_optlstat_id < 230 -- picked
-- ver. 2.4
-- added frm_del
-- marek dziekanski 2021-03-24 11:05
{R}{R}Shipment.ShipmentNumber=REF_KEY;Shipment.DeliveryFromDateTime=FRM_DEL;Shipment.DeliveryToDateTime=TO_DEL;{R}D:\JobTemplates\cdd2_upt_shpm.xml{R}SLA PFD/FND STEP 12: Update Shipment with New CDD2{R}processShipmentOrderUpdate{R}API{EOL}{R}15{R}SLA_SEL_TO_TENDER{R}{R}{R}SLA_SEL_TO_TENDER{R}{R}select to_char(ld.ld_leg_id) ld_leg_id
from ld_leg_t ld
join shpm_t sh on sh.shpm_id = ld.shpm_id
where  ld.cur_optlstat_id = 305--planned
and ld.lgst_grp_cd = 'SLA'
-- finish date is set
and regexp_like (substr(nvl(sh.rfrc_num19, 'Nil'),1,10), '[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
and UPPER(nvl(sh.rfrc_num18,'NIL')) != 'YES'
-- and UPPER(nvl(sh.rfrc_num15,'NIL')) != 'HOLD'
-- not to France
-- and (sh.cust_cd != '61022' OR sh.frm_shpg_loc_cd != 'MA')
-- and ld.srvc_cd is not null
-- not ocean service
and upper(nvl(ld.srvc_cd,'NULL')) not in ('SSEA','SS','SSEA_PP','SSEA_PD','SSEA_DD','SSEA_DP'
, 'OCEAN_PP','OCEAN_PD','OCEAN_DD','OCEAN_DP')

-- SLA from 'ABCYD' must be order status = 500
and not exists (select ldx.ld_leg_id
  from ld_leg_t ldx
  join ld_leg_detl_t dtx on ldx.ld_leg_id = dtx.ld_leg_id
  join shpm_t shx on shx.shpm_id = dtx.shpm_id
  where UPPER(ldx.LGST_GRP_CD) ='SLA'
  and ldx.ld_leg_id = ld.ld_leg_id
  -- the leg to 'ABCYD', 'EXTYD' allowed in other than 500 status
  and upper(dtx.to_shpg_loc_cd) != 'EXTYD'
    and shx.rfrc_num16 != '500' -- order status other than 500
    -- there must be a leg to the 'ABCYD' or 'EXTYD' yard location
  and exists (select 1 from ld_leg_detl_t dtxx
                join shpm_t shxx on shxx.shpm_id=dtxx.shpm_id
                and upper(dtxx.to_shpg_loc_cd) = 'EXTYD'
              )
  -- ver. 2.2
  -- Marek Dziekanski 2022-07-05 01:10
)
{R}{R}LoadTenderData.SystemLoadID=ld_leg_id;{R}D:\JobTemplates\processTender.xml{R}SLA PFD/FND STEP 13: Tender SLA Loads{R}processTender{R}API{EOL}SDL_STR_UPD_LD_VSL_BK_TCD{R}1{R}SDL_STR_UPD_LD_VSL_BK_TCD{R}UPD_LD_OCEANBKLD{R}{R}UPD_LD_TCD{R}RFRC_LD{R}select distinct to_char(sd1.ld_leg_id) as ld_leg_id
, to_char(tr.cntr_yard_dtt, 'yyyy-mm-dd"T"hh24:mi:ss') as REF_NUM
, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
 end as activity
, 'TCD' as code
from ld_leg_t ld
inner join trip_t tr on tr.trip_id = ld.trip_id
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join ld_leg_detl_t sd1 on sd1.shpm_id = sd.shpm_id 
left join rfrc_num_t rf 
    inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'TCD'
on rf.ld_leg_id = sd1.ld_leg_id
where tr.cntr_yard_dtt is not null
and sd1.ld_leg_id is not null
and ld.cur_optlstat_id < 345 -- not completed yet
and trim(nvl(rf.rfrc_num,'Nil')) != to_char(tr.cntr_yard_dtt, 'yyyy-mm-dd"T"hh24:mi:ss')
-- ver. 1.0
-- Marek Dziekanski 2022-03-01 15:44
order by ld_leg_id
{R}<CISDocument>
