      <AlertEntityTypeEnumVal>ALERTENTTYPE_STOP</AlertEntityTypeEnumVal>
      <AlertText></AlertText>	   
      <AlertSeverityEnumVal>ALRTSVRTY_GREEN</AlertSeverityEnumVal>	
   </AlertData>
</CISDocument>
