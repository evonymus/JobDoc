{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=LD_LEG_ID;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE; {R}{R}Update Load Bookings Reference Numbers{R}processMaintainEntityReferenceNumber{R}API{EOL}{R}2{R}UPD_LD_OCEANBKLD{R}UPD_LD_OCEANVSLD{R}{R}UPD_LD_OCEANBKLD{R}RFRC_LD{R}select distinct to_char(sd1.ld_leg_id) as ld_leg_id
, nvl(tr.carr_cd,' ') || ' ' || tr.rfrc_num1 as REF_NUM
, to_char(rf.rfrc_num_id) as ref_id
, case nvl(rf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
 end as activity
, 'OCEANBKLD' as code
FROM LD_LEG_T LD
inner join trip_t tr on tr.trip_id = ld.trip_id
inner join ld_leg_detl_t sd on sd.ld_leg_id = ld.ld_leg_id
inner join ld_leg_detl_t sd1 on sd1.shpm_id = sd.shpm_id 
inner join ld_leg_t ldd on ldd.ld_leg_id = sd1.ld_leg_id
left join rfrc_num_t rf 
    inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd = 'OCEANBKLD'
on rf.ld_leg_id = sd1.ld_leg_id
where tr.vesl is not null
and tr.rfrc_num1 is not null
and ld.cur_optlstat_id < 345 -- not completed yet
and trim(nvl(rf.rfrc_num,'Nil')) !=nvl(tr.carr_cd,' ') || ' ' || tr.rfrc_num1
-- ver. 1.2.1
-- Marek Dziekanski 2022-03-02 12:43
order by ld_leg_id{R}<CISDocument>
   <ApiHeader>
      <OperationName>processMaintainEntityReferenceNumber</OperationName>
   </ApiHeader>
   <ReferenceNumberUpdateData>
     <ReferenceNumberActionEnumVal></ReferenceNumberActionEnumVal>
