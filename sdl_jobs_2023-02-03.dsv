{R}LoadTenderData.SystemLoadID=LD_LEG_ID;LoadTenderData.CarrierCode=CARRIER_CD; {R}{R}Update a Tender{R}processTenderUpdate{R}API{EOL}{R}6{R}SEU_CHN_LDFLG_03_DELETE{R}SEU_CHN_TDEVCD_FLG_SHPM{R}I_DEL_LD_RFRC{R}SEU_LDFLG_03_DELETE{R}{R}select to_char(ld.ld_leg_id) as ld_leg_id
, to_char(rf.rfrc_num_id) as rfrc_num_id
, ld.carr_cd
from ld_leg_t ld
inner join rfrc_num_t rf on rf.ld_leg_id = ld.ld_leg_id
inner join dom_val_t dm on rf.rfrc_num_typ = dm.val_enu and dm.val_cd = 'LDFLG'
where ld.lgst_grp_cd = 'SEU'
-- ver: 1.1
-- Marek Dziekanski 2022-02-22 17:12
and rf.rfrc_num = '03'
{R}{R}{R}{R}Delete LDFLG=03 for SEU{R}{R}Chaining{EOL}{R}7{R}SEU_CHN_TDEVCD_FLG_SHPM{R}SEU_ARR_ETA_CDD2_UPD{R}I_SET_SHPM_RFRC{R}SEU_CHN_TDEVCD_FLG_SHPM{R}{R}select sh.shpm_num as ref_key
-- I_SET_SHPM_RFRC
, sh.shpm_num as shpm_num -- used by I_SET_SHPM_RFRC
, case nvl(srf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as s_activity
, cast('03' as varchar2(70)) as s_ref_num
, to_char(srf.rfrc_num_id) as s_rfrc_num_id
, cast('SHPFLG03' as varchar2(80)) as S_REF_TYPE
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.to_shpg_loc_cd != sh.to_shpg_loc_cd
inner join stop_t st on sd.drop_stop_id = st.stop_id
inner join stop_t dt on sd.pick_stop_id = dt.stop_id
inner join op_ap_statnst_t op on op.ld_leg_detl_id = sd.ld_leg_detl_id 
left join rfrc_num_t srf
  inner join dom_val_t sdm on sdm.val_enu = srf.rfrc_num_typ and sdm.val_cd='SHPFLG03'
on srf.shpm_id = sh.shpm_id
where substr(op.sec_cd, 1, 2) in ('1','13','14','20','21' , '31','45','67','SC','82')
and sh.cur_optlstat_id < 260 -- completed
and nvl(dt.carr_eta_dtt,st.carr_eta_dtt) is not null
-- CDD is set to a date
and regexp_like ( substr(nvl(sh.rfrc_num5,'Nil'), 1, 10),'[0-9]{4}-[0-1][0-9]-[0-3][0-9]')
-- stop date later than CDD
and greatest(
  nvl(dt.carr_eta_dtt, to_date('1970-01-01','yyyy-mm-dd'))
  ,nvl(st.carr_eta_dtt, to_date('1970-01-01','yyyy-mm-dd'))
  ) > case validate_conversion(nvl(sh.rfrc_num3,'Nil') as date, 'yyyy-mm-dd"T"hh24:mi:ss')
    when 1 then to_date(substr(sh.rfrc_num3, 1, 10), 'yyyy-mm-dd')
    else to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
    end
group by sh.shpm_num, sh.rfrc_num5,  sh.rfrc_num3, srf.rfrc_num_id
having case greatest( 
        greatest(
            nvl(max(st.carr_eta_dtt), to_date('1970-01-01', 'yyyy-mm-dd'))
          , nvl(max(dt.carr_eta_dtt), to_date('1970-01-01','yyyy-mm-dd'))
        )
       , to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
    )
    when to_date(substr(sh.rfrc_num5, 1, 10), 'yyyy-mm-dd')
      then 'Nil'
    else to_char( greatest( 
      nvl(max(st.carr_eta_dtt), to_date('1970-01-01','yyyy-mm-dd'))
    , nvl(max(dt.carr_eta_dtt), to_date('1970-01-01','yyyy-mm-dd')) 
    ), 'yyyy-mm-dd"T"hh24:mi:ss')
-- ver 1.1.2
-- Marek Dziekanski 2022-04-28 11:56:55 
   end != nvl(sh.rfrc_num3,'Nil')


{R}{R}{R}{R}Flag TDEVCD5 Shipments that need re-rating{R}{R}Chaining{EOL}{R}8{R}SEU_ARR_ETA_CDD2_UPD{R}SEU_RRT_LOAD_SHPFLG_03{R}{R}SEU_ARR_ETA_CDD2_UPD{R}SET_SHPM_RFRC_NUM{R}select sh.shpm_num as ref_key
-- I_SET_SHPM_RFRC
, sh.shpm_num as shpm_num -- used by I_SET_SHPM_RFRC
, case nvl(srf.rfrc_num_id, 0)
    when 0 then 'AT_ADD'
    else 'AT_UPDATE'
  end as s_activity
, cast('03' as varchar2(70)) as s_ref_num
, to_char(srf.rfrc_num_id) as s_rfrc_num_id
, cast('SHPFLG03' as varchar2(80)) as S_REF_TYPE
from shpm_t sh
left join rfrc_num_t srf
  inner join dom_val_t sdm on sdm.val_enu = srf.rfrc_num_typ and sdm.val_cd='SHPFLG03'
on srf.shpm_id = sh.shpm_id
where exists (select 1 from ld_leg_t ld
    inner join ld_leg_detl_t sd on ld.ld_leg_id = sd.ld_leg_id
    inner join stop_t st on st.stop_id = sd.pick_stop_id

    where sd.shpm_id = sh.shpm_id
    and ld.cur_optlstat_id between 320 and 340
    and ld.lgst_grp_cd = 'SEU'
    and srf.rfrc_num_id is NULL -- flag not already set

    and case upper(nvl(sh.rfrc_num3, 'NIL'))
        when 'NIL' then sh.rfrc_num5 --CDD
        else case validate_conversion(substr(sh.rfrc_num3,1,16) as date, 'yyyy-mm-dd"T"hh24:mi')
                when 1 then sh.rfrc_num3
                else sh.rfrc_num5
              end
    end  < to_char(st.last_cmpd_arvl_dtt, 'yyyy-mm-dd')
-- ver 1.1
-- Marek Dziekanski 2022-11-18 10:11
)
