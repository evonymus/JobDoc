{R}ReferenceNumberUpdateData.ReferenceNumberEntityKey=LD_LEG_ID;ReferenceNumberUpdateData.ReferenceNumberActionEnumVal=ACTIVITY;ReferenceNumberUpdateData.SystemReferenceNumberID=REF_ID;ReferenceNumberUpdateData.ReferenceNumber=REF_NUM;ReferenceNumberUpdateData.ReferenceNumberTypeCode=CODE; {R}{R}Update Load LTDEV5CD Reference Number to 5{R}processMaintainEntityReferenceNumber{R}API{EOL}SDL_SEU_CONFIRM_SCFP_DELIVERY{R}1{R}SDL_SEU_CONFIRM_SCFP_DELIVERY{R}{R}{R}SEU_CONFIRM_SCFP_DELIVERY{R}CONFIRM_ARRIVAL{R}select to_char(ld.ld_leg_id) as load_id
, to_char(sd.drop_stop_id) as drop_stop_id
from shpm_t sh
-- always 1st leg
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id and sd.frm_shpg_loc_cd = sh.frm_shpg_loc_cd
inner join ld_leg_t ld on ld.ld_leg_id = sd.ld_leg_id
where sd.frm_shpg_loc_cd in ( 'MS','MZ','MA')
and ld.srvc_cd in ('SFPU','SFPUR')
and ld.carr_cd = 'SCFP'
-- ver. 1.0
-- Marek Dziekanski 2022-06-28 14:31
and ld.cur_optlstat_id = 335 -- In Transit
{R}<CISDocument>
