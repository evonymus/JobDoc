{R}AlertData.EntityID=SHPM_ID;AlertData.AlertText=TEXT;AlertData.AlertTypeCode=ALRT_TYPE_CODE; {R}{R}Alert Vessel Departure{R}processGenerateAlert{R}API{EOL}SDL_ALRT_ETA{R}1{R}SDL_ALRT_ETA{R}{R}{R}ALRT_ETA{R}{R}select distinct to_char(st.stop_id) as stop_id
, 'MSG:ETA:' || to_char(st.carr_eta_dtt,'yyyymmddhh24mi') || '  Chassis No: ' || SD.SHPM_NUM 
  || ' , Customer Name: ' || sd.cust_name
  || ' , COW Customer: ' || nvl(rf.rfrc_num,' ')
  || ' , ETA: ' || to_char(st.carr_eta_dtt, 'yyyy-mm-dd hh24:mi') 
  || ' , City: ' || sd.to_cty_name
  || ', In case of any question on the products mentioned in this mail, or if you want to unsuscribe, please contact the Deliery Service Desk. '
  || ', Sweden: dsd.sodertalje@scania.com'
  || ', The Netherlands: dsd.zwolle@scania.com'
  || ', France: delivery.servicedeskangers@scania.com'
  as text
from stop_t st
join ld_leg_detl_t sd on sd.ld_leg_id = st.ld_leg_id
left join rfrc_num_t rf
   inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='CSTADD'
on rf.shpm_id = sd.shpm_id
where st.carr_eta_dtt is not null
-- the stop has not been alerted yet
and not exists (select 1 from MNTR_ACTY_T mon
  where mon.stop_id = st.stop_id
  and mon.alrt_typ_cd ='RPT_ETA'
  and substr(nvl(mon.alrt_text,'NULL'),1,20) = 'MSG:ETA:' || to_char(st.carr_eta_dtt,'yyyymmddhh24mi')
  -- ver 1.5
  -- Marek Dziekanski, 2022-03-28 13:13
)

{R}{R}AlertData.EntityID=STOP_ID;AlertData.AlertText=TEXT; {R}D:\JobTemplates\alrt_eta.xml{R}Report Revised ETA change{R}processGenerateAlert{R}API{EOL}SDL_ALRT_ETA_MA{R}1{R}SDL_ALRT_ETA_MA{R}{R}{R}ALRT_ETA_MA{R}ALRT_SHPM{R}select distinct to_char(sh.shpm_id) as shpm_id, mna.mntr_acty_id
	,'RPT_CDD2_MA' as alrt_type_code
	, 'MSG:CDD2:' || substr(sh.rfrc_num3,1,10) 
  || ', Chassis No: ' || sh.shpm_num 
	|| ', Customer Name: ' || nvl(rf.rfrc_num,' ')
	|| ', Shipment Destination Location Code:' || sh.to_shpg_loc_cd
	|| ', City: ' || sd.to_cty_name
	as text
from shpm_t sh
inner join ld_leg_detl_t sd on sd.shpm_id = sh.shpm_id
-- select the last record with the alert to compare
left join ( select max(mn.mntr_acty_id) as mntr_acty_id
		, mn.shpm_num
		 from mntr_acty_t mn,  shpm_t xsh
		 where xsh.shpm_num = mn.shpm_num
				and mn.alrt_typ_cd = 'RPT_CDD2_MA'  
	group by mn.shpm_num
) aa on aa.shpm_num = sh.shpm_num
left join mntr_acty_t mna on aa.mntr_acty_id = mna.mntr_acty_id
left join rfrc_num_t rf 
 -- inner join to the left joined reference table
 inner join dom_val_t dm on dm.val_enu = rf.rfrc_num_typ and dm.val_cd='ORDCNAM'
on rf.shpm_id = sh.shpm_id
where sh.cur_optlstat_id < 260 -- delivered
and sh.frm_shpg_loc_cd = 'MA'
and regexp_like(substr(nvl(sh.rfrc_num3,'Nil'),1,10),'[0-9]{4}-[0-9][0-9]-[0-3][0-9]')
and substr(sh.rfrc_num3,1,10) > '2022-06-09'
-- ver 1.0
-- Marek Dziekanski 2022-05-27 12:51
and substr(nvl(mna.alrt_text,'NULL'),1,19) != ('MSG:CDD2:' || substr(sh.rfrc_num3,1,10)){R}<?xml version="1.0" encoding="UTF-8"?>
